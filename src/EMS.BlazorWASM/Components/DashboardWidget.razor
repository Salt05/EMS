<div class="relative overflow-hidden rounded-xl bg-white p-6 border border-border shadow-bento hover:shadow-bento-hover transition-all duration-300">
    <div class="flex items-center justify-between">
        <span class="text-sm font-medium text-muted">@Title</span>
        <div class="flex items-center gap-2">
            @if (IsDemo)
            {
                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-100 text-amber-800" title="Dữ liệu mô phỏng - API chưa sẵn sàng">
                    ⏳ DEMO
                </span>
            }
            <div class="text-charcoal p-2 bg-canvas rounded-lg">
                @Icon
            </div>
        </div>
    </div>
    
    <div class="mt-4 flex items-baseline justify-between">
        <div class="text-2xl font-bold tracking-tight text-charcoal">@Value</div>
        @if (!string.IsNullOrEmpty(Trend))
        {
            <div class="flex items-center text-xs font-semibold @(TrendDirection == "up" ? "text-emerald-600" : TrendDirection == "down" ? "text-rose-600" : "text-muted")">
                @if (TrendDirection == "up")
                {
                    <svg class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
                    </svg>
                }
                else if (TrendDirection == "down")
                {
                    <svg class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                    </svg>
                }
                <span>@Trend</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = "0";
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public string? Trend { get; set; }
    [Parameter] public string TrendDirection { get; set; } = "none";
    [Parameter] public bool IsDemo { get; set; } = false;
}
