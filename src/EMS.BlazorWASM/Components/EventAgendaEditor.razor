@using EMS.Shared.DTOs
@using EMS.BlazorWASM.Services
@inject IAgendaServiceClient AgendaService
@inject ToastService ToastService

<div class="bg-white border border-border rounded-xl p-6 shadow-sm mb-6">
    <!-- Header -->
    <div class="flex items-center justify-between mb-4 pb-3 border-b border-border">
        <div>
            <h3 class="text-lg font-bold text-charcoal flex items-center gap-2">
                <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Lịch trình sự kiện
            </h3>
            <p class="text-xs text-muted mt-0.5">Phân chia các giai đoạn / tiết mục và thời gian duy trì của chương trình</p>
        </div>
        <button type="button" @onclick="OpenAddModal" class="px-3.5 py-2 text-xs font-semibold text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg transition-colors flex items-center gap-1.5 shadow-sm">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            + Thêm mốc giai đoạn
        </button>
    </div>

    <!-- Agenda Items List -->
    @if (isLoading)
    {
        <div class="py-8 text-center text-xs text-muted">
            Đang tải danh sách lịch trình...
        </div>
    }
    else if (agendaItems == null || !agendaItems.Any())
    {
        <div class="py-8 text-center bg-canvas rounded-xl border border-dashed border-border">
            <svg class="w-8 h-8 text-muted mx-auto mb-2 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-xs font-medium text-muted">Chưa có giai đoạn nào được tạo cho sự kiện này.</p>
            <button type="button" @onclick="OpenAddModal" class="mt-2 text-xs font-semibold text-indigo-600 hover:underline">
                + Thêm mốc giai đoạn đầu tiên
            </button>
        </div>
    }
    else
    {
        @if (HasOutOfBoundsItems())
        {
            <div class="p-3 bg-rose-50 border border-rose-200 text-rose-700 text-xs rounded-xl font-medium mb-4 flex items-center gap-2 animate-fadeIn">
                <svg class="w-4 h-4 text-rose-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                <span>Phát hiện mốc lịch trình (tô đỏ) nằm ngoài khoảng thời gian sự kiện mới. Vui lòng bấm Sửa để điều chỉnh lại mốc đó.</span>
            </div>
        }

        <div class="divide-y divide-border border border-border rounded-xl overflow-hidden bg-white">
            @for (int i = 0; i < agendaItems.Count; i++)
            {
                var item = agendaItems[i];
                var index = i + 1;
                var itemStart = item.StartTime.ToLocalTime();
                var itemEnd = item.EndTime.ToLocalTime();
                var isOutOfBounds = itemStart < EventStartTime.ToLocalTime() || itemEnd > EventEndTime.ToLocalTime();

                <div class="py-3.5 flex items-center justify-between transition-colors px-3 text-xs @(isOutOfBounds ? "bg-rose-50/90 border-l-4 border-l-rose-600" : "hover:bg-canvas/50")">
                    <div class="flex items-center gap-3 flex-wrap">
                        <span class="w-6 h-6 rounded-full @(isOutOfBounds ? "bg-rose-200 text-rose-800" : "bg-indigo-100 text-indigo-700") text-[11px] font-bold flex items-center justify-center">
                            @index
                        </span>

                        <!-- Khung thời gian -->
                        <div class="px-2.5 py-1 text-xs font-mono font-bold @(isOutOfBounds ? "text-rose-800 bg-rose-100 border-rose-200" : "text-indigo-700 bg-indigo-50 border-indigo-100") rounded-md border whitespace-nowrap">
                            @itemStart.ToString("HH:mm") - @itemEnd.ToString("HH:mm")
                        </div>

                        <!-- Thời gian duy trì -->
                        <div class="px-2.5 py-1 text-xs font-semibold @(isOutOfBounds ? "text-rose-800 bg-rose-100 border-rose-200" : "text-emerald-700 bg-emerald-50 border-emerald-200") rounded-md border flex items-center gap-1 whitespace-nowrap" title="Thời gian duy trì sự kiện">
                            <svg class="w-3.5 h-3.5 @(isOutOfBounds ? "text-rose-600" : "text-emerald-600")" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>@FormatDuration(itemStart, itemEnd)</span>
                        </div>

                        @if (isOutOfBounds)
                        {
                            <span class="px-2 py-0.5 text-[11px] font-bold text-rose-700 bg-rose-100 border border-rose-300 rounded flex items-center gap-1">
                                <svg class="w-3.5 h-3.5 text-rose-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                ⚠️ Vượt ngoài thời gian sự kiện
                            </span>
                        }

                        <!-- Nội dung giai đoạn -->
                        <div class="text-xs font-semibold @(isOutOfBounds ? "text-rose-900 font-bold" : "text-charcoal") ms-1">
                            @item.Title
                        </div>
                    </div>

                    <!-- Nút Thao tác -->
                    <div class="flex items-center gap-1 shrink-0">
                        <button type="button" @onclick="() => EditItem(item)" class="px-2.5 py-1 text-xs font-semibold @(isOutOfBounds ? "text-rose-800 bg-rose-100 hover:bg-rose-200 border-rose-300" : "text-indigo-600 bg-indigo-50 hover:bg-indigo-100 border-indigo-100") rounded-md border transition-colors flex items-center gap-1" title="Chỉnh sửa">
                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                            </svg>
                            Sửa
                        </button>
                        <button type="button" @onclick="() => DeleteItem(item.Id)" class="p-1.5 text-muted hover:text-rose-600 hover:bg-rose-50 rounded-md transition-colors" title="Xóa">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Modal / Popup Thêm & Chỉnh sửa Giai đoạn -->
@if (showModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-charcoal/60 backdrop-blur-sm animate-fadeIn">
        <div class="bg-white border border-border rounded-2xl shadow-2xl max-w-xl w-full p-6 relative">
            <!-- Close Button -->
            <button type="button" @onclick="CloseModal" class="absolute top-4 right-4 text-muted hover:text-charcoal p-1 rounded-lg">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>

            <!-- Modal Header -->
            <div class="mb-5 pb-3 border-b border-border">
                <h3 class="text-base font-bold text-charcoal">
                    @(editingId == null ? "Thêm mốc giai đoạn mới" : "Chỉnh sửa mốc giai đoạn")
                </h3>
                <p class="text-xs text-muted mt-0.5">
                    Giới hạn: Tối thiểu @FormatTime(calculatedMinTime) đến tối đa @FormatTime(calculatedMaxTime)
                </p>
            </div>

            <!-- Content Title Input -->
            <div class="mb-5">
                <label class="block text-xs font-semibold text-charcoal mb-1.5">
                    Nội dung tiết mục / Hoạt động giai đoạn <span class="text-rose-500">*</span>
                </label>
                <input type="text" placeholder="Ví dụ: Đón khách & Check-in vé QR" 
                       class="w-full px-3.5 py-2.5 text-xs border border-border rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none bg-canvas/30" 
                       @bind="formTitle" />
            </div>

            <!-- Range Slider Box -->
            <div class="mb-5 p-4 bg-indigo-50/40 border border-indigo-100 rounded-xl space-y-3">
                <div class="flex items-center justify-between text-xs font-semibold text-indigo-900">
                    <span>Điều chỉnh mốc thời gian bằng Range Slider:</span>
                    <span class="px-2.5 py-1 text-xs font-bold text-emerald-800 bg-emerald-100/80 border border-emerald-200 rounded-md">
                        ⏱ Duy trì: @FormatDuration(formStartTime, formEndTime)
                    </span>
                </div>

                <!-- Range Slider Inputs -->
                <div class="space-y-2 py-2">
                    <div class="flex items-center gap-3">
                        <span class="text-xs text-muted font-mono w-16">Bắt đầu:</span>
                        <input type="range" 
                               min="0" 
                               max="@sliderMaxSpanMinutes" 
                               step="1" 
                               value="@sliderStartMinutes" 
                               @oninput="OnStartSliderInput"
                               class="w-full accent-indigo-600 h-2 bg-slate-200 rounded-lg cursor-pointer" />
                        <span class="text-xs font-bold font-mono text-indigo-700 w-16 text-right">
                            @FormatTime(formStartTime)
                        </span>
                    </div>

                    <div class="flex items-center gap-3">
                        <span class="text-xs text-muted font-mono w-16">Kết thúc:</span>
                        <input type="range" 
                               min="0" 
                               max="@sliderMaxSpanMinutes" 
                               step="1" 
                               value="@sliderEndMinutes" 
                               @oninput="OnEndSliderInput"
                               class="w-full accent-indigo-600 h-2 bg-slate-200 rounded-lg cursor-pointer" />
                        <span class="text-xs font-bold font-mono text-indigo-700 w-16 text-right">
                            @FormatTime(formEndTime)
                        </span>
                    </div>
                </div>

                <div class="flex items-center justify-between text-[11px] text-muted border-t border-indigo-100 pt-2 font-mono">
                    <span>Min: @FormatTime(calculatedMinTime)</span>
                    <span>Max: @FormatTime(calculatedMaxTime)</span>
                </div>
            </div>

            <!-- Manual DateTime Inputs (Synchronized) -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-5">
                <div>
                    <label class="block text-xs font-medium text-charcoal mb-1">Thời gian bắt đầu (Thủ công)</label>
                    <input type="datetime-local" 
                           class="w-full px-3 py-2 text-xs border border-border rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none bg-white" 
                           value="@formStartTime.ToString("yyyy-MM-ddTHH:mm")" 
                           @onchange="OnManualStartTimeChange" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-charcoal mb-1">Thời gian kết thúc (Thủ công)</label>
                    <input type="datetime-local" 
                           class="w-full px-3 py-2 text-xs border border-border rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none bg-white" 
                           value="@formEndTime.ToString("yyyy-MM-ddTHH:mm")" 
                           @onchange="OnManualEndTimeChange" />
                </div>
            </div>

            <!-- Error Notification -->
            @if (!string.IsNullOrEmpty(formError))
            {
                <div class="text-xs text-rose-600 bg-rose-50 p-3 rounded-xl mb-4 border border-rose-200 flex items-start gap-2">
                    <svg class="w-4 h-4 text-rose-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>@formError</span>
                </div>
            }

            <!-- Footer Action Buttons -->
            <div class="flex items-center justify-end gap-3 border-t border-border pt-4">
                <button type="button" @onclick="CloseModal" class="px-4 py-2 text-xs font-semibold text-charcoal bg-white border border-border hover:bg-canvas rounded-xl transition-colors">
                    Hủy bỏ
                </button>
                <button type="button" @onclick="SaveAgendaItem" disabled="@isSaving" class="px-5 py-2 text-xs font-semibold text-white bg-indigo-600 hover:bg-indigo-700 disabled:opacity-50 rounded-xl transition-colors shadow-sm">
                    @(isSaving ? "Đang lưu..." : (editingId == null ? "Lưu giai đoạn" : "Cập nhật giai đoạn"))
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string EventId { get; set; } = string.Empty;
    [Parameter] public DateTime EventStartTime { get; set; } = DateTime.Now;
    [Parameter] public DateTime EventEndTime { get; set; } = DateTime.Now.AddHours(8);

    private List<AgendaItemDto> agendaItems = new();
    private bool isLoading = true;
    private bool showModal = false;
    private bool isSaving = false;
    private string? editingId = null;
    private string? formError = null;

    private DateTime formStartTime;
    private DateTime formEndTime;
    private string formTitle = string.Empty;

    private DateTime calculatedMinTime;
    private DateTime calculatedMaxTime;
    private int sliderMaxSpanMinutes = 100;
    private int sliderStartMinutes = 0;
    private int sliderEndMinutes = 30;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(EventId))
        {
            await LoadAgenda();
        }
    }

    private async Task LoadAgenda()
    {
        isLoading = true;
        var list = await AgendaService.GetAgendaByEventAsync(EventId);
        agendaItems = list.OrderBy(x => x.StartTime).ToList();
        isLoading = false;
    }

    private void OpenAddModal()
    {
        editingId = null;
        formTitle = string.Empty;
        formError = null;

        // Calculate Min and Max bounds
        calculatedMaxTime = EventEndTime > EventStartTime ? EventEndTime : EventStartTime.AddHours(8);

        if (agendaItems.Any())
        {
            // GD2 trở đi: Min = EndTime của giai đoạn trước đó
            var lastItem = agendaItems.OrderBy(x => x.StartTime).Last();
            calculatedMinTime = lastItem.EndTime.ToLocalTime();
        }
        else
        {
            // GD1: Min = EventStartTime
            calculatedMinTime = EventStartTime > DateTime.MinValue ? EventStartTime.ToLocalTime() : DateTime.Now;
        }

        if (calculatedMinTime >= calculatedMaxTime)
        {
            calculatedMinTime = EventStartTime.ToLocalTime();
        }

        formStartTime = calculatedMinTime;
        formEndTime = formStartTime.AddMinutes(30) <= calculatedMaxTime ? formStartTime.AddMinutes(30) : calculatedMaxTime;

        InitSliderValues();
        showModal = true;
    }

    private void EditItem(AgendaItemDto item)
    {
        editingId = item.Id;
        formTitle = item.Title;
        formStartTime = item.StartTime.ToLocalTime();
        formEndTime = item.EndTime.ToLocalTime();
        formError = null;

        // Calculate Min bounds for edit
        var sorted = agendaItems.OrderBy(x => x.StartTime).ToList();
        var itemIndex = sorted.FindIndex(x => x.Id == item.Id);

        calculatedMaxTime = EventEndTime > EventStartTime ? EventEndTime.ToLocalTime() : EventStartTime.AddHours(8).ToLocalTime();

        if (itemIndex > 0)
        {
            calculatedMinTime = sorted[itemIndex - 1].EndTime.ToLocalTime();
        }
        else
        {
            calculatedMinTime = EventStartTime > DateTime.MinValue ? EventStartTime.ToLocalTime() : DateTime.Now;
        }

        InitSliderValues();
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingId = null;
        formError = null;
    }

    private void InitSliderValues()
    {
        var totalMinutes = (int)(calculatedMaxTime - calculatedMinTime).TotalMinutes;
        sliderMaxSpanMinutes = Math.Max(1, totalMinutes);
        sliderStartMinutes = Math.Clamp((int)(formStartTime - calculatedMinTime).TotalMinutes, 0, sliderMaxSpanMinutes);
        sliderEndMinutes = Math.Clamp((int)(formEndTime - calculatedMinTime).TotalMinutes, sliderStartMinutes, sliderMaxSpanMinutes);
    }

    private void OnStartSliderInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val))
        {
            sliderStartMinutes = Math.Clamp(val, 0, sliderEndMinutes);
            formStartTime = calculatedMinTime.AddMinutes(sliderStartMinutes);
            if (formStartTime > calculatedMaxTime) formStartTime = calculatedMaxTime;
            ValidateTimes();
        }
    }

    private void OnEndSliderInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val))
        {
            sliderEndMinutes = Math.Clamp(val, sliderStartMinutes, sliderMaxSpanMinutes);
            formEndTime = calculatedMinTime.AddMinutes(sliderEndMinutes);
            if (formEndTime > calculatedMaxTime) formEndTime = calculatedMaxTime;
            ValidateTimes();
        }
    }

    private void OnManualStartTimeChange(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var dt))
        {
            formStartTime = dt;
            sliderStartMinutes = (int)(formStartTime - calculatedMinTime).TotalMinutes;
            ValidateTimes();
        }
    }

    private void OnManualEndTimeChange(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var dt))
        {
            formEndTime = dt;
            sliderEndMinutes = (int)(formEndTime - calculatedMinTime).TotalMinutes;
            ValidateTimes();
        }
    }

    private bool ValidateTimes()
    {
        formError = null;

        if (formStartTime < calculatedMinTime)
        {
            formError = $"Thời gian bắt đầu không được nhỏ hơn mốc tối thiểu ({FormatTime(calculatedMinTime)}). Vui lòng nhập lại.";
            return false;
        }

        if (formEndTime > calculatedMaxTime)
        {
            formError = $"Thời gian kết thúc không được vượt quá mốc kết thúc sự kiện ({FormatTime(calculatedMaxTime)}). Vui lòng nhập lại.";
            return false;
        }

        if (formEndTime <= formStartTime)
        {
            formError = "Thời gian kết thúc phải lớn hơn thời gian bắt đầu. Vui lòng nhập lại.";
            return false;
        }

        return true;
    }

    private async Task SaveAgendaItem()
    {
        if (string.IsNullOrWhiteSpace(formTitle))
        {
            formError = "Vui lòng nhập nội dung tiết mục / giai đoạn.";
            return;
        }

        if (!ValidateTimes()) return;

        isSaving = true;
        formError = null;

        if (editingId == null)
        {
            var dto = new CreateAgendaDto
            {
                Title = formTitle.Trim(),
                StartTime = formStartTime,
                EndTime = formEndTime
            };

            var result = await AgendaService.CreateAgendaItemAsync(EventId, dto);
            if (result != null)
            {
                ToastService.ShowSuccess("Đã thêm mốc giai đoạn mới.");
                showModal = false;
                await LoadAgenda();
            }
            else
            {
                formError = "Không thể thêm lịch trình. Vui lòng thử lại.";
            }
        }
        else
        {
            var dto = new UpdateAgendaDto
            {
                Title = formTitle.Trim(),
                StartTime = formStartTime,
                EndTime = formEndTime
            };

            var result = await AgendaService.UpdateAgendaItemAsync(editingId, dto);
            if (result != null)
            {
                ToastService.ShowSuccess("Đã cập nhật mốc giai đoạn.");
                showModal = false;
                await LoadAgenda();
            }
            else
            {
                formError = "Không thể cập nhật lịch trình. Vui lòng thử lại.";
            }
        }

        isSaving = false;
    }

    private async Task DeleteItem(string id)
    {
        var success = await AgendaService.DeleteAgendaItemAsync(id);
        if (success)
        {
            ToastService.ShowSuccess("Đã xóa mốc giai đoạn.");
            await LoadAgenda();
        }
        else
        {
            ToastService.ShowError("Xóa mốc giai đoạn thất bại.");
        }
    }

    private string FormatTime(DateTime dt) => dt.ToString("dd/MM/yyyy HH:mm");

    private string FormatDuration(DateTime start, DateTime end)
    {
        var diff = end - start;
        if (diff.TotalMinutes <= 0) return "0 phút";

        int hours = (int)diff.TotalHours;
        int mins = diff.Minutes;

        if (hours > 0 && mins > 0) return $"{hours} giờ {mins} phút";
        if (hours > 0) return $"{hours} giờ";
        return $"{mins} phút";
    }

    private bool HasOutOfBoundsItems()
    {
        if (agendaItems == null || !agendaItems.Any()) return false;
        var evStart = EventStartTime.ToLocalTime();
        var evEnd = EventEndTime.ToLocalTime();
        return agendaItems.Any(x => x.StartTime.ToLocalTime() < evStart || x.EndTime.ToLocalTime() > evEnd);
    }
}
