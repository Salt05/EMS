@using Microsoft.JSInterop
@inject HttpClient HttpClient
@inject IJSRuntime JSRuntime
@inject ToastService ToastService

<div class="inline-flex items-center gap-2">
    <button @onclick="ExportExcel"
            disabled="@_loading"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-charcoal bg-white border border-border rounded-lg shadow-bento hover:shadow-bento-hover hover:bg-canvas transition-all active:scale-[0.97] disabled:opacity-50">
        @if (_loading && _loadingFormat == "excel")
        {
            <div class="animate-spin h-3.5 w-3.5 border-2 border-charcoal/20 border-t-charcoal rounded-full"></div>
        }
        else
        {
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
        }
        <span>Excel</span>
    </button>

    <button @onclick="ExportPdf"
            disabled="@_loading"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-white bg-charcoal rounded-lg shadow-bento hover:bg-slate-800 transition-all active:scale-[0.97] disabled:opacity-50">
        @if (_loading && _loadingFormat == "pdf")
        {
            <div class="animate-spin h-3.5 w-3.5 border-2 border-white/30 border-t-white rounded-full"></div>
        }
        else
        {
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
        }
        <span>PDF</span>
    </button>
</div>

@code {
    /// <summary>Event ID for per-event export. If null, exports tenant summary.</summary>
    [Parameter] public string? EventId { get; set; }

    private bool _loading;
    private string? _loadingFormat;

    private Task ExportExcel() => ExportAsync("excel");
    private Task ExportPdf() => ExportAsync("pdf");

    private async Task ExportAsync(string format)
    {
        _loading = true;
        _loadingFormat = format;
        StateHasChanged();

        try
        {
            var url = string.IsNullOrEmpty(EventId)
                ? $"api/reports/events/summary?format={format}"
                : $"api/reports/events/{EventId}/registrations?format={format}";

            var response = await HttpClient.GetAsync(url);
            if (!response.IsSuccessStatusCode)
            {
                ToastService.ShowError($"Xuất báo cáo thất bại (HTTP {(int)response.StatusCode})");
                return;
            }

            var bytes = await response.Content.ReadAsByteArrayAsync();
            var contentType = response.Content.Headers.ContentType?.MediaType ?? "application/octet-stream";
            var fileName = response.Content.Headers.ContentDisposition?.FileName?.Trim('"')
                ?? $"bao-cao.{(format == "pdf" ? "pdf" : "xlsx")}";

            var base64 = Convert.ToBase64String(bytes);
            await JSRuntime.InvokeVoidAsync("emsCharts.downloadFile", fileName, contentType, base64);
            ToastService.ShowSuccess($"Đã xuất {format.ToUpperInvariant()} thành công!");
        }
        catch (Exception)
        {
            ToastService.ShowError("Không thể kết nối đến server để xuất báo cáo.");
        }
        finally
        {
            _loading = false;
            _loadingFormat = null;
            StateHasChanged();
        }
    }
}
