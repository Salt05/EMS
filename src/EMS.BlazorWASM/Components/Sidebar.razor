@code {
    [Parameter]
    public bool SidebarOpen { get; set; }

    [Parameter]
    public EventCallback OnSidebarClose { get; set; }

    private bool IsSuperAdmin { get; set; }
    private bool IsTenantAdmin { get; set; }
    private bool IsOrganizer { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            IsSuperAdmin = user.IsInRole("superadmin") || user.IsInRole("SuperAdmin");
            IsTenantAdmin = user.IsInRole("admin") || user.IsInRole("Admin");
            IsOrganizer = user.IsInRole("manager") || user.IsInRole("Manager");
        }
    }

    private async Task CloseSidebar()
    {
        if (OnSidebarClose.HasDelegate)
        {
            await OnSidebarClose.InvokeAsync();
        }
    }
}
