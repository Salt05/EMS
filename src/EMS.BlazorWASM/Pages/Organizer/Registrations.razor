@page "/organizer/events/{EventId}/registrations"
@using EMS.Shared.DTOs.Registrations
@using EMS.Shared.DTOs.Events
@using EMS.BlazorWASM.Services
@implements IDisposable
@inject IOrganizerServiceClient OrganizerService
@inject IEventServiceClient EventService
@inject ICheckInServiceClient CheckInService
@inject NavigationManager Navigation
@attribute [Authorize(Roles = "manager,admin")]

<PageTitle>Quản lý Đăng ký - EMS</PageTitle>

<div class="max-w-7xl mx-auto pb-12 pt-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-charcoal">
                Quản lý Đăng ký
            </h1>
            <p class="text-sm text-muted mt-1">
                <a href="/organizer/my-events" class="hover:underline text-muted">Sự kiện của tôi</a> / Đăng ký
            </p>
        </div>
        <div>
            <button class="inline-flex items-center px-4 py-2 text-sm font-semibold text-charcoal bg-white border border-border rounded-md hover:bg-canvas transition-all" @onclick="BackToEvents">
                <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Quay lại danh sách
            </button>
        </div>
    </div>

    @if (isLoadingEvent)
    {
        <div class="flex justify-center items-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-charcoal"></div>
        </div>
    }
    else if (eventDto == null)
    {
        <div class="alert alert-error">
            <span>Không tìm thấy sự kiện hoặc bạn không có quyền quản lý sự kiện này.</span>
        </div>
    }
    else
    {
        <!-- Event Summary Card -->
        <div class="bg-white border border-border rounded-xl p-6 shadow-bento mb-8">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-center">
                <div class="lg:col-span-2">
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold @GetEventStatusBadgeClass(eventDto.Status)">
                        @eventDto.StatusName
                    </span>
                    <h2 class="text-xl font-bold text-charcoal mt-2 mb-2">@eventDto.Title</h2>
                    <p class="text-xs text-muted flex items-center gap-4">
                        <span class="flex items-center gap-1">
                            <svg class="h-4 w-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 00-2 2z" />
                            </svg>
                            @eventDto.StartTime.ToLocalTime().ToString("g")
                        </span>
                        <span class="flex items-center gap-1">
                            <svg class="h-4 w-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            @eventDto.Location
                        </span>
                    </p>
                </div>
                <div class="bg-canvas border border-border rounded-xl p-4 grid grid-cols-3 gap-4 text-center">
                    <div>
                        <div class="text-[10px] font-bold text-muted uppercase tracking-wider">Sức chứa</div>
                        <div class="text-lg font-bold text-charcoal mt-1 font-mono">@(eventDto.Capacity > 0 ? eventDto.Capacity.ToString() : "Vô hạn")</div>
                    </div>
                    <div>
                        <div class="text-[10px] font-bold text-muted uppercase tracking-wider">Đã duyệt</div>
                        <div class="text-lg font-bold text-emerald-600 mt-1 font-mono">@confirmedCount</div>
                    </div>
                    <div>
                        <div class="text-[10px] font-bold text-muted uppercase tracking-wider">Chờ (Waitlist)</div>
                        <div class="text-lg font-bold text-blue-600 mt-1 font-mono">@waitlistCount</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Navigation Tabs -->
        <div class="border-b border-border mb-6">
            <nav class="-mb-px flex space-x-6 overflow-x-auto" aria-label="Tabs">
                <button @onclick='() => SwitchTab("pending")' class="py-4 px-1 border-b-2 font-semibold text-sm transition-colors focus:outline-none whitespace-nowrap @(activeTab == "pending" ? "border-charcoal text-charcoal" : "border-transparent text-muted hover:text-charcoal hover:border-border")">
                    Chờ duyệt @(pendingCount > 0 ? $"({pendingCount})" : "")
                </button>
                <button @onclick='() => SwitchTab("waitlist")' class="py-4 px-1 border-b-2 font-semibold text-sm transition-colors focus:outline-none whitespace-nowrap @(activeTab == "waitlist" ? "border-charcoal text-charcoal" : "border-transparent text-muted hover:text-charcoal hover:border-border")">
                    Danh sách chờ @(waitlistCount > 0 ? $"({waitlistCount})" : "")
                </button>
                <button @onclick='() => SwitchTab("confirmed")' class="py-4 px-1 border-b-2 font-semibold text-sm transition-colors focus:outline-none whitespace-nowrap @(activeTab == "confirmed" ? "border-charcoal text-charcoal" : "border-transparent text-muted hover:text-charcoal hover:border-border")">
                    Đã duyệt @(confirmedCount > 0 ? $"({confirmedCount})" : "")
                </button>
                <button @onclick='() => SwitchTab("all")' class="py-4 px-1 border-b-2 font-semibold text-sm transition-colors focus:outline-none whitespace-nowrap @(activeTab == "all" ? "border-charcoal text-charcoal" : "border-transparent text-muted hover:text-charcoal hover:border-border")">
                    Tất cả đăng ký
                </button>
                <button @onclick='() => SwitchTab("checkin")' class="py-4 px-1 border-b-2 font-semibold text-sm transition-colors focus:outline-none whitespace-nowrap @(activeTab == "checkin" ? "border-charcoal text-charcoal" : "border-transparent text-muted hover:text-charcoal hover:border-border")">
                    Điểm danh (Check-in)
                </button>
            </nav>
        </div>

        <div class="bg-white border border-border rounded-xl shadow-bento overflow-hidden">
            @if (isLoadingRegistrations)
            {
                <div class="flex justify-center items-center py-20">
                    <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-charcoal"></div>
                </div>
            }
            else if (activeTab == "checkin")
            {
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 p-6">
                    <!-- Check-in Validation & Countdown -->
                    <div class="lg:col-span-5 space-y-6">
                        <div class="bg-canvas border border-border rounded-xl p-6">
                            <h3 class="text-xs font-bold text-muted uppercase tracking-wider mb-3 flex items-center gap-2">
                                <svg class="h-4 w-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                Thời gian diễn ra
                            </h3>
                            <div class="text-2xl font-bold font-mono text-center py-4 bg-white border border-border rounded-lg @(countdownText == "Sự kiện đã kết thúc" || countdownText == "Event has ended" ? "text-rose-600" : "text-charcoal")">
                                @countdownText
                            </div>
                        </div>

                        <div class="bg-canvas border border-border rounded-xl p-6">
                            <h3 class="text-xs font-bold text-muted uppercase tracking-wider mb-2 flex items-center gap-2">
                                <svg class="h-4 w-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                Xác thực Điểm danh
                            </h3>
                            <p class="text-xs text-muted mb-4">Nhập mã check-in gồm 6 chữ số do sinh viên cung cấp để điểm danh.</p>

                            <div class="flex gap-2">
                                <input type="text" class="block w-full py-2 px-3 border border-border rounded-md text-sm bg-white focus:outline-none focus:ring-1 focus:ring-charcoal" 
                                       placeholder="Nhập mã check-in (ví dụ: AE82D1)" 
                                       @bind="checkInCode" 
                                       @bind:event="oninput" 
                                       @onkeyup="HandleCodeKeyUp" />
                                <button class="inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-charcoal rounded-md shadow-sm hover:bg-slate-800 transition-all active:scale-[0.98]" 
                                        @onclick="ValidateCheckIn" 
                                        disabled="@(isValidating || string.IsNullOrWhiteSpace(checkInCode))">
                                    @if (isValidating)
                                    {
                                        <span class="animate-spin rounded-full h-4 w-4 border-b-2 border-white mr-1"></span>
                                    }
                                    Xác nhận
                                </button>
                            </div>

                            @if (!string.IsNullOrEmpty(validateMessage))
                            {
                                <div class="mt-4 p-3 rounded-lg text-xs font-semibold @(validateSuccess ? "bg-emerald-100 text-emerald-800" : "bg-rose-100 text-rose-800")">
                                    @validateMessage
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Attendees List -->
                    <div class="lg:col-span-7 bg-canvas border border-border rounded-xl overflow-hidden">
                        <div class="p-4 border-b border-border flex items-center justify-between bg-white">
                            <h3 class="text-xs font-bold text-charcoal uppercase tracking-wider flex items-center gap-2">
                                <svg class="h-4 w-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                </svg>
                                Đã điểm danh (@checkedInAttendees.Count / @confirmedCount)
                            </h3>
                            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-slate-100 text-slate-800">
                                Tự cập nhật (5s)
                            </span>
                        </div>
                        
                        <div class="divide-y divide-border overflow-y-auto" style="max-height: 400px;">
                            @if (checkedInAttendees.Count == 0)
                            {
                                <div class="p-12 text-center text-xs text-muted bg-white">
                                    Chưa có sinh viên nào thực hiện điểm danh.
                                </div>
                            }
                            else
                            {
                                @foreach (var attendee in checkedInAttendees)
                                {
                                    <div class="p-4 flex items-center justify-between hover:bg-canvas transition-colors bg-white">
                                        <div>
                                            <div class="text-sm font-semibold text-charcoal">@(string.IsNullOrEmpty(attendee.UserFullName) ? "Sinh viên" : attendee.UserFullName)</div>
                                            <div class="text-xs text-muted mt-0.5">MSSV: @(attendee.UserMSSV ?? "N/A") | Email: @(attendee.UserEmail ?? "N/A")</div>
                                        </div>
                                        @if (attendee.CheckedInAt.HasValue)
                                        {
                                            <span class="inline-flex items-center text-xs font-semibold text-emerald-600">
                                                <svg class="h-4 w-4 mr-1 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                                </svg>
                                                @attendee.CheckedInAt.Value.ToLocalTime().ToString("t")
                                            </span>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    @if (filteredRegistrations == null || !filteredRegistrations.Any())
                    {
                        <div class="p-12 text-center text-xs text-muted flex flex-col items-center justify-center">
                            <svg class="h-10 w-10 text-muted mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                            </svg>
                            <span>Không tìm thấy yêu cầu đăng ký nào trong mục này.</span>
                        </div>
                    }
                    else
                    {
                        <table class="min-w-full divide-y divide-border">
                            <thead class="bg-canvas">
                                <tr>
                                    @if (activeTab == "waitlist")
                                    {
                                        <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono" style="width: 100px;">Thứ tự</th>
                                    }
                                    <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Thông tin Sinh viên</th>
                                    <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Thời gian đăng ký</th>
                                    @if (activeTab == "all")
                                    {
                                        <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Trạng thái</th>
                                    }
                                    @if (activeTab == "confirmed")
                                    {
                                        <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Trạng thái Check-in</th>
                                    }
                                    @if (activeTab == "pending" || activeTab == "waitlist" || activeTab == "all")
                                    {
                                        <th class="px-6 py-3 text-right text-xs font-bold text-muted uppercase tracking-wider font-mono" style="width: 250px;">Hành động</th>
                                    }
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-border">
                                @for (int i = 0; i < filteredRegistrations.Count; i++)
                                {
                                    var reg = filteredRegistrations[i];
                                    <tr>
                                        @if (activeTab == "waitlist")
                                        {
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-charcoal font-mono">
                                                #@(i + 1)
                                            </td>
                                        }
                                        <td class="px-6 py-4 text-sm text-charcoal">
                                            <div class="flex flex-col space-y-0.5">
                                                <span class="font-semibold text-charcoal">@(string.IsNullOrEmpty(reg.UserFullName) ? "Sinh viên" : reg.UserFullName)</span>
                                                <span class="text-xs text-muted font-mono">Email: @(reg.UserEmail ?? "N/A")</span>
                                                <span class="text-xs text-muted font-mono">MSSV: @(reg.UserMSSV ?? "N/A")</span>
                                                @if (!string.IsNullOrEmpty(reg.Note))
                                                {
                                                    <span class="mt-1 p-2 rounded bg-canvas border border-border text-xs text-muted max-w-lg">
                                                        <strong>Ghi chú:</strong> @reg.Note
                                                    </span>
                                                }
                                                @if (reg.Status == 5 && !string.IsNullOrEmpty(reg.RejectionReason))
                                                {
                                                    <span class="mt-1 p-2 rounded bg-rose-50 border border-rose-100 text-xs text-rose-700 max-w-lg">
                                                        <strong>Lý do từ chối:</strong> @reg.RejectionReason
                                                    </span>
                                                }
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-xs text-muted font-mono">
                                            @reg.RegisteredAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        </td>
                                        @if (activeTab == "all")
                                        {
                                            <td class="px-6 py-4 whitespace-nowrap text-xs font-semibold">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded @GetRegistrationStatusBadgeClass((RegistrationStatus)reg.Status)">
                                                    @reg.StatusName
                                                </span>
                                            </td>
                                        }
                                        @if (activeTab == "confirmed")
                                        {
                                            <td class="px-6 py-4 whitespace-nowrap text-xs font-semibold text-emerald-600">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded bg-emerald-100 text-emerald-800">
                                                    @(reg.CheckedIn ? "Đã điểm danh" : "Đã duyệt")
                                                </span>
                                            </td>
                                        }
                                        @if (activeTab == "pending" || activeTab == "waitlist" || activeTab == "all")
                                        {
                                            <td class="px-6 py-4 whitespace-nowrap text-right text-xs font-medium space-x-2">
                                                @if (reg.Status == (int)RegistrationStatus.Pending || (activeTab == "all" && reg.Status == (int)RegistrationStatus.Waitlisted))
                                                {
                                                    <button class="text-emerald-600 hover:underline" @onclick="() => ApproveRegistration(reg.Id)">Phê duyệt</button>
                                                }
                                                @if (reg.Status == (int)RegistrationStatus.Pending || reg.Status == (int)RegistrationStatus.Waitlisted)
                                                {
                                                    <button class="text-rose-600 hover:underline" @onclick="() => OpenRejectModal(reg.Id, reg.UserFullName)">Từ chối</button>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }
        </div>
    }
</div>

<!-- Rejection Modal Overlay -->
<FormModal Title="Từ chối đơn đăng ký" IsOpen="showRejectModal" SaveText="Từ chối đăng ký" OnSave="ConfirmReject" OnCancel="CloseRejectModal">
    <div class="space-y-4">
        <p class="text-sm text-muted">Bạn có chắc chắn muốn từ chối đăng ký của sinh viên <strong>@selectedRegName</strong>?</p>
        <div>
            <label for="rejectionReasonInput" class="block text-xs font-bold text-muted uppercase tracking-wider mb-2">Lý do từ chối (Bắt buộc)</label>
            <textarea class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" 
                      id="rejectionReasonInput" 
                      @bind="rejectionReason" 
                      rows="3" 
                      placeholder="Nêu rõ lý do từ chối (ví dụ: thông tin không hợp lệ, không đạt điều kiện sự kiện)"></textarea>
            @if (showReasonError)
            {
                <div class="text-rose-600 mt-1 text-xs">Vui lòng nhập lý do từ chối.</div>
            }
        </div>
    </div>
</FormModal>

@code {
    [Parameter]
    public string EventId { get; set; } = string.Empty;

    private EventResponseDto? eventDto;
    private List<RegistrationResponseDto> allRegistrations = new();
    private List<RegistrationResponseDto> filteredRegistrations = new();

    private bool isLoadingEvent = true;
    private bool isLoadingRegistrations = true;
    private string activeTab = "pending";

    // Check-in state
    private List<RegistrationResponseDto> checkedInAttendees = new();
    private string checkInCode = string.Empty;
    private string countdownText = string.Empty;
    private bool isValidating = false;
    private string? validateMessage = null;
    private bool validateSuccess = false;
    private System.Threading.Timer? pollingTimer;
    private System.Threading.Timer? countdownTimer;

    // Statistics counts
    private int pendingCount;
    private int confirmedCount;
    private int waitlistCount;

    // Modal state variables
    private bool showRejectModal = false;
    private string selectedRegId = string.Empty;
    private string selectedRegName = string.Empty;
    private string rejectionReason = string.Empty;
    private bool showReasonError = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadEventInfo();
        await LoadRegistrations();
        
        if (eventDto != null)
        {
            StartCountdown();
            StartPolling();
        }
    }

    private async Task LoadEventInfo()
    {
        isLoadingEvent = true;
        try
        {
            eventDto = await EventService.GetEventByIdAsync(EventId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading event info: {ex.Message}");
        }
        finally
        {
            isLoadingEvent = false;
        }
    }

    private async Task LoadRegistrations(bool bypassCache = false)
    {
        isLoadingRegistrations = true;
        try
        {
            allRegistrations = await OrganizerService.GetRegistrationsAsync(EventId, bypassCache);
            UpdateCounts();
            ApplyFilter();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading registrations: {ex.Message}");
        }
        finally
        {
            isLoadingRegistrations = false;
        }
    }

    private void UpdateCounts()
    {
        pendingCount = allRegistrations.Count(r => r.Status == (int)RegistrationStatus.Pending);
        confirmedCount = allRegistrations.Count(r => r.Status == (int)RegistrationStatus.Confirmed);
        waitlistCount = allRegistrations.Count(r => r.Status == (int)RegistrationStatus.Waitlisted);
    }

    private void ApplyFilter()
    {
        if (activeTab == "pending")
        {
            filteredRegistrations = allRegistrations
                .Where(r => r.Status == (int)RegistrationStatus.Pending)
                .OrderBy(r => r.RegisteredAt)
                .ToList();
        }
        else if (activeTab == "waitlist")
        {
            filteredRegistrations = allRegistrations
                .Where(r => r.Status == (int)RegistrationStatus.Waitlisted)
                .OrderBy(r => r.RegisteredAt)
                .ToList();
        }
        else if (activeTab == "confirmed")
        {
            filteredRegistrations = allRegistrations
                .Where(r => r.Status == (int)RegistrationStatus.Confirmed)
                .OrderBy(r => r.RegisteredAt)
                .ToList();
        }
        else // all
        {
            filteredRegistrations = allRegistrations
                .OrderByDescending(r => r.RegisteredAt)
                .ToList();
        }
    }

    private void SwitchTab(string tabName)
    {
        activeTab = tabName;
        ApplyFilter();
        
        if (tabName == "checkin")
        {
            _ = PollAttendees();
        }
    }

    private async Task ApproveRegistration(string id)
    {
        var success = await OrganizerService.ApproveRegistrationAsync(id);
        if (success)
        {
            await LoadRegistrations(bypassCache: true);
        }
    }

    private void OpenRejectModal(string registrationId, string? studentName)
    {
        selectedRegId = registrationId;
        selectedRegName = string.IsNullOrEmpty(studentName) ? "sinh viên này" : studentName;
        rejectionReason = string.Empty;
        showReasonError = false;
        showRejectModal = true;
    }

    private void CloseRejectModal()
    {
        showRejectModal = false;
        selectedRegId = string.Empty;
        selectedRegName = string.Empty;
        rejectionReason = string.Empty;
        showReasonError = false;
    }

    private async Task ConfirmReject()
    {
        if (string.IsNullOrWhiteSpace(rejectionReason))
        {
            showReasonError = true;
            return;
        }

        var success = await OrganizerService.RejectRegistrationAsync(selectedRegId, rejectionReason);
        if (success)
        {
            CloseRejectModal();
            await LoadRegistrations(bypassCache: true);
        }
    }

    private void BackToEvents()
    {
        Navigation.NavigateTo("/organizer/my-events");
    }

    private string GetRegistrationStatusBadgeClass(RegistrationStatus status)
    {
        return status switch
        {
            RegistrationStatus.Pending => "bg-amber-100 text-amber-800",
            RegistrationStatus.Confirmed => "bg-emerald-100 text-emerald-800",
            RegistrationStatus.Waitlisted => "bg-blue-100 text-blue-800",
            RegistrationStatus.Cancelled => "bg-slate-100 text-slate-800",
            RegistrationStatus.Rejected => "bg-rose-100 text-rose-800",
            _ => "bg-slate-100 text-slate-800"
        };
    }

    private string GetEventStatusBadgeClass(int status) => status switch
    {
        1 => "bg-amber-100 text-amber-800",       // Pending
        2 => "bg-emerald-100 text-emerald-800",   // Approved
        3 => "bg-blue-100 text-blue-800",         // Ongoing
        4 => "bg-slate-100 text-slate-800",       // Ended
        5 => "bg-slate-100 text-slate-800",       // Cancelled
        6 => "bg-rose-100 text-rose-800",         // Rejected
        _ => "bg-slate-100 text-slate-800"
    };

    private void StartCountdown()
    {
        countdownTimer = new System.Threading.Timer(UpdateCountdown, null, 0, 1000);
    }

    private void UpdateCountdown(object? state)
    {
        if (eventDto == null) return;
        
        var remaining = eventDto.EndTime - DateTime.UtcNow;
        if (remaining <= TimeSpan.Zero)
        {
            countdownText = "Sự kiện đã kết thúc";
            countdownTimer?.Change(System.Threading.Timeout.Infinite, 0); // Stop timer
        }
        else
        {
            // If it's more than a day
            if (remaining.TotalDays >= 1)
            {
                countdownText = $"{(int)remaining.TotalDays} ngày {remaining.Hours:D2}h {remaining.Minutes:D2}m";
            }
            else
            {
                countdownText = $"{(int)remaining.TotalHours:D2}:{remaining.Minutes:D2}:{remaining.Seconds:D2}";
            }
        }
        InvokeAsync(StateHasChanged);
    }

    private void StartPolling()
    {
        pollingTimer = new System.Threading.Timer(async _ => await PollAttendees(), null, 0, 5000);
    }

    private async Task PollAttendees()
    {
        if (activeTab == "checkin")
        {
            try
            {
                var attendees = await CheckInService.GetAttendeesAsync(EventId);
                checkedInAttendees = attendees.OrderByDescending(a => a.CheckedInAt).ToList();
                await InvokeAsync(StateHasChanged);
            }
            catch
            {
                // Ignore polling errors to prevent UI interruptions
            }
        }
    }

    private async Task ValidateCheckIn()
    {
        if (string.IsNullOrWhiteSpace(checkInCode)) return;
        
        isValidating = true;
        validateMessage = null;
        
        try
        {
            var result = await CheckInService.ValidateCheckInCodeAsync(checkInCode.Trim());
            if (result != null && result.CheckedIn)
            {
                validateSuccess = true;
                validateMessage = "Điểm danh thành công!";
                checkInCode = string.Empty; // clear code
                
                await PollAttendees(); // Refresh immediately
            }
            else
            {
                validateSuccess = false;
                validateMessage = "Mã không hợp lệ, hết hạn hoặc đã được sử dụng.";
            }
        }
        catch (Exception ex)
        {
            validateSuccess = false;
            validateMessage = "Không thể xác thực mã.";
            Console.WriteLine($"Error validating check-in: {ex.Message}");
        }
        finally
        {
            isValidating = false;
        }
    }
    
    private async Task HandleCodeKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(checkInCode) && !isValidating)
        {
            await ValidateCheckIn();
        }
    }

    public void Dispose()
    {
        pollingTimer?.Dispose();
        countdownTimer?.Dispose();
    }
}
