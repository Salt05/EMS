@page "/Organizer/Registrations/Pending"
@attribute [Authorize(Roles = "manager")]
@inject IOrganizerServiceClient OrganizerService
@inject ToastService ToastService
@using EMS.Shared.DTOs.Events
@using EMS.Shared.DTOs.Registrations

<PageTitle>Phê duyệt Đăng ký — EMS</PageTitle>

<div class="max-w-7xl mx-auto pb-12 pt-6">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold tracking-tight text-charcoal flex items-center gap-2">
            Phê duyệt Đăng ký Sinh viên
            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-100 text-amber-800">
                ⏳ DEMO
            </span>
        </h1>
        <p class="text-sm text-muted mt-1">Duyệt hoặc từ chối đơn đăng ký tham gia sự kiện của sinh viên.</p>
    </div>

    <!-- Event Selection -->
    <div class="bg-white border border-border rounded-xl p-6 shadow-bento mb-8">
        <div class="max-w-md">
            <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-2">Chọn Sự kiện</label>
            <select class="block w-full py-2 px-3 border border-border rounded-md text-sm bg-white focus:outline-none focus:ring-1 focus:ring-charcoal" @onchange="OnEventSelected">
                <option value="">-- Chọn sự kiện của bạn --</option>
                @foreach (var evt in myEvents)
                {
                    <option value="@evt.Id">@evt.Title</option>
                }
            </select>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(selectedEventId))
    {
        <!-- Tabs -->
        <div class="border-b border-border mb-6">
            <nav class="-mb-px flex space-x-8" aria-label="Tabs">
                <button @onclick='() => ChangeTab("pending")' class="py-4 px-1 border-b-2 font-medium text-sm transition-colors focus:outline-none @(activeTab == "pending" ? "border-charcoal text-charcoal" : "border-transparent text-muted hover:text-charcoal hover:border-border")">
                    Chờ duyệt
                </button>
                <button @onclick='() => ChangeTab("approved")' class="py-4 px-1 border-b-2 font-medium text-sm transition-colors focus:outline-none @(activeTab == "approved" ? "border-charcoal text-charcoal" : "border-transparent text-muted hover:text-charcoal hover:border-border")">
                    Đã duyệt
                </button>
                <button @onclick='() => ChangeTab("rejected")' class="py-4 px-1 border-b-2 font-medium text-sm transition-colors focus:outline-none @(activeTab == "rejected" ? "border-charcoal text-charcoal" : "border-transparent text-muted hover:text-charcoal hover:border-border")">
                    Đã từ chối
                </button>
            </nav>
        </div>

        <!-- Data Table -->
        <DataTable TItem="RegistrationResponseDto" Items="filteredRegistrations" TotalCount="filteredRegistrations.Count" 
                   Page="page" PageSize="pageSize" PageChanged="OnPageChanged" ShowSearch="false" IsLoading="isLoading">
            <TableHeader>
                <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">STT</th>
                <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">MSSV</th>
                <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Họ tên</th>
                <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Email</th>
                <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Thời gian đăng ký</th>
                @if (activeTab == "pending")
                {
                    <th class="px-6 py-3 text-right text-xs font-bold text-muted uppercase tracking-wider font-mono">Hành động</th>
                }
                @if (activeTab == "rejected")
                {
                    <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Lý do từ chối</th>
                }
            </TableHeader>
            <RowTemplate Context="reg">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@(filteredRegistrations.IndexOf(reg) + 1)</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@(reg.UserMSSV ?? "-")</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-charcoal">@reg.UserFullName</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@reg.UserEmail</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@reg.RegisteredAt.ToString("dd/MM/yyyy HH:mm")</td>
                @if (activeTab == "pending")
                {
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
                        <button @onclick="() => ApproveRegistration(reg)" class="text-emerald-600 hover:underline">Duyệt</button>
                        <button @onclick="() => OpenRejectModal(reg)" class="text-rose-600 hover:underline">Từ chối</button>
                    </td>
                }
                @if (activeTab == "rejected")
                {
                    <td class="px-6 py-4 text-sm text-rose-700">@reg.RejectionReason</td>
                }
            </RowTemplate>
        </DataTable>
    }
    else
    {
        <div class="bg-white border border-dashed border-border rounded-xl p-12 text-center flex flex-col items-center">
            <div class="h-12 w-12 rounded-full bg-canvas flex items-center justify-center mb-4">
                <svg class="h-6 w-6 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.24 17.84a3 3 0 00-2.922-3.84H4a3 3 0 00-3 3v1a1 1 0 001 1h12a1 1 0 001-1v-1zm-4.24-8.84a3 3 0 11-6 0 3 3 0 016 0zM12 9a1 1 0 01.832-.832l3.17-1.17 1.17-3.17a1 1 0 011.664 0l1.17 3.17 3.17 1.17a1 1 0 010 1.664l-3.17 1.17-1.17 3.17a1 1 0 01-1.664 0l-1.17-3.17-3.17-1.17A1 1 0 0112 9z" />
                </svg>
            </div>
            <h3 class="text-sm font-bold text-charcoal mb-1">Chưa chọn sự kiện</h3>
            <p class="text-xs text-muted max-w-sm">Chọn một sự kiện từ danh sách bên trên để quản lý đăng ký của sinh viên.</p>
        </div>
    }
</div>

<!-- Reject Registration Modal -->
<FormModal Title="Từ chối đơn đăng ký" IsOpen="isRejectOpen" SaveText="Xác nhận từ chối" OnSave="RejectRegistration" OnCancel="() => isRejectOpen = false">
    <div class="space-y-4">
        <p class="text-sm text-muted">Bạn có chắc muốn từ chối đăng ký của sinh viên <strong>@selectedRegistration?.UserFullName</strong>?</p>
        <div>
            <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Lý do từ chối (bắt buộc)</label>
            <textarea @bind="rejectReason" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" rows="3" placeholder="Nhập lý do từ chối..."></textarea>
        </div>
    </div>
</FormModal>

@code {
    private List<EventResponseDto> myEvents = new();
    private string selectedEventId = "";
    private List<RegistrationResponseDto> registrations = new();
    private List<RegistrationResponseDto> filteredRegistrations = new();
    private bool isLoading;

    private int page = 1;
    private int pageSize = 10;
    private string activeTab = "pending";

    // Rejection Form
    private bool isRejectOpen;
    private RegistrationResponseDto? selectedRegistration;
    private string rejectReason = "";

    protected override async Task OnInitializedAsync()
    {
        myEvents = await OrganizerService.GetEventsAsync();
    }

    private async Task OnEventSelected(ChangeEventArgs e)
    {
        selectedEventId = e.Value?.ToString() ?? "";
        if (!string.IsNullOrEmpty(selectedEventId))
        {
            await LoadRegistrations();
        }
    }

    private async Task LoadRegistrations()
    {
        isLoading = true;
        try
        {
            registrations = await OrganizerService.GetRegistrationsAsync(selectedEventId);
            ApplyFilter();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Lỗi khi tải danh sách đăng ký.");
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilter()
    {
        if (activeTab == "pending")
        {
            filteredRegistrations = registrations.Where(r => r.Status == 1).ToList();
        }
        else if (activeTab == "approved")
        {
            filteredRegistrations = registrations.Where(r => r.Status == 2).ToList();
        }
        else if (activeTab == "rejected")
        {
            filteredRegistrations = registrations.Where(r => r.Status == 6).ToList();
        }
    }

    private void ChangeTab(string tab)
    {
        activeTab = tab;
        page = 1;
        ApplyFilter();
    }

    private void OnPageChanged(int newPage) => page = newPage;

    private async Task ApproveRegistration(RegistrationResponseDto reg)
    {
        isLoading = true;
        var success = await OrganizerService.ApproveRegistrationAsync(reg.Id);
        if (success)
        {
            ToastService.ShowSuccess("Đã duyệt đơn đăng ký của sinh viên.");
            await LoadRegistrations();
        }
        else
        {
            ToastService.ShowError("Phê duyệt đăng ký thất bại.");
        }
        isLoading = false;
    }

    private void OpenRejectModal(RegistrationResponseDto reg)
    {
        selectedRegistration = reg;
        rejectReason = "";
        isRejectOpen = true;
    }

    private async Task RejectRegistration()
    {
        if (selectedRegistration == null) return;
        if (string.IsNullOrWhiteSpace(rejectReason))
        {
            ToastService.ShowWarning("Vui lòng nhập lý do từ chối.");
            return;
        }

        isLoading = true;
        var success = await OrganizerService.RejectRegistrationAsync(selectedRegistration.Id, rejectReason);
        if (success)
        {
            ToastService.ShowSuccess("Đã từ chối đơn đăng ký.");
            await LoadRegistrations();
        }
        else
        {
            ToastService.ShowError("Từ chối đăng ký thất bại.");
        }
        isRejectOpen = false;
        isLoading = false;
    }
}
