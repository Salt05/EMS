@page "/Organizer/Attendance"
@attribute [Authorize(Roles = "manager")]
@inject IOrganizerServiceClient OrganizerService
@inject ToastService ToastService
@inject IJSRuntime JSRuntime
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@using EMS.Shared.DTOs.Events
@using EMS.Shared.DTOs.Registrations
@using System.Text
@using System.Threading

<PageTitle>Điểm danh sự kiện — EMS</PageTitle>

<div class="max-w-7xl mx-auto pb-12 pt-6">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold tracking-tight text-charcoal">
            Điểm danh sự kiện
        </h1>
        <p class="text-sm text-muted mt-1">Tạo mã điểm danh tức thời cho các sự kiện của bạn và theo dõi thời gian thực.</p>
    </div>

    <!-- Controls Card -->
    <div class="bg-white border border-border rounded-xl p-6 shadow-bento mb-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
            <!-- Event Dropdown -->
            <div>
                <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-2">Chọn Sự kiện</label>
                <select class="block w-full py-2 px-3 border border-border rounded-md text-sm bg-white focus:outline-none focus:ring-1 focus:ring-charcoal" @onchange="OnEventSelected" value="@selectedEventId">
                    <option value="">-- Chọn một sự kiện --</option>
                    @foreach (var evt in myEvents)
                    {
                        <option value="@evt.Id">@evt.Title</option>
                    }
                </select>
            </div>

            <!-- Code Generation & Display -->
            <div class="md:col-span-2 flex flex-wrap items-center gap-4">
                @if (!string.IsNullOrEmpty(selectedEventId))
                {
                    <button @onclick="() => showDurationModal = true" class="px-4 py-2 text-sm font-semibold text-white bg-charcoal rounded-md shadow-sm hover:bg-slate-800 transition-all active:scale-[0.98]">
                        Tạo mã check-in
                    </button>
                    
                    @if (!string.IsNullOrEmpty(checkInCode))
                    {
                        <div class="flex items-center gap-3 bg-canvas border border-border px-4 py-2 rounded-lg">
                            <span class="text-xs font-bold text-muted uppercase">Mã hiện tại:</span>
                            <span class="text-lg font-bold text-charcoal font-mono tracking-wider">@checkInCode</span>
                            <span class="h-4 w-px bg-border"></span>
                            <span class="text-xs font-bold @(timeLeftSeconds < 60 ? "text-rose-600 animate-pulse" : "text-emerald-600") font-mono">
                                Hết hạn sau: @FormatTime(timeLeftSeconds)
                            </span>
                            <span class="h-4 w-px bg-border"></span>
                            <!-- Invalidate Code Button -->
                            <button @onclick="DisableCode" class="text-rose-600 hover:text-rose-700 p-1 transition-colors flex items-center justify-center" title="Vô hiệu hóa mã">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                                </svg>
                            </button>
                            <span class="h-4 w-px bg-border"></span>
                            <button @onclick="() => isZoomed = true" class="text-muted hover:text-charcoal p-1 transition-colors flex items-center justify-center" title="Phóng to mã điểm danh">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
                                </svg>
                            </button>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(selectedEventId))
    {
        <!-- Attendee List -->
        <div class="mb-4 flex items-center justify-between">
            <h2 class="text-lg font-bold text-charcoal flex items-center gap-2">
                Sinh viên đã check-in
                <span class="text-sm font-normal text-muted">(@attendees.Count người)</span>
            </h2>
            @if (attendees.Any())
            {
                <button @onclick="ExportToExcel" class="inline-flex items-center px-4 py-2 text-sm font-semibold text-charcoal bg-white border border-border rounded-md hover:bg-canvas transition-colors">
                    <svg class="h-4 w-4 mr-2 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Xuất danh sách (Excel/CSV)
                </button>
            }
        </div>

        <DataTable TItem="RegistrationResponseDto" Items="attendees" TotalCount="attendees.Count" 
                   Page="page" PageSize="pageSize" PageChanged="OnPageChanged" ShowSearch="false" IsLoading="isLoading">
            <TableHeader>
                <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">STT</th>
                <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">MSSV</th>
                <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Họ tên</th>
                <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Email</th>
                <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Thời gian check-in</th>
            </TableHeader>
            <RowTemplate Context="reg">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@(attendees.IndexOf(reg) + 1)</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@(reg.UserMSSV ?? "-")</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-charcoal">@reg.UserFullName</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@reg.UserEmail</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@(reg.CheckedInAt?.ToString("dd/MM/yyyy HH:mm:ss") ?? "-")</td>
            </RowTemplate>
        </DataTable>
    }
    else
    {
        <div class="bg-white border border-dashed border-border rounded-xl p-12 text-center flex flex-col items-center">
            <div class="h-12 w-12 rounded-full bg-canvas flex items-center justify-center mb-4">
                <svg class="h-6 w-6 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
                </svg>
            </div>
            <h3 class="text-sm font-bold text-charcoal mb-1">Chưa chọn sự kiện</h3>
            <p class="text-xs text-muted max-w-sm">Chọn một sự kiện từ danh sách bên trên để quản lý điểm danh.</p>
        </div>
    }
</div>

<!-- Duration Selection Modal -->
@if (showDurationModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center overflow-x-hidden overflow-y-auto outline-none focus:outline-none">
        <div class="fixed inset-0 bg-charcoal/40 backdrop-blur-sm transition-opacity" @onclick="() => showDurationModal = false"></div>
        <div class="relative w-full max-w-sm mx-auto my-6 z-50 p-4">
            <div class="relative flex flex-col w-full bg-white border border-border rounded-xl shadow-bento outline-none focus:outline-none p-6">
                <h3 class="text-base font-bold text-charcoal mb-2">Chọn thời gian hiệu lực</h3>
                <p class="text-xs text-muted mb-4">Vui lòng chọn thời gian tồn tại cho mã điểm danh của sự kiện này.</p>
                
                <div class="grid grid-cols-2 gap-3">
                    <button @onclick="() => SelectDurationAndGenerate(1)" class="py-2.5 px-4 text-sm font-semibold text-charcoal bg-canvas border border-border rounded-lg hover:bg-white transition-all active:scale-[0.98] focus:outline-none">
                        1 phút
                    </button>
                    <button @onclick="() => SelectDurationAndGenerate(2)" class="py-2.5 px-4 text-sm font-semibold text-charcoal bg-canvas border border-border rounded-lg hover:bg-white transition-all active:scale-[0.98] focus:outline-none">
                        2 phút
                    </button>
                    <button @onclick="() => SelectDurationAndGenerate(5)" class="py-2.5 px-4 text-sm font-semibold text-charcoal bg-canvas border border-border rounded-lg hover:bg-white transition-all active:scale-[0.98] focus:outline-none">
                        5 phút
                    </button>
                    <button @onclick="() => SelectDurationAndGenerate(10)" class="py-2.5 px-4 text-sm font-semibold text-charcoal bg-canvas border border-border rounded-lg hover:bg-white transition-all active:scale-[0.98] focus:outline-none">
                        10 phút
                    </button>
                </div>

                <button @onclick="() => showDurationModal = false" class="mt-4 w-full py-2 text-sm font-semibold text-muted bg-canvas hover:bg-border rounded-lg transition-colors focus:outline-none">
                    Hủy bỏ
                </button>
            </div>
        </div>
    </div>
}

@if (isZoomed)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center bg-charcoal/95 backdrop-blur-md">
        <!-- Close button top-right -->
        <button @onclick="() => isZoomed = false" class="absolute top-6 right-6 text-white/70 hover:text-white p-2 rounded-full hover:bg-white/10 transition-colors focus:outline-none" title="Đóng">
            <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>

        <div class="text-center max-w-4xl px-6 space-y-8 select-none">
            <div class="text-sm font-bold text-emerald-400 uppercase tracking-widest font-mono">MÃ ĐIỂM DANH SỰ KIỆN</div>
            <h2 class="text-2xl md:text-3xl font-extrabold text-white line-clamp-2">
                @(myEvents.Find(e => e.Id == selectedEventId)?.Title ?? "Sự kiện")
            </h2>
            <div class="py-12 px-16 bg-white/5 border border-white/10 rounded-2xl shadow-2xl relative overflow-hidden backdrop-blur-sm">
                <!-- Large Check-in Code -->
                <div class="text-8xl md:text-[12rem] font-extrabold text-white font-mono tracking-widest leading-none">
                    @checkInCode
                </div>
            </div>
            <div class="text-lg md:text-2xl font-bold @(timeLeftSeconds < 60 ? "text-rose-400 animate-pulse" : "text-white/80") font-mono flex items-center justify-center gap-2">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Thời gian còn lại: @FormatTime(timeLeftSeconds)
            </div>
        </div>
    </div>
}

@code {
    private List<EventResponseDto> myEvents = new();
    private string selectedEventId = "";
    private List<RegistrationResponseDto> attendees = new();
    private bool isLoading;

    private int page = 1;
    private int pageSize = 10;

    // Checkin Code
    private string checkInCode = "";
    private int timeLeftSeconds = 0;
    private CancellationTokenSource? timerCts;
    private bool isZoomed = false;

    // Duration modal states
    private bool showDurationModal = false;
    private int selectedDurationMinutes = 30;

    protected override async Task OnInitializedAsync()
    {
        var allEvents = await OrganizerService.GetEventsAsync();
        // Only approved or ongoing events can be checked in
        myEvents = allEvents.Where(e => e.Status == 2 || e.Status == 3).ToList();

        // Restore selected event from local storage
        var savedEventId = await LocalStorage.GetItemAsync<string>("SelectedEventId_Organizer_Attendance");
        if (!string.IsNullOrEmpty(savedEventId) && myEvents.Any(e => e.Id == savedEventId))
        {
            selectedEventId = savedEventId;
            await LoadEventDetailsForSelected();
        }
    }

    private async Task OnEventSelected(ChangeEventArgs e)
    {
        selectedEventId = e.Value?.ToString() ?? "";
        await LocalStorage.SetItemAsync("SelectedEventId_Organizer_Attendance", selectedEventId);
        await LoadEventDetailsForSelected();
    }

    private async Task LoadEventDetailsForSelected()
    {
        checkInCode = "";
        timeLeftSeconds = 0;
        timerCts?.Cancel();

        if (!string.IsNullOrEmpty(selectedEventId))
        {
            var selectedEv = myEvents.Find(evt => evt.Id == selectedEventId);
            if (selectedEv != null && !string.IsNullOrEmpty(selectedEv.CheckInCode))
            {
                checkInCode = selectedEv.CheckInCode;
                if (selectedEv.CheckInCodeExpiresAt.HasValue)
                {
                    var span = selectedEv.CheckInCodeExpiresAt.Value - DateTime.UtcNow;
                    timeLeftSeconds = (int)Math.Max(0, span.TotalSeconds);
                    if (timeLeftSeconds > 0)
                    {
                        StartCountdown();
                    }
                }
            }
            await LoadAttendees();
        }
    }

    private async Task LoadAttendees()
    {
        isLoading = true;
        try
        {
            attendees = await OrganizerService.GetAttendeesAsync(selectedEventId);
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Không thể tải danh sách điểm danh.");
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnPageChanged(int newPage) => page = newPage;

    private async Task SelectDurationAndGenerate(int minutes)
    {
        showDurationModal = false;
        selectedDurationMinutes = minutes;
        await GenerateCode();
    }

    private async Task GenerateCode()
    {
        if (string.IsNullOrEmpty(selectedEventId)) return;
        
        var code = await OrganizerService.GenerateCheckInCodeAsync(selectedEventId, selectedDurationMinutes);
        if (!string.IsNullOrEmpty(code))
        {
            checkInCode = code;
            timeLeftSeconds = selectedDurationMinutes * 60;
            ToastService.ShowSuccess("Mã check-in mới đã được sinh.");
            StartCountdown();
            
            var ev = myEvents.Find(e => e.Id == selectedEventId);
            if (ev != null)
            {
                ev.CheckInCode = code;
                ev.CheckInCodeExpiresAt = DateTime.UtcNow.AddMinutes(selectedDurationMinutes);
            }
        }
        else
        {
            ToastService.ShowError("Không thể sinh mã check-in.");
        }
    }

    private async Task DisableCode()
    {
        if (string.IsNullOrEmpty(selectedEventId)) return;

        try
        {
            var response = await Http.PostAsync($"api/events/{selectedEventId}/expire-code", null);
            if (response.IsSuccessStatusCode)
            {
                checkInCode = "";
                timeLeftSeconds = 0;
                timerCts?.Cancel();
                isZoomed = false;
                
                var ev = myEvents.Find(e => e.Id == selectedEventId);
                if (ev != null)
                {
                    ev.CheckInCode = null;
                    ev.CheckInCodeExpiresAt = null;
                }
                
                ToastService.ShowSuccess("Đã vô hiệu hóa mã điểm danh.");
            }
            else
            {
                ToastService.ShowError("Vô hiệu hóa mã điểm danh thất bại.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Có lỗi xảy ra khi vô hiệu hóa mã.");
            Console.WriteLine(ex.Message);
        }
    }

    private void StartCountdown()
    {
        timerCts?.Cancel();
        timerCts = new CancellationTokenSource();
        var token = timerCts.Token;

        Task.Run(async () =>
        {
            while (timeLeftSeconds > 0 && !token.IsCancellationRequested)
            {
                await Task.Delay(1000, token);
                if (token.IsCancellationRequested) break;
                
                timeLeftSeconds--;
                await InvokeAsync(StateHasChanged);
            }

            if (timeLeftSeconds <= 0 && !token.IsCancellationRequested)
            {
                checkInCode = "";
                await InvokeAsync(StateHasChanged);
            }
        }, token);
    }

    private string FormatTime(int seconds)
    {
        var minutes = seconds / 60;
        var secs = seconds % 60;
        return $"{minutes:D2}:{secs:D2}";
    }

    private async Task ExportToExcel()
    {
        if (!attendees.Any()) return;

        var csvBuilder = new StringBuilder();
        // Add BOM
        csvBuilder.Append("\uFEFF");
        csvBuilder.AppendLine("STT,MSSV,Họ Tên,Email,Thời gian điểm danh");
        for (int i = 0; i < attendees.Count; i++)
        {
            var a = attendees[i];
            csvBuilder.AppendLine($"{i + 1},{a.UserMSSV},{a.UserFullName},{a.UserEmail},{a.CheckedInAt?.ToString("dd/MM/yyyy HH:mm:ss")}");
        }

        var bytes = Encoding.UTF8.GetBytes(csvBuilder.ToString());
        var base64 = Convert.ToBase64String(bytes);

        // Register download JS function dynamically
        await JSRuntime.InvokeVoidAsync("eval", @"
            window.downloadFile = (fileName, contentType, base64Content) => {
                const binary = atob(base64Content);
                const array = new Uint8Array(binary.length);
                for (let i = 0; i < binary.length; i++) {
                    array[i] = binary.charCodeAt(i);
                }
                const blob = new Blob([array], {type: contentType});
                const link = document.createElement('a');
                link.href = window.URL.createObjectURL(blob);
                link.download = fileName;
                link.click();
                window.URL.revokeObjectURL(link.href);
            };
        ");

        var eventTitleClean = myEvents.Find(e => e.Id == selectedEventId)?.Title ?? "su-kien";
        var fileName = $"diem-danh-{eventTitleClean.Replace(" ", "-")}.csv";

        await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "text/csv;charset=utf-8", base64);
        ToastService.ShowSuccess("Đã tải về danh sách điểm danh thành công.");
    }
}
