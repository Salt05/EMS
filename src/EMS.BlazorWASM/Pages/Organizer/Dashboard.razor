@page "/Organizer/Dashboard"
@attribute [Authorize(Roles = "manager,Manager,organizer")]
@inject IOrganizerServiceClient OrganizerService

<PageTitle>Dashboard Organizer — EMS</PageTitle>

<div class="max-w-7xl mx-auto pb-12 pt-6">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold tracking-tight text-charcoal flex items-center gap-2">
            Bảng điều khiển Ban tổ chức
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-amber-100 text-amber-800">
                ⏳ DEMO
            </span>
        </h1>
        <p class="text-sm text-muted mt-1">Quản lý hiệu suất, lượt đăng ký và điểm danh cho các sự kiện bạn phụ trách.</p>
    </div>

    @if (stats == null)
    {
        <div class="flex justify-center items-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-charcoal"></div>
        </div>
    }
    else
    {
        <!-- Stats Widgets -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <DashboardWidget Title="Sự kiện của tôi" Value="@stats.TotalEvents.ToString()" IsDemo="true">
                <Icon>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <polygon points="12 2 2 7 12 12 22 7 12 2"/>
                        <polyline points="2 17 12 22 22 17"/>
                        <polyline points="2 12 12 17 22 12"/>
                    </svg>
                </Icon>
            </DashboardWidget>

            <DashboardWidget Title="Đang diễn ra" Value="@stats.OngoingEvents.ToString()" IsDemo="true">
                <Icon>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                </Icon>
            </DashboardWidget>

            <DashboardWidget Title="Sắp diễn ra" Value="@stats.UpcomingEvents.ToString()" IsDemo="true">
                <Icon>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </Icon>
            </DashboardWidget>

            <DashboardWidget Title="Tỷ lệ Check-in trung bình" Value="@($"{stats.CheckInRate}%")" IsDemo="true">
                <Icon>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </Icon>
            </DashboardWidget>
        </div>

        <!-- Registration Count Chart -->
        <div class="bg-white border border-border rounded-xl p-6 shadow-bento">
            <h3 class="text-base font-bold text-charcoal mb-4 flex items-center justify-between">
                Số Lượng Đăng Ký Theo Từng Sự Kiện
                <span class="text-xs text-muted font-normal">Đơn vị: Người đăng ký</span>
            </h3>
            <div class="mt-8 space-y-5">
                @foreach (var ev in stats.EventRegistrations)
                {
                    var maxVal = stats.EventRegistrations.Max(e => e.RegistrationCount);
                    var percentage = maxVal > 0 ? (ev.RegistrationCount * 100 / maxVal) : 0;
                    <div>
                        <div class="flex items-center justify-between text-sm mb-1.5">
                            <span class="font-medium text-charcoal">@ev.EventTitle</span>
                            <span class="font-bold text-charcoal font-mono">@ev.RegistrationCount</span>
                        </div>
                        <div class="w-full bg-canvas h-3 rounded-full overflow-hidden">
                            <div class="bg-charcoal h-full rounded-full transition-all duration-500" style="width: @(percentage)%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private OrganizerDashboardStatsDto? stats;

    protected override async Task OnInitializedAsync()
    {
        stats = await OrganizerService.GetStatsAsync();
    }
}
