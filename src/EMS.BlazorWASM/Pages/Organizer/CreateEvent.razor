@page "/organizer/events/create"
@using EMS.Shared.DTOs.Events
@using EMS.BlazorWASM.Services
@inject IEventServiceClient EventService
@inject IOrganizerServiceClient OrganizerService
@inject NavigationManager NavigationManager
@attribute [Authorize(Roles = "manager,admin")]

<PageTitle>Tạo Sự kiện mới — EMS</PageTitle>

<div class="max-w-5xl mx-auto pb-12 pt-6">
    <!-- Header -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <div class="flex items-center gap-2 text-xs font-medium text-muted mb-2">
                <a href="/organizer/my-events" class="hover:text-charcoal transition-colors">Sự kiện của tôi</a>
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
                <span class="text-charcoal">Tạo Sự kiện mới</span>
            </div>
            <h1 class="text-2xl font-bold tracking-tight text-charcoal">Tạo Sự kiện mới</h1>
        </div>
        <button type="button" @onclick="Cancel" class="px-4 py-2 text-sm font-medium text-charcoal bg-white border border-border rounded-md shadow-sm hover:bg-canvas transition-colors">
            Huỷ bỏ
        </button>
    </div>

    <!-- Form -->
    <EMS.BlazorWASM.Components.EventForm 
        EventModel="@eventDto" 
        IsSubmitting="@isSubmitting" 
        ErrorMessage="@errorMessage" 
        SubmitButtonText="Tạo Sự Kiện Mới" 
        OnValidSubmit="HandleValidSubmit" />
</div>

@code {
    private CreateEventDto eventDto = new();
    private bool isSubmitting = false;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        // Set default values
        eventDto.StartTime = DateTime.Now.AddDays(1).Date.AddHours(9); // Tomorrow 9 AM
        eventDto.EndTime = DateTime.Now.AddDays(1).Date.AddHours(17); // Tomorrow 5 PM
        eventDto.Capacity = 0;
    }

    private async Task HandleValidSubmit()
    {
        if (eventDto.StartTime >= eventDto.EndTime)
        {
            errorMessage = "Thời gian kết thúc phải diễn ra sau thời gian bắt đầu.";
            return;
        }

        errorMessage = null;
        isSubmitting = true;
        
        try
        {
            var result = await EventService.CreateEventAsync(eventDto);
            if (result != null)
            {
                OrganizerService.InvalidateCache();
                NavigationManager.NavigateTo("/organizer/my-events");
            }
            else
            {
                errorMessage = "Có lỗi xảy ra khi gửi đăng ký sự kiện. Vui lòng kiểm tra lại.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi hệ thống: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel() => NavigationManager.NavigateTo("/organizer/my-events");
}
