@page "/SuperAdmin/Dashboard"
@attribute [Authorize(Roles = "superadmin,SuperAdmin")]
@inject ISuperAdminServiceClient SuperAdminService

<PageTitle>Dashboard Super Admin — EMS</PageTitle>

<div class="max-w-7xl mx-auto pb-12 pt-6">
    <!-- Header -->
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-charcoal flex items-center gap-2">
                Tổng Quan Hệ Thống
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-amber-100 text-amber-800">
                    ⏳ DEMO
                </span>
            </h1>
            <p class="text-sm text-muted mt-1">Số liệu tổng quan trên toàn bộ các Tenant và người dùng hệ thống.</p>
        </div>
    </div>

    @if (stats == null)
    {
        <div class="flex justify-center items-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-charcoal"></div>
        </div>
    }
    else
    {
        <!-- Stats Widgets -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <DashboardWidget Title="Tổng số Tenant" Value="@stats.TotalTenants.ToString()" IsDemo="true">
                <Icon>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                </Icon>
            </DashboardWidget>
            
            <DashboardWidget Title="Tổng số User" Value="@stats.TotalUsers.ToString()" IsDemo="true">
                <Icon>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                </Icon>
            </DashboardWidget>

            <DashboardWidget Title="Tổng số Event" Value="@stats.TotalEvents.ToString()" IsDemo="true">
                <Icon>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 00-2 2z" />
                    </svg>
                </Icon>
            </DashboardWidget>
        </div>

        <!-- Charts Section -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Top Tenants Chart -->
            <div class="bg-white border border-border rounded-xl p-6 shadow-bento">
                <h3 class="text-base font-bold text-charcoal mb-4 flex items-center justify-between">
                    Top 5 Tenants Theo Số Lượng Sự Kiện
                    <span class="text-xs text-muted font-normal">Đơn vị: Sự kiện</span>
                </h3>
                <div class="mt-8 space-y-5">
                    @foreach (var tenant in stats.TopTenants)
                    {
                        var percentage = stats.TopTenants.Max(t => t.EventCount) > 0 
                            ? (tenant.EventCount * 100 / stats.TopTenants.Max(t => t.EventCount)) 
                            : 0;
                        <div>
                            <div class="flex items-center justify-between text-sm mb-1.5">
                                <span class="font-medium text-charcoal">@tenant.TenantName</span>
                                <span class="font-bold text-charcoal font-mono">@tenant.EventCount</span>
                            </div>
                            <div class="w-full bg-canvas h-3 rounded-full overflow-hidden">
                                <div class="bg-charcoal h-full rounded-full transition-all duration-500" style="width: @(percentage)%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Role Ratio Chart -->
            <div class="bg-white border border-border rounded-xl p-6 shadow-bento">
                <h3 class="text-base font-bold text-charcoal mb-4">Tỷ Lệ Người Dùng Theo Vai Trò</h3>
                <div class="mt-8 space-y-6">
                    @foreach (var ratio in stats.RoleRatios)
                    {
                        <div>
                            <div class="flex items-center justify-between text-sm mb-1">
                                <span class="font-medium text-charcoal flex items-center gap-2">
                                    <span class="h-3.5 w-3.5 rounded-full @GetRoleColorClass(ratio.RoleName)"></span>
                                    @GetRoleDisplayName(ratio.RoleName)
                                </span>
                                <div class="text-right">
                                    <span class="font-bold text-charcoal font-mono">@ratio.Ratio%</span>
                                    <span class="text-xs text-muted font-normal ml-1">(@ratio.UserCount user)</span>
                                </div>
                            </div>
                            <div class="w-full bg-canvas h-3 rounded-full overflow-hidden">
                                <div class="h-full rounded-full transition-all duration-500 @GetRoleBgClass(ratio.RoleName)" style="width: @(ratio.Ratio)%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private SuperAdminDashboardStatsDto? stats;

    protected override async Task OnInitializedAsync()
    {
        stats = await SuperAdminService.GetStatsAsync();
    }

    private string GetRoleDisplayName(string role) => role switch
    {
        "superadmin" or "Super Admin" => "Super Admin",
        "admin" or "Tenant Admin" => "Tenant Admin",
        "manager" or "Organizer" => "Organizer",
        _ => "Sinh viên (Student)"
    };

    private string GetRoleColorClass(string role) => role switch
    {
        "superadmin" or "Super Admin" => "bg-rose-500",
        "admin" or "Tenant Admin" => "bg-amber-500",
        "manager" or "Organizer" => "bg-blue-500",
        _ => "bg-emerald-500"
    };

    private string GetRoleBgClass(string role) => role switch
    {
        "superadmin" or "Super Admin" => "bg-rose-500",
        "admin" or "Tenant Admin" => "bg-amber-500",
        "manager" or "Organizer" => "bg-blue-500",
        _ => "bg-emerald-500"
    };
}
