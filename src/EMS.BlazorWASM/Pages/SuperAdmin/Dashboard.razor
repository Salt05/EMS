@page "/SuperAdmin/Dashboard"
@attribute [Authorize(Roles = "superadmin")]
@inject ISuperAdminServiceClient SuperAdminService

<PageTitle>Dashboard Super Admin — EMS</PageTitle>

<div class="max-w-7xl mx-auto pb-12 pt-6">
    <!-- Header -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-charcoal flex items-center gap-2">
                Tổng Quan Hệ Thống
            </h1>
            <p class="text-sm text-muted mt-1">Số liệu tổng quan trên toàn bộ các Tenant và người dùng hệ thống.</p>
        </div>
        <ExportButtons />
    </div>

    @if (stats == null)
    {
        <div class="flex justify-center items-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-charcoal"></div>
        </div>
    }
    else
    {
        <!-- Stats Widgets -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <DashboardWidget Title="Tổng số Tenant" Value="@stats.TotalTenants.ToString()">
                <Icon>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                </Icon>
            </DashboardWidget>
            
            <DashboardWidget Title="Tổng số User" Value="@stats.TotalUsers.ToString()">
                <Icon>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                </Icon>
            </DashboardWidget>

            <DashboardWidget Title="Tổng số Event" Value="@stats.TotalEvents.ToString()">
                <Icon>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 00-2 2z" />
                    </svg>
                </Icon>
            </DashboardWidget>
        </div>

        <!-- Charts Section -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Top Tenants Chart (Bar) -->
            <div class="bg-white border border-border rounded-xl p-6 shadow-bento">
                <h3 class="text-base font-bold text-charcoal mb-4 flex items-center justify-between">
                    Top 5 Tenants Theo Số Lượng Sự Kiện
                    <span class="text-xs text-muted font-normal">Đơn vị: Sự kiện</span>
                </h3>
                <BarChart Labels="@stats.TopTenants.Select(t => t.TenantName).ToList()"
                          Data="@stats.TopTenants.Select(t => (double)t.EventCount).ToList()"
                          DatasetLabel="Số sự kiện"
                          Height="260" />
            </div>

            <!-- Role Ratio Chart (Doughnut) -->
            <div class="bg-white border border-border rounded-xl p-6 shadow-bento">
                <h3 class="text-base font-bold text-charcoal mb-4">Tỷ Lệ Người Dùng Theo Vai Trò</h3>
                <DoughnutChart Labels="@stats.RoleRatios.Select(r => $"{GetRoleDisplayName(r.RoleName)} ({r.UserCount})").ToList()"
                               Data="@stats.RoleRatios.Select(r => r.Ratio).ToList()"
                               DatasetLabel="Tỷ lệ (%)"
                               Colors="@(new List<string> { "#1A1F36", "#3B82F6", "#10B981", "#F59E0B", "#EF4444" })"
                               Height="260" />
            </div>
        </div>
    }
</div>

@code {
    private SuperAdminDashboardStatsDto? stats;

    protected override async Task OnInitializedAsync()
    {
        stats = await SuperAdminService.GetStatsAsync();
    }

    private string GetRoleDisplayName(string role) => role switch
    {
        "superadmin" or "Super Admin" => "Super Admin",
        "admin" or "Tenant Admin" => "Tenant Admin",
        "manager" or "Organizer" => "Organizer",
        _ => "Sinh viên (Student)"
    };
}
