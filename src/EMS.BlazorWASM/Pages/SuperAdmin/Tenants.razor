@page "/SuperAdmin/Tenants"
@attribute [Authorize(Roles = "superadmin")]
@inject ISuperAdminServiceClient SuperAdminService
@inject ToastService ToastService
@using EMS.Shared.DTOs

<PageTitle>Quản lý Tenants — EMS</PageTitle>

<div class="max-w-7xl mx-auto pb-12 pt-6">
    <!-- Header -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-charcoal flex items-center gap-2">
                Quản lý Tổ chức (Tenants)
            </h1>
            <p class="text-sm text-muted mt-1">Danh sách các trường, tổ chức sử dụng hệ thống quản lý sự kiện EMS.</p>
        </div>
        <div class="flex items-center gap-2">
            <button @onclick="() => LoadData(true)" class="inline-flex items-center justify-center gap-1.5 px-3.5 py-2 border border-border rounded-md hover:bg-canvas text-sm font-semibold text-charcoal bg-white shadow-sm transition-colors active:scale-[0.98]">
                <svg class="h-4 w-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12" />
                </svg>
                Làm mới dữ liệu
            </button>
            <button @onclick="OpenAddModal" class="inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-charcoal rounded-md shadow-sm hover:bg-slate-800 transition-all active:scale-[0.98]">
                <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
                Thêm Tenant mới
            </button>
        </div>
    </div>

    <!-- Data Table -->
    <DataTable TItem="TenantDTO" Items="filteredTenants" TotalCount="filteredTenants.Count" 
               Page="page" PageSize="pageSize" PageChanged="OnPageChanged" SearchChanged="OnSearchChanged" 
               SearchPlaceholder="Tìm kiếm theo tên, subdomain..." IsLoading="isLoading">
        <CustomFilter>
            <select class="block py-1.5 px-3 border border-border rounded-md text-sm bg-white focus:outline-none focus:ring-1 focus:ring-charcoal" @onchange="OnStatusFilterChanged">
                <option value="all">Tất cả trạng thái</option>
                <option value="active">Hoạt động (Active)</option>
                <option value="inactive">Khóa (Inactive)</option>
            </select>
        </CustomFilter>
        <TableHeader>
            <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Tên tổ chức</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Subdomain</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Admin Email</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Số user</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Số event</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Ngày tạo</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Trạng thái</th>
            <th class="px-6 py-3 text-right text-xs font-bold text-muted uppercase tracking-wider font-mono">Hành động</th>
        </TableHeader>
        <RowTemplate Context="tenant">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-charcoal">@tenant.Name</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@tenant.Subdomain</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@tenant.Email</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@tenant.UserCount</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@tenant.EventCount</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@tenant.CreatedAt.ToString("dd/MM/yyyy")</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @(tenant.IsActive ? "bg-emerald-100 text-emerald-800" : "bg-rose-100 text-rose-800")">
                    @(tenant.IsActive ? "Active" : "Inactive")
                </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
                <button @onclick="() => OpenEditModal(tenant)" class="text-charcoal hover:underline">Sửa</button>
                <button @onclick="() => OpenDeleteConfirm(tenant)" class="text-rose-600 hover:underline">Xóa</button>
            </td>
        </RowTemplate>
    </DataTable>
</div>

<!-- Add/Edit Form Modal -->
<FormModal Title="@(isEditMode ? "Sửa thông tin Tenant" : "Thêm Tenant mới")" IsOpen="isFormOpen" SaveText="Lưu lại" OnSave="SaveTenant" OnCancel="CloseForm">
    <div class="space-y-4">
        <div>
            <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Tên tổ chức / trường</label>
            <input type="text" @bind="currentTenant.Name" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" placeholder="Ví dụ: ĐH HUFLIT" />
        </div>
        <div>
            <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Subdomain</label>
            <input type="text" @bind="currentTenant.Subdomain" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" placeholder="Ví dụ: huflit" />
        </div>
        <div>
            <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Admin Email</label>
            <input type="email" @bind="currentTenant.Email" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" placeholder="admin@domain.com" />
        </div>
        @if (!isEditMode)
        {
            <div>
                <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Mật khẩu Admin</label>
                <input type="password" @bind="adminPassword" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" placeholder="********" />
            </div>
        }
        <div>
            <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Số điện thoại</label>
            <input type="text" @bind="currentTenant.PhoneNumber" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" />
        </div>
        <div>
            <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Địa chỉ</label>
            <input type="text" @bind="currentTenant.Address" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" />
        </div>
        <div class="flex items-center gap-2 mt-2">
            <input type="checkbox" id="isActive" @bind="currentTenant.IsActive" class="rounded border-border text-charcoal focus:ring-charcoal" />
            <label for="isActive" class="text-sm font-semibold text-charcoal">Kích hoạt hoạt động</label>
        </div>
    </div>
</FormModal>

<!-- Delete Confirm Modal -->
<ConfirmModal Title="Xác nhận xóa Tenant" Message="@($"Bạn có chắc chắn muốn xóa tenant '{tenantToDelete?.Name}'? Hành động này không thể hoàn tác.")" 
              IsOpen="isDeleteOpen" IsDanger="true" ConfirmText="Xóa ngay" OnConfirm="ConfirmDelete" OnCancel="() => isDeleteOpen = false" />

@code {
    private List<TenantDTO> allTenants = new();
    private List<TenantDTO> filteredTenants = new();
    private bool isLoading = true;
    private int page = 1;
    private int pageSize = 10;
    private string searchQuery = "";
    private string statusFilter = "all";

    // Form
    private bool isFormOpen;
    private bool isEditMode;
    private TenantDTO currentTenant = new();
    private string adminPassword = "";

    // Delete
    private bool isDeleteOpen;
    private TenantDTO? tenantToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData(bool bypassCache = false)
    {
        isLoading = true;
        try
        {
            allTenants = await SuperAdminService.GetTenantsAsync(bypassCache);
            ApplyFilter();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Không thể tải danh sách Tenants.");
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilter()
    {
        var temp = allTenants;

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            var q = searchQuery.ToLower();
            temp = temp.Where(t => t.Name.ToLower().Contains(q) || t.Subdomain.ToLower().Contains(q) || t.Email.ToLower().Contains(q)).ToList();
        }

        if (statusFilter == "active")
        {
            temp = temp.Where(t => t.IsActive).ToList();
        }
        else if (statusFilter == "inactive")
        {
            temp = temp.Where(t => !t.IsActive).ToList();
        }

        filteredTenants = temp;
    }

    private void OnPageChanged(int newPage) => page = newPage;

    private void OnSearchChanged(string query)
    {
        searchQuery = query;
        page = 1;
        ApplyFilter();
    }

    private void OnStatusFilterChanged(ChangeEventArgs e)
    {
        statusFilter = e.Value?.ToString() ?? "all";
        page = 1;
        ApplyFilter();
    }

    private void OpenAddModal()
    {
        isEditMode = false;
        currentTenant = new TenantDTO { IsActive = true };
        adminPassword = "";
        isFormOpen = true;
    }

    private void OpenEditModal(TenantDTO tenant)
    {
        isEditMode = true;
        currentTenant = new TenantDTO
        {
            Id = tenant.Id,
            Name = tenant.Name,
            Subdomain = tenant.Subdomain,
            Email = tenant.Email,
            PhoneNumber = tenant.PhoneNumber,
            Address = tenant.Address,
            IsActive = tenant.IsActive,
            CreatedAt = tenant.CreatedAt
        };
        isFormOpen = true;
    }

    private void CloseForm() => isFormOpen = false;

    private async Task SaveTenant()
    {
        if (string.IsNullOrWhiteSpace(currentTenant.Name) || string.IsNullOrWhiteSpace(currentTenant.Subdomain) || string.IsNullOrWhiteSpace(currentTenant.Email))
        {
            ToastService.ShowWarning("Vui lòng nhập đầy đủ các trường bắt buộc.");
            return;
        }

        isLoading = true;
        if (isEditMode)
        {
            var success = await SuperAdminService.UpdateTenantAsync(currentTenant.Id, currentTenant);
            if (success)
            {
                ToastService.ShowSuccess("Cập nhật thông tin Tenant thành công.");
                await LoadData();
            }
            else
            {
                ToastService.ShowError("Cập nhật Tenant thất bại.");
            }
        }
        else
        {
            if (string.IsNullOrWhiteSpace(adminPassword))
            {
                ToastService.ShowWarning("Vui lòng cung cấp mật khẩu tài khoản Admin.");
                isLoading = false;
                return;
            }

            var created = await SuperAdminService.CreateTenantAsync(currentTenant);
            if (created != null)
            {
                ToastService.ShowSuccess("Tạo Tenant thành công.");
                await LoadData();
            }
            else
            {
                ToastService.ShowError("Tạo Tenant thất bại.");
            }
        }
        isFormOpen = false;
        isLoading = false;
    }

    private void OpenDeleteConfirm(TenantDTO tenant)
    {
        // Simple mock check
        if (tenant.Id == "huflit" || tenant.Id == "bachkhoa")
        {
            ToastService.ShowWarning("Không thể xóa Tenant đang có dữ liệu người dùng/sự kiện thực tế.");
            return;
        }
        tenantToDelete = tenant;
        isDeleteOpen = true;
    }

    private async Task ConfirmDelete()
    {
        if (tenantToDelete != null)
        {
            var success = await SuperAdminService.DeleteTenantAsync(tenantToDelete.Id);
            if (success)
            {
                ToastService.ShowSuccess("Đã xóa Tenant thành công.");
                await LoadData();
            }
            else
            {
                ToastService.ShowError("Không thể xóa Tenant này.");
            }
        }
        isDeleteOpen = false;
    }
}
