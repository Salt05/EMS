@page "/SuperAdmin/Events"
@attribute [Authorize(Roles = "superadmin")]
@inject ISuperAdminServiceClient SuperAdminService
@inject ToastService ToastService
@using EMS.Shared.DTOs.Events
@using EMS.Shared.DTOs

<PageTitle>Quản lý Sự kiện Hệ thống — EMS</PageTitle>

<div class="max-w-7xl mx-auto pb-12 pt-6">
    <!-- Header -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-charcoal flex items-center gap-2">
                Quản lý Sự kiện Hệ Thống
            </h1>
            <p class="text-sm text-muted mt-1">Giám sát toàn bộ các sự kiện hoạt động chéo Tenants trên hệ thống EMS.</p>
        </div>
        <button @onclick="() => LoadData(true)" class="inline-flex items-center justify-center gap-1.5 px-3.5 py-2 border border-border rounded-md hover:bg-canvas text-sm font-semibold text-charcoal bg-white shadow-sm transition-colors active:scale-[0.98]">
            <svg class="h-4 w-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3-3 3 3m-3-3v12" />
            </svg>
            Làm mới dữ liệu
        </button>
    </div>
    
    <!-- Data Table -->
    <DataTable TItem="EventResponseDto" Items="filteredEvents" TotalCount="filteredEvents.Count" 
               Page="page" PageSize="pageSize" PageChanged="OnPageChanged" SearchChanged="OnSearchChanged" 
               SearchPlaceholder="Tìm kiếm theo tên sự kiện..." IsLoading="isLoading"
               OnRowClick="OpenDetailsModal">
        <CustomFilter>
            <div class="flex items-center gap-2">
                <select class="block py-1.5 px-3 border border-border rounded-md text-sm bg-white focus:outline-none focus:ring-1 focus:ring-charcoal" @onchange="OnTenantFilterChanged">
                    <option value="all">Tất cả Tenants</option>
                    @foreach (var tenant in tenants)
                    {
                        <option value="@tenant.Id">@tenant.Name</option>
                    }
                </select>
                <select class="block py-1.5 px-3 border border-border rounded-md text-sm bg-white focus:outline-none focus:ring-1 focus:ring-charcoal" @onchange="OnStatusFilterChanged">
                    <option value="0">Tất cả trạng thái</option>
                    <option value="1">Đang chờ duyệt (Pending)</option>
                    <option value="2">Đã phê duyệt (Approved)</option>
                    <option value="3">Đang diễn ra (Ongoing)</option>
                    <option value="4">Đã kết thúc (Ended)</option>
                    <option value="5">Đã hủy bỏ (Cancelled)</option>
                    <option value="6">Từ chối (Rejected)</option>
                </select>
            </div>
        </CustomFilter>
        <TableHeader>
            <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Tên sự kiện</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Tenant</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Người tạo</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Địa điểm</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Giá vé</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Trạng thái</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-muted uppercase tracking-wider font-mono">Thời gian bắt đầu</th>
        </TableHeader>
        <RowTemplate Context="evt">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-charcoal">@evt.Title</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-muted">@GetTenantName(evt.TenantId)</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@(string.IsNullOrEmpty(evt.OrganizerEmail) ? "Không rõ" : evt.OrganizerEmail)</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-muted">@evt.Location</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-emerald-600 font-bold">@(evt.Price == 0 ? "Miễn phí" : $"{evt.Price:N0}đ")</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold @GetStatusBadgeClass(evt.Status)">
                    @evt.StatusName
                </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-muted font-mono">@evt.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
        </RowTemplate>
    </DataTable>
</div>

<!-- Details Modal -->
<FormModal Title="Chi tiết Sự kiện" IsOpen="isDetailsOpen" SaveText="Đóng" SaveButtonVisible="false" OnSave="() => isDetailsOpen = false" OnCancel="() => isDetailsOpen = false">
    @if (selectedEvent != null)
    {
        <div class="space-y-4 text-sm">
            @if (!string.IsNullOrEmpty(selectedEvent.ImageUrl))
            {
                <div class="w-full aspect-video rounded-lg overflow-hidden border border-border bg-canvas mb-4">
                    <img src="@selectedEvent.ImageUrl" class="w-full h-full object-cover" />
                </div>
            }
            <div class="grid grid-cols-3 gap-2">
                <span class="font-bold text-muted text-xs uppercase">Tên sự kiện:</span>
                <span class="col-span-2 text-charcoal font-semibold">@selectedEvent.Title</span>
            </div>
            <div class="grid grid-cols-3 gap-2">
                <span class="font-bold text-muted text-xs uppercase">Tổ chức (Tenant):</span>
                <span class="col-span-2 text-charcoal">@GetTenantName(selectedEvent.TenantId)</span>
            </div>
            <div class="grid grid-cols-3 gap-2">
                <span class="font-bold text-muted text-xs uppercase">Người tạo:</span>
                <span class="col-span-2 text-charcoal font-mono">@(string.IsNullOrEmpty(selectedEvent.OrganizerEmail) ? "Không rõ" : selectedEvent.OrganizerEmail)</span>
            </div>
            <div class="grid grid-cols-3 gap-2">
                <span class="font-bold text-muted text-xs uppercase">Mô tả:</span>
                <span class="col-span-2 text-muted leading-relaxed">@selectedEvent.Description</span>
            </div>
            <div class="grid grid-cols-3 gap-2">
                <span class="font-bold text-muted text-xs uppercase">Địa điểm:</span>
                <span class="col-span-2 text-charcoal">@selectedEvent.Location</span>
            </div>
            <div class="grid grid-cols-3 gap-2">
                <span class="font-bold text-muted text-xs uppercase">Giá vé:</span>
                <span class="col-span-2 text-emerald-600 font-bold">@(selectedEvent.Price == 0 ? "Miễn phí" : $"{selectedEvent.Price:N0} VNĐ")</span>
            </div>
            <div class="grid grid-cols-3 gap-2">
                <span class="font-bold text-muted text-xs uppercase">Thời gian:</span>
                <span class="col-span-2 text-charcoal font-mono">@selectedEvent.StartTime.ToString("dd/MM/yyyy HH:mm") - @selectedEvent.EndTime.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="grid grid-cols-3 gap-2">
                <span class="font-bold text-muted text-xs uppercase">Sức chứa tối đa:</span>
                <span class="col-span-2 text-charcoal font-mono">@selectedEvent.Capacity người</span>
            </div>
            <div class="grid grid-cols-3 gap-2">
                <span class="font-bold text-muted text-xs uppercase">Trạng thái:</span>
                <span class="col-span-2">
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold @GetStatusBadgeClass(selectedEvent.Status)">
                        @selectedEvent.StatusName
                    </span>
                </span>
            </div>
            @if (selectedEvent.Status == 5 && !string.IsNullOrEmpty(selectedEvent.RejectionReason))
            {
                <div class="bg-rose-50 border border-rose-100 rounded-lg p-3 text-rose-800">
                    <strong class="block text-xs uppercase mb-1">Lý do hủy bỏ:</strong>
                    <p class="text-xs">@selectedEvent.RejectionReason</p>
                </div>
            }

            <div class="pt-4 border-t border-border flex items-center justify-between">
                <a href="/SuperAdmin/Events/edit/@selectedEvent.Id" class="px-4 py-2 text-sm font-semibold text-charcoal bg-white border border-border rounded-md hover:bg-canvas transition-colors">
                    Chỉnh sửa sự kiện
                </a>
                @if (selectedEvent.Status != 5 && selectedEvent.Status != 4)
                {
                    <button class="px-4 py-2 text-sm font-semibold text-white bg-rose-600 rounded-md shadow-sm hover:bg-rose-700 transition-all active:scale-[0.98]"
                            @onclick="TriggerCancelFromDetails">
                        Hủy sự kiện
                    </button>
                }
            </div>
        </div>
    }
</FormModal>

<!-- Cancel Event Modal -->
<FormModal Title="Xác nhận hủy Sự kiện hệ thống" IsOpen="isCancelOpen" SaveText="Xác nhận hủy" OnSave="CancelEvent" OnCancel="() => isCancelOpen = false">
    <div class="space-y-4">
        <p class="text-sm text-muted">Hành động này sẽ hủy bỏ sự kiện <strong>@selectedEvent?.Title</strong> trên toàn hệ thống và gửi email thông báo hủy.</p>
        <div>
            <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Lý do hủy (bắt buộc)</label>
            <textarea @bind="cancelReason" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" rows="3" placeholder="Nhập lý do hủy sự kiện..."></textarea>
        </div>
    </div>
</FormModal>

@code {
    private List<EventResponseDto> allEvents = new();
    private List<EventResponseDto> filteredEvents = new();
    private List<TenantDTO> tenants = new();
    private bool isLoading = true;

    private int page = 1;
    private int pageSize = 10;
    private string searchQuery = "";
    private string tenantFilter = "all";
    private int statusFilter = 0;

    // Modals
    private bool isDetailsOpen;
    private bool isCancelOpen;
    private EventResponseDto? selectedEvent;
    private string cancelReason = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData(bool bypassCache = false)
    {
        isLoading = true;
        try
        {
            tenants = await SuperAdminService.GetTenantsAsync(bypassCache);
            allEvents = await SuperAdminService.GetEventsAsync(bypassCache);
            ApplyFilter();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Không thể tải danh sách sự kiện.");
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilter()
    {
        var temp = allEvents;

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            var q = searchQuery.ToLower();
            temp = temp.Where(e => e.Title.ToLower().Contains(q)).ToList();
        }

        if (tenantFilter != "all")
        {
            temp = temp.Where(e => e.TenantId == tenantFilter).ToList();
        }

        if (statusFilter > 0)
        {
            temp = temp.Where(e => e.Status == statusFilter).ToList();
        }

        filteredEvents = temp;
    }

    private void OnPageChanged(int newPage) => page = newPage;

    private void OnSearchChanged(string query)
    {
        searchQuery = query;
        page = 1;
        ApplyFilter();
    }

    private void OnTenantFilterChanged(ChangeEventArgs e)
    {
        tenantFilter = e.Value?.ToString() ?? "all";
        page = 1;
        ApplyFilter();
    }

    private void OnStatusFilterChanged(ChangeEventArgs e)
    {
        statusFilter = int.TryParse(e.Value?.ToString(), out var res) ? res : 0;
        page = 1;
        ApplyFilter();
    }

    private string GetTenantName(string tenantId)
    {
        var tenant = tenants.Find(t => t.Id == tenantId);
        return tenant?.Name ?? tenantId;
    }

    private void OpenDetailsModal(EventResponseDto evt)
    {
        selectedEvent = evt;
        isDetailsOpen = true;
    }

    private void OpenCancelModal(EventResponseDto evt)
    {
        selectedEvent = evt;
        cancelReason = "";
        isCancelOpen = true;
    }

    private void TriggerCancelFromDetails()
    {
        isDetailsOpen = false;
        cancelReason = "";
        isCancelOpen = true;
    }

    private async Task CancelEvent()
    {
        if (selectedEvent == null) return;
        if (string.IsNullOrWhiteSpace(cancelReason))
        {
            ToastService.ShowWarning("Vui lòng cung cấp lý do hủy sự kiện.");
            return;
        }

        isLoading = true;
        var success = await SuperAdminService.CancelEventAsync(selectedEvent.Id, cancelReason);
        if (success)
        {
            ToastService.ShowSuccess("Đã hủy sự kiện và thông báo tới các bên liên quan.");
            await LoadData();
        }
        else
        {
            ToastService.ShowError("Hủy sự kiện thất bại.");
        }
        isCancelOpen = false;
        isLoading = false;
    }

    private string GetStatusBadgeClass(int status) => status switch
    {
        1 => "bg-amber-100 text-amber-800", // Pending
        2 => "bg-emerald-100 text-emerald-800", // Approved
        3 => "bg-blue-100 text-blue-800", // Ongoing
        4 => "bg-slate-100 text-slate-800", // Ended
        5 => "bg-rose-100 text-rose-800", // Cancelled
        _ => "bg-red-100 text-red-800" // Rejected / Unknown
    };
}
