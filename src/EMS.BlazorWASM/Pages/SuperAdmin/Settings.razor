@page "/SuperAdmin/Settings"
@attribute [Authorize(Roles = "superadmin")]
@inject ToastService ToastService

<PageTitle>Cấu hình hệ thống — EMS</PageTitle>

<div class="max-w-4xl mx-auto pb-12 pt-6">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold tracking-tight text-charcoal flex items-center gap-2">
            Cấu hình hệ thống
        </h1>
        <p class="text-sm text-muted mt-1">Cấu hình các tham số môi trường và dịch vụ cốt lõi của toàn hệ thống EMS.</p>
    </div>

    @if (isSaving)
    {
        <div class="flex justify-center items-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-charcoal"></div>
        </div>
    }
    else
    {
        <div class="space-y-8">
            <!-- SMTP Config -->
            <div class="bg-white border border-border rounded-xl p-6 shadow-bento">
                <h3 class="text-base font-bold text-charcoal mb-4 flex items-center gap-2">
                    <svg class="h-5 w-5 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 00-2 2z" />
                    </svg>
                    Cấu hình dịch vụ SMTP (Email)
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">SMTP Host</label>
                        <input type="text" @bind="smtpHost" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">SMTP Port</label>
                        <input type="number" @bind="smtpPort" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Username / Account</label>
                        <input type="text" @bind="smtpUser" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Password</label>
                        <input type="password" @bind="smtpPassword" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" />
                    </div>
                    <div class="md:col-span-2 flex items-center gap-2 mt-2">
                        <input type="checkbox" id="ssl" @bind="smtpSsl" class="rounded border-border text-charcoal focus:ring-charcoal" />
                        <label for="ssl" class="text-sm font-semibold text-charcoal">Kích hoạt SSL / TLS</label>
                    </div>
                </div>
            </div>

            <!-- Rate Limiting Config -->
            <div class="bg-white border border-border rounded-xl p-6 shadow-bento">
                <h3 class="text-base font-bold text-charcoal mb-4 flex items-center gap-2">
                    <svg class="h-5 w-5 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Cấu hình giới hạn tần suất (Rate Limiting)
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Giới hạn số request tối đa</label>
                        <input type="number" @bind="rateLimitRequests" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" />
                        <span class="text-[10px] text-muted">Số request được phép trên một đơn vị thời gian.</span>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Đơn vị thời gian (giây)</label>
                        <input type="number" @bind="rateLimitSeconds" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" />
                    </div>
                </div>
            </div>

            <!-- Firebase Config -->
            <div class="bg-white border border-border rounded-xl p-6 shadow-bento">
                <h3 class="text-base font-bold text-charcoal mb-4 flex items-center gap-2">
                    <svg class="h-5 w-5 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                    Cấu hình dịch vụ Firebase Auth / Firestore
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Firebase Project ID</label>
                        <input type="text" @bind="firebaseProjectId" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Firebase Storage Bucket</label>
                        <input type="text" @bind="firebaseBucket" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" />
                    </div>
                </div>
            </div>

            <!-- JWT Config -->
            <div class="bg-white border border-border rounded-xl p-6 shadow-bento">
                <h3 class="text-base font-bold text-charcoal mb-4 flex items-center gap-2">
                    <svg class="h-5 w-5 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                    </svg>
                    Cấu hình mã xác thực JSON Web Token (JWT)
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">JWT Issuer</label>
                        <input type="text" @bind="jwtIssuer" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-muted uppercase tracking-wider mb-1">Thời gian hết hạn (phút)</label>
                        <input type="number" @bind="jwtExpiry" class="block w-full py-2 px-3 border border-border rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-charcoal" />
                    </div>
                </div>
            </div>

            <!-- Save Bar -->
            <div class="flex items-center justify-end gap-3 pt-4">
                <button @onclick="ResetSettings" class="px-4 py-2 text-sm font-semibold text-charcoal bg-white border border-border rounded-md hover:bg-canvas transition-colors active:scale-[0.98]">
                    Khôi phục
                </button>
                <button @onclick="SaveSettings" class="px-5 py-2 text-sm font-semibold text-white bg-charcoal rounded-md shadow-sm hover:bg-slate-800 transition-all active:scale-[0.98]">
                    Lưu cấu hình
                </button>
            </div>
        </div>
    }
</div>

@code {
    private bool isSaving = false;

    // SMTP
    private string smtpHost = "smtp.gmail.com";
    private int smtpPort = 587;
    private string smtpUser = "no-reply@ems.local";
    private string smtpPassword = "password_secret";
    private bool smtpSsl = true;

    // Rate Limiting
    private int rateLimitRequests = 60;
    private int rateLimitSeconds = 60;

    // Firebase
    private string firebaseProjectId = "ems-portal-2026";
    private string firebaseBucket = "ems-portal-2026.appspot.com";

    // JWT
    private string jwtIssuer = "ems-auth-server";
    private int jwtExpiry = 180;

    private async Task SaveSettings()
    {
        isSaving = true;
        await Task.Delay(800); // Simulate saving delay
        isSaving = false;
        ToastService.ShowSuccess("Đã lưu cấu hình hệ thống thành công.");
    }

    private void ResetSettings()
    {
        smtpHost = "smtp.gmail.com";
        smtpPort = 587;
        smtpUser = "no-reply@ems.local";
        smtpPassword = "password_secret";
        smtpSsl = true;
        rateLimitRequests = 60;
        rateLimitSeconds = 60;
        firebaseProjectId = "ems-portal-2026";
        firebaseBucket = "ems-portal-2026.appspot.com";
        jwtIssuer = "ems-auth-server";
        jwtExpiry = 180;
        ToastService.ShowInfo("Đã khôi phục các giá trị mặc định.");
    }
}
