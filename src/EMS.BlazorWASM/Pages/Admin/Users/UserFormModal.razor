@* Modal tạo/chỉnh sửa user *@

@if (true)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center">
        <!-- Overlay -->
        <div class="fixed inset-0 bg-charcoal/30 backdrop-blur-sm" @onclick="OnClose"></div>

        <!-- Modal Card -->
        <div class="relative bg-white rounded-xl shadow-xl border border-border w-full max-w-lg mx-4 max-h-[90vh] overflow-y-auto z-10">
            <!-- Header -->
            <div class="flex items-center justify-between px-6 py-4 border-b border-border">
                <h2 class="text-lg font-bold text-charcoal">@(IsEdit ? "Chỉnh sửa người dùng" : "Thêm người dùng mới")</h2>
                <button class="p-1.5 rounded text-muted hover:text-charcoal hover:bg-canvas transition-colors" @onclick="OnClose">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>
            </div>

            <!-- Form -->
            <div class="p-6 space-y-4">
                <!-- Error -->
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="px-4 py-3 rounded-lg bg-paleRed-bg text-paleRed-text text-sm font-medium flex items-center gap-2">
                        <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                        @errorMessage
                    </div>
                }

                <!-- MSSV (chỉ khi tạo mới) -->
                @if (!IsEdit)
                {
                    <div>
                        <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1.5">MSSV</label>
                        <input type="text" @bind="mssv" placeholder="Nhập MSSV..."
                               class="w-full px-3 py-2 text-sm border border-border rounded-md bg-canvas focus:bg-white focus:ring-1 focus:ring-charcoal focus:border-charcoal outline-none transition-all" />
                    </div>
                }

                <!-- Họ tên -->
                <div>
                    <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1.5">Họ tên <span class="text-paleRed-text">*</span></label>
                    <input type="text" @bind="fullName" placeholder="Nhập họ tên đầy đủ..."
                           class="w-full px-3 py-2 text-sm border border-border rounded-md bg-canvas focus:bg-white focus:ring-1 focus:ring-charcoal focus:border-charcoal outline-none transition-all" />
                </div>

                <!-- Email -->
                <div>
                    <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1.5">Email <span class="text-paleRed-text">*</span></label>
                    <input type="email" @bind="email" placeholder="user@example.com"
                           class="w-full px-3 py-2 text-sm border border-border rounded-md bg-canvas focus:bg-white focus:ring-1 focus:ring-charcoal focus:border-charcoal outline-none transition-all" />
                </div>

                <!-- Số điện thoại -->
                <div>
                    <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1.5">Số điện thoại</label>
                    <input type="tel" @bind="phoneNumber" placeholder="0xxx xxx xxx"
                           class="w-full px-3 py-2 text-sm border border-border rounded-md bg-canvas focus:bg-white focus:ring-1 focus:ring-charcoal focus:border-charcoal outline-none transition-all" />
                </div>

                <!-- Khoa/Phòng ban -->
                <div>
                    <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1.5">Khoa / Phòng ban</label>
                    <input type="text" @bind="department" placeholder="Ví dụ: Công nghệ Thông tin"
                           class="w-full px-3 py-2 text-sm border border-border rounded-md bg-canvas focus:bg-white focus:ring-1 focus:ring-charcoal focus:border-charcoal outline-none transition-all" />
                </div>

                <!-- Role (Chỉ khi tạo mới) -->
                @if (!IsEdit)
                {
                    <div>
                        <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1.5">Vai trò <span class="text-paleRed-text">*</span></label>
                        <select @bind="selectedRole"
                                class="w-full px-3 py-2 text-sm border border-border rounded-md bg-canvas focus:bg-white focus:ring-1 focus:ring-charcoal focus:border-charcoal outline-none transition-all">
                            <option value="employee">Student</option>
                            <option value="manager">Organizer</option>
                            <option value="admin">Tenant Admin</option>
                            @if (IsSuperAdmin)
                            {
                                <option value="superadmin">Super Admin</option>
                            }
                        </select>
                    </div>
                }

                <!-- Tenant (Chỉ SuperAdmin khi tạo mới) -->
                @if (IsSuperAdmin && !IsEdit)
                {
                    <div>
                        <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1.5">Tenant <span class="text-paleRed-text">*</span></label>
                        <select @bind="selectedTenantId"
                                class="w-full px-3 py-2 text-sm border border-border rounded-md bg-canvas focus:bg-white focus:ring-1 focus:ring-charcoal focus:border-charcoal outline-none transition-all">
                            @foreach (var tenant in Tenants)
                            {
                                <option value="@tenant.Id">@tenant.Name</option>
                            }
                        </select>
                    </div>
                }

                <!-- Password (chỉ khi tạo mới) -->
                @if (!IsEdit)
                {
                    <div>
                        <label class="block text-xs font-semibold text-muted uppercase tracking-wider mb-1.5">Mật khẩu <span class="text-paleRed-text">*</span></label>
                        <input type="password" @bind="password" placeholder="Tối thiểu 6 ký tự..."
                               class="w-full px-3 py-2 text-sm border border-border rounded-md bg-canvas focus:bg-white focus:ring-1 focus:ring-charcoal focus:border-charcoal outline-none transition-all" />
                    </div>
                }
            </div>

            <!-- Footer -->
            <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-border bg-canvas/50">
                <button class="px-4 py-2 text-sm font-medium text-muted hover:text-charcoal bg-white border border-border rounded-md hover:bg-canvas transition-colors"
                        @onclick="OnClose" disabled="@isSaving">
                    Hủy
                </button>
                <button class="px-4 py-2 text-sm font-semibold text-white bg-charcoal rounded-md hover:bg-slate-800 transition-all active:scale-[0.98] disabled:opacity-50"
                        @onclick="HandleSubmit" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="flex items-center gap-2">
                            <span class="animate-spin h-3.5 w-3.5 border-2 border-white/30 border-t-white rounded-full"></span>
                            Đang lưu...
                        </span>
                    }
                    else
                    {
                        @(IsEdit ? "Cập nhật" : "Tạo mới")
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public AdminUserItemDto? User { get; set; }
    [Parameter] public bool IsSuperAdmin { get; set; }
    [Parameter] public string CurrentTenantId { get; set; } = string.Empty;
    [Parameter] public List<TenantDTO> Tenants { get; set; } = new();
    [Parameter] public EventCallback<(bool IsEdit, AdminCreateUserRequestDto? CreateDto, AdminUpdateUserRequestDto? UpdateDto, string? UserId)> OnSave { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    // Form fields
    private string mssv = string.Empty;
    private string fullName = string.Empty;
    private string email = string.Empty;
    private string? phoneNumber;
    private string? department;
    private string selectedRole = "employee";
    private string selectedTenantId = string.Empty;
    private string password = string.Empty;
    private string? errorMessage;
    private bool isSaving = false;

    protected override void OnInitialized()
    {
        if (IsEdit && User != null)
        {
            fullName = User.FullName;
            email = User.Email;
            phoneNumber = User.PhoneNumber;
            department = User.Department;
            selectedRole = User.RoleIds.FirstOrDefault() ?? "employee";
            selectedTenantId = User.TenantId;
        }
        else
        {
            // Default tenant
            selectedTenantId = Tenants.FirstOrDefault()?.Id ?? CurrentTenantId;
        }
    }

    private async Task HandleSubmit()
    {
        errorMessage = null;

        // Validation
        if (string.IsNullOrWhiteSpace(fullName))
        {
            errorMessage = "Họ tên không được để trống";
            return;
        }
        if (string.IsNullOrWhiteSpace(email) || !email.Contains("@"))
        {
            errorMessage = "Email không hợp lệ";
            return;
        }
        if (!IsEdit && string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Mật khẩu không được để trống";
            return;
        }
        if (!IsEdit && password.Length < 6)
        {
            errorMessage = "Mật khẩu phải có ít nhất 6 ký tự";
            return;
        }

        isSaving = true;
        StateHasChanged();

        try
        {
            if (IsEdit)
            {
                var updateDto = new AdminUpdateUserRequestDto
                {
                    FullName = fullName,
                    Email = email,
                    PhoneNumber = phoneNumber,
                    Department = department
                };
                await OnSave.InvokeAsync((true, null, updateDto, User?.Id));
            }
            else
            {
                var createDto = new AdminCreateUserRequestDto
                {
                    MSSV = string.IsNullOrWhiteSpace(mssv) ? null : mssv,
                    FullName = fullName,
                    Email = email,
                    PhoneNumber = phoneNumber,
                    Department = department,
                    Password = password,
                    RoleId = selectedRole,
                    TenantId = IsSuperAdmin ? selectedTenantId : CurrentTenantId
                };
                await OnSave.InvokeAsync((false, createDto, null, null));
            }
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }
}
