@page "/Admin/Reports"
@attribute [Authorize(Roles = "admin")]
@inject ITenantAdminServiceClient TenantAdminService
@inject ToastService ToastService
@inject IJSRuntime JSRuntime

<PageTitle>Báo cáo thống kê — EMS</PageTitle>

<div class="max-w-7xl mx-auto pb-12 pt-6">
    <!-- Header -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-charcoal">
                Báo cáo Thống kê
            </h1>
            <p class="text-sm text-muted mt-1">Phân tích số liệu đăng ký, điểm danh và hoạt động sự kiện trong tổ chức.</p>
        </div>
        <ExportButtons />
    </div>

    @if (stats == null)
    {
        <div class="flex justify-center items-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-charcoal"></div>
        </div>
    }
    else
    {
        <!-- Summary KPI Cards -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <DashboardWidget Title="Tổng sự kiện" Value="@stats.TotalEvents.ToString()">
                <Icon>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                </Icon>
            </DashboardWidget>
            <DashboardWidget Title="Đang diễn ra" Value="@stats.OngoingEvents.ToString()">
                <Icon>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                </Icon>
            </DashboardWidget>
            <DashboardWidget Title="Tỷ lệ Check-in" Value="@($"{stats.CheckInRate}%")">
                <Icon>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </Icon>
            </DashboardWidget>
            <DashboardWidget Title="Người dùng" Value="@stats.TotalUsers.ToString()">
                <Icon>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                </Icon>
            </DashboardWidget>
        </div>

        <!-- Charts Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">

            <!-- Top Organizers Bar Chart -->
            <div class="bg-white border border-border rounded-xl p-6 shadow-bento">
                <h3 class="text-base font-bold text-charcoal mb-4 flex items-center justify-between">
                    Top 5 Ban Tổ Chức Tích Cực
                    <span class="text-xs text-muted font-normal">Số sự kiện đã tạo</span>
                </h3>
                <BarChart Labels="@stats.TopOrganizers.Select(o => o.OrganizerName).ToList()"
                          Data="@stats.TopOrganizers.Select(o => (double)o.EventCount).ToList()"
                          DatasetLabel="Sự kiện"
                          Height="240" />
            </div>

            <!-- Check-in Rate Doughnut -->
            <div class="bg-white border border-border rounded-xl p-6 shadow-bento">
                <h3 class="text-base font-bold text-charcoal mb-4">Tỷ Lệ Điểm Danh Tổng Quan</h3>
                <DoughnutChart Labels="@(new List<string> { "Đã điểm danh", "Chưa điểm danh" })"
                               Data="@(new List<double> { stats.CheckInRate, Math.Max(0, 100 - stats.CheckInRate) })"
                               DatasetLabel="Tỷ lệ (%)"
                               Colors="@(new List<string> { "#1A1F36", "#E3E8EE" })"
                               Height="240" />
            </div>

            <!-- Monthly Events Line Chart (full width) -->
            <div class="bg-white border border-border rounded-xl p-6 shadow-bento lg:col-span-2">
                <h3 class="text-base font-bold text-charcoal mb-4">Xu Hướng Số Lượng Sự Kiện Theo Tháng</h3>
                <LineChart Labels="@stats.MonthlyEvents.Select(m => m.Month).ToList()"
                           Data="@stats.MonthlyEvents.Select(m => (double)m.EventCount).ToList()"
                           DatasetLabel="Sự kiện"
                           Height="220" />
            </div>

        </div>
    }
</div>

@code {
    private TenantAdminDashboardStatsDto? stats;

    protected override async Task OnInitializedAsync()
    {
        stats = await TenantAdminService.GetStatsAsync();
    }
}
