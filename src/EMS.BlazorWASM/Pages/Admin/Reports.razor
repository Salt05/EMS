@page "/Admin/Reports"
@attribute [Authorize(Roles = "admin,Admin")]
@inject ITenantAdminServiceClient TenantAdminService
@inject ToastService ToastService
@inject IJSRuntime JSRuntime
@using System.Text

<PageTitle>Báo cáo thống kê — EMS</PageTitle>

<div class="max-w-7xl mx-auto pb-12 pt-6">
    <!-- Header -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-charcoal flex items-center gap-2">
                Báo cáo Thống kê
                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-100 text-amber-800">
                    ⏳ DEMO
                </span>
            </h1>
            <p class="text-sm text-muted mt-1">Phân tích số liệu đăng ký, điểm danh và hoạt động sự kiện trong tổ chức.</p>
        </div>
        <button @onclick="ExportReport" class="inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-charcoal rounded-md shadow-sm hover:bg-slate-800 transition-all active:scale-[0.98]">
            <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Xuất báo cáo tổng hợp
        </button>
    </div>

    <!-- Bento Charts Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
        
        <!-- Registration vs Check-in ratio per event -->
        <div class="bg-white border border-border rounded-xl p-6 shadow-bento">
            <h3 class="text-base font-bold text-charcoal mb-4 flex items-center justify-between">
                Tỷ Lệ Đăng Ký vs Điểm Danh Theo Sự Kiện
                <span class="text-xs text-muted font-normal">Xám: Đăng ký | Đen: Điểm danh</span>
            </h3>
            <div class="mt-8 space-y-6">
                @foreach (var ev in mockEventStats)
                {
                    <div>
                        <div class="flex items-center justify-between text-sm mb-1.5">
                            <span class="font-medium text-charcoal">@ev.Title</span>
                            <span class="font-bold text-charcoal font-mono">@ev.CheckInCount / @ev.RegCount (@(ev.RegCount > 0 ? (ev.CheckInCount * 100 / ev.RegCount) : 0)%)</span>
                        </div>
                        <div class="w-full bg-canvas h-4 rounded-full overflow-hidden relative">
                            <!-- Registration bar (Grey-ish) -->
                            <div class="bg-slate-300 h-full rounded-full transition-all duration-500 absolute left-0" style="width: @(ev.RegPercent)%"></div>
                            <!-- Check-in bar (Black-ish) -->
                            <div class="bg-charcoal h-full rounded-full transition-all duration-500 absolute left-0" style="width: @(ev.CheckInPercent)%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Top 5 largest events -->
        <div class="bg-white border border-border rounded-xl p-6 shadow-bento">
            <h3 class="text-base font-bold text-charcoal mb-4">Top 5 Sự Kiện Có Lượng Sinh Viên Tham Gia Đông Nhất</h3>
            <div class="mt-8 space-y-6">
                @foreach (var ev in mockEventStats.OrderByDescending(e => e.CheckInCount).Take(5))
                {
                    var maxCheckin = mockEventStats.Max(e => e.CheckInCount);
                    var barWidth = maxCheckin > 0 ? (ev.CheckInCount * 100 / maxCheckin) : 0;
                    <div>
                        <div class="flex items-center justify-between text-sm mb-1.5">
                            <span class="font-medium text-charcoal flex items-center gap-2">
                                <span class="h-3 w-3 rounded-full bg-charcoal"></span>
                                @ev.Title
                            </span>
                            <span class="font-bold text-charcoal font-mono">@ev.CheckInCount sinh viên</span>
                        </div>
                        <div class="w-full bg-canvas h-3 rounded-full overflow-hidden">
                            <div class="bg-charcoal h-full rounded-full transition-all duration-500" style="width: @(barWidth)%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Registration timelines -->
        <div class="bg-white border border-border rounded-xl p-6 shadow-bento lg:col-span-2">
            <h3 class="text-base font-bold text-charcoal mb-4">Xu Hướng Số Lượng Đăng Ký Theo Thời Gian</h3>
            <div class="mt-8 flex items-end justify-between h-48 pt-6">
                @foreach (var trend in mockRegistrationTrends)
                {
                    var maxVal = mockRegistrationTrends.Max(t => t.Count);
                    var heightPercent = maxVal > 0 ? (trend.Count * 100 / maxVal) : 0;
                    <div class="flex flex-col items-center flex-1 group">
                        <span class="text-xs font-bold text-charcoal mb-2 opacity-0 group-hover:opacity-100 transition-opacity font-mono">@trend.Count Đăng ký</span>
                        <!-- Custom Gradient Bar -->
                        <div class="w-10 bg-gradient-to-t from-slate-200 to-charcoal/20 group-hover:to-charcoal rounded-t transition-all duration-300" style="height: @(heightPercent * 1.3)px"></div>
                        <span class="text-xs text-muted mt-2">@trend.Date</span>
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@code {
    private List<MockEventReportDto> mockEventStats = new()
    {
        new() { Title = "Hackathon HUFLIT 2026", RegCount = 150, CheckInCount = 120, RegPercent = 100, CheckInPercent = 80 },
        new() { Title = "Workshop Git & GitHub", RegCount = 85, CheckInCount = 78, RegPercent = 85, CheckInPercent = 78 },
        new() { Title = "Seminar AI & Deep Learning", RegCount = 120, CheckInCount = 95, RegPercent = 95, CheckInPercent = 75 },
        new() { Title = "Coding Contest", RegCount = 60, CheckInCount = 45, RegPercent = 60, CheckInPercent = 45 },
        new() { Title = "NCKH Sinh Viên", RegCount = 40, CheckInCount = 38, RegPercent = 40, CheckInPercent = 38 }
    };

    private List<MockTrendDto> mockRegistrationTrends = new()
    {
        new() { Date = "Thứ Hai", Count = 45 },
        new() { Date = "Thứ Ba", Count = 60 },
        new() { Date = "Thứ Tư", Count = 85 },
        new() { Date = "Thứ Năm", Count = 55 },
        new() { Date = "Thứ Sáu", Count = 110 },
        new() { Date = "Thứ Bảy", Count = 130 },
        new() { Date = "Chủ Nhật", Count = 95 }
    };

    private async Task ExportReport()
    {
        var csvBuilder = new StringBuilder();
        // Add BOM
        csvBuilder.Append("\uFEFF");
        csvBuilder.AppendLine("BÁO CÁO TỔNG HỢP HOẠT ĐỘNG SỰ KIỆN");
        csvBuilder.AppendLine($"Ngày xuất báo cáo: {DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")}");
        csvBuilder.AppendLine();
        csvBuilder.AppendLine("Tên sự kiện,Số lượng đăng ký,Số lượng điểm danh,Tỷ lệ điểm danh (%)");
        foreach (var ev in mockEventStats)
        {
            var rate = ev.RegCount > 0 ? (ev.CheckInCount * 100 / ev.RegCount) : 0;
            csvBuilder.AppendLine($"{ev.Title},{ev.RegCount},{ev.CheckInCount},{rate}%");
        }

        var bytes = Encoding.UTF8.GetBytes(csvBuilder.ToString());
        var base64 = Convert.ToBase64String(bytes);

        // Register download JS function dynamically
        await JSRuntime.InvokeVoidAsync("eval", @"
            window.downloadFile = (fileName, contentType, base64Content) => {
                const binary = atob(base64Content);
                const array = new Uint8Array(binary.length);
                for (let i = 0; i < binary.length; i++) {
                    array[i] = binary.charCodeAt(i);
                }
                const blob = new Blob([array], {type: contentType});
                const link = document.createElement('a');
                link.href = window.URL.createObjectURL(blob);
                link.download = fileName;
                link.click();
                window.URL.revokeObjectURL(link.href);
            };
        ");

        await JSRuntime.InvokeVoidAsync("downloadFile", "bao-cao-tong-hop-su-kien.csv", "text/csv;charset=utf-8", base64);
        ToastService.ShowSuccess("Báo cáo tổng hợp đã được xuất thành công.");
    }

    private class MockEventReportDto
    {
        public string Title { get; set; } = string.Empty;
        public int RegCount { get; set; }
        public int CheckInCount { get; set; }
        public int RegPercent { get; set; }
        public int CheckInPercent { get; set; }
    }

    private class MockTrendDto
    {
        public string Date { get; set; } = string.Empty;
        public int Count { get; set; }
    }
}
