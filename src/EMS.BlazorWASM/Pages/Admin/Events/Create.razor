@page "/admin/events/new"
@page "/admin/events/edit/{Id}"
@page "/SuperAdmin/Events/edit/{Id}"
@attribute [Authorize]
@inject EMS.BlazorWASM.Services.IEventServiceClient EventService
@inject EMS.BlazorWASM.Services.ISuperAdminServiceClient SuperAdminService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@using EMS.Shared.DTOs.Events

<PageTitle>@(isEditMode ? "Chỉnh sửa Sự kiện" : "Tạo Sự Kiện Mới") — EMS</PageTitle>

<div class="max-w-5xl mx-auto pb-12 pt-6">
    <!-- Header -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <div class="flex items-center gap-2 text-xs font-medium text-muted mb-2">
                <a href="/" class="hover:text-charcoal transition-colors">Bảng điều khiển</a>
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
                @if (isEditMode)
                {
                    <a href="@(isSuperAdmin ? "/SuperAdmin/Events" : "/admin/events")" class="hover:text-charcoal transition-colors">Danh sách sự kiện</a>
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                    <span class="text-charcoal">Chỉnh sửa</span>
                }
                else
                {
                    <span class="text-charcoal">Tạo Sự Kiện</span>
                }
            </div>
            <h1 class="text-2xl font-bold tracking-tight text-charcoal">@(isEditMode ? "Chỉnh sửa Sự kiện" : "Tạo Sự Kiện Mới")</h1>
        </div>
        <button type="button" @onclick="NavigateBack" class="px-4 py-2 text-sm font-medium text-charcoal bg-white border border-border rounded-md shadow-sm hover:bg-canvas transition-colors">
            Huỷ bỏ
        </button>
    </div>

    @if (isLoading)
    {
        <div class="flex justify-center items-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-charcoal"></div>
        </div>
    }
    else
    {
        <!-- Form -->
        <EMS.BlazorWASM.Components.EventForm 
            EventModel="@eventModel" 
            IsSubmitting="@isSubmitting" 
            ErrorMessage="@errorMessage" 
            SubmitButtonText="@(isEditMode ? "Lưu thay đổi" : "Tạo Sự Kiện Mới")" 
            OnValidSubmit="HandleSubmitAsync" />

        @if (isEditMode && !string.IsNullOrEmpty(Id))
        {
            <div class="mt-8">
                <EMS.BlazorWASM.Components.EventAgendaEditor EventId="@Id" EventStartTime="@eventModel.StartTime" />
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    private CreateEventDto eventModel = new();
    private bool isSubmitting = false;
    private bool isLoading = true;
    private bool isSuperAdmin = false;
    private string errorMessage = string.Empty;

    private bool isEditMode => !string.IsNullOrEmpty(Id);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isSuperAdmin = authState.User.IsInRole("superadmin");

        if (isEditMode)
        {
            isLoading = true;
            try
            {
                EventResponseDto? ev = null;
                if (isSuperAdmin)
                {
                    ev = await SuperAdminService.GetEventByIdAsync(Id!);
                }
                else
                {
                    ev = await EventService.GetEventByIdAsync(Id!);
                }

                if (ev != null)
                {
                    eventModel = new CreateEventDto
                    {
                        Title = ev.Title,
                        Description = ev.Description,
                        Location = ev.Location,
                        VenueId = ev.VenueId,
                        StartTime = ev.StartTime.ToLocalTime(),
                        EndTime = ev.EndTime.ToLocalTime(),
                        Capacity = ev.Capacity,
                        ImageUrl = ev.ImageUrl,
                        Price = ev.Price,
                        Scope = ev.Scope
                    };
                }
                else
                {
                    errorMessage = "Không tìm thấy thông tin sự kiện.";
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Lỗi khi tải thông tin sự kiện: {ex.Message}";
            }
            finally
            {
                isLoading = false;
            }
        }
        else
        {
            // Set default values for creation mode
            eventModel.StartTime = DateTime.Now.AddDays(1).Date.AddHours(9); // Tomorrow 9 AM
            eventModel.EndTime = DateTime.Now.AddDays(1).Date.AddHours(17); // Tomorrow 5 PM
            eventModel.Capacity = 0;
            isLoading = false;
        }
    }

    private async Task HandleSubmitAsync()
    {
        if (eventModel.StartTime >= eventModel.EndTime)
        {
            errorMessage = "Thời gian kết thúc phải diễn ra sau thời gian bắt đầu.";
            return;
        }

        errorMessage = string.Empty;
        isSubmitting = true;
        
        try
        {
            if (isEditMode)
            {
                var updateDto = new UpdateEventDto
                {
                    Title = eventModel.Title,
                    Description = eventModel.Description,
                    Location = eventModel.Location,
                    VenueId = eventModel.VenueId,
                    StartTime = eventModel.StartTime.ToUniversalTime(),
                    EndTime = eventModel.EndTime.ToUniversalTime(),
                    Capacity = eventModel.Capacity,
                    ImageUrl = eventModel.ImageUrl,
                    Price = eventModel.Price,
                    Scope = eventModel.Scope
                };

                bool success = false;
                if (isSuperAdmin)
                {
                    success = await SuperAdminService.UpdateEventAsync(Id!, updateDto);
                }
                else
                {
                    success = await EventService.UpdateEventAsync(Id!, updateDto);
                }

                if (success)
                {
                    NavigateBack();
                }
                else
                {
                    errorMessage = "Có lỗi xảy ra khi cập nhật sự kiện. Vui lòng kiểm tra lại thông tin.";
                }
            }
            else
            {
                var result = await EventService.CreateEventAsync(eventModel);
                if (result != null)
                {
                    NavigateBack();
                }
                else
                {
                    errorMessage = "Có lỗi xảy ra khi tạo sự kiện. Vui lòng kiểm tra lại thông tin.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi hệ thống: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void NavigateBack()
    {
        if (isEditMode)
        {
            if (isSuperAdmin)
                NavigationManager.NavigateTo("/SuperAdmin/Events");
            else
                NavigationManager.NavigateTo("/admin/events");
        }
        else
        {
            NavigationManager.NavigateTo("/admin/events");
        }
    }
}
