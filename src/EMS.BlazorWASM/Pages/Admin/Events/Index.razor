@page "/admin/events"
@attribute [Authorize]
@inject EMS.BlazorWASM.Services.IEventServiceClient EventService
@inject EMS.BlazorWASM.Services.IRegistrationServiceClient RegistrationService
@using EMS.Shared.DTOs.Events

<PageTitle>Quản lý Sự kiện — EMS</PageTitle>

<div class="max-w-7xl mx-auto pb-12 pt-6">
    <!-- Header -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <div class="flex items-center gap-2 text-xs font-medium text-muted mb-2">
                <a href="/" class="hover:text-charcoal transition-colors">Bảng điều khiển</a>
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
                <span class="text-charcoal">Danh sách sự kiện</span>
            </div>
            <h1 class="text-2xl font-bold tracking-tight text-charcoal">Sự kiện của bạn</h1>
        </div>
        <a href="admin/events/new" class="inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-charcoal rounded-md shadow-sm hover:bg-slate-800 transition-all active:scale-[0.98]">
            <svg class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Tạo Sự kiện
        </a>
    </div>

    @if (isLoading)
    {
        <div class="flex justify-center items-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-charcoal"></div>
        </div>
    }
    else
    {
        @if (events.Count == 0)
        {
            <div class="bg-white border border-dashed border-border rounded-xl p-12 text-center flex flex-col items-center">
                <div class="h-12 w-12 rounded-full bg-canvas flex items-center justify-center mb-4">
                    <svg class="h-6 w-6 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 00-2 2z" />
                    </svg>
                </div>
                <h3 class="text-lg font-bold text-charcoal mb-1">Chưa có sự kiện nào</h3>
                <p class="text-sm text-muted max-w-sm mb-6">Hãy tạo sự kiện đầu tiên để bắt đầu đón nhận đăng ký từ những người tham gia.</p>
                <a href="admin/events/new" class="px-4 py-2 text-sm font-semibold text-charcoal bg-white border border-border rounded-md hover:bg-canvas transition-colors">Tạo Sự kiện Ngay</a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var evt in events)
                {
                    var count = registrationCounts.ContainsKey(evt.Id) ? registrationCounts[evt.Id] : 0;
                    <a href="admin/events/@evt.Id" class="group bg-white border border-border rounded-xl overflow-hidden hover:shadow-bento-hover transition-all duration-300 flex flex-col">
                        <div class="relative w-full aspect-video bg-canvas overflow-hidden">
                            @if (!string.IsNullOrEmpty(evt.ImageUrl))
                            {
                                <img src="@evt.ImageUrl" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" onerror="this.src='https://placehold.co/600x400/F7F9FC/1A1F36?text=No+Image'; this.onerror=null;" />
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center bg-slate-100 group-hover:scale-105 transition-transform duration-500">
                                    <svg class="h-8 w-8 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                </div>
                            }
                            <div class="absolute top-3 left-3">
                                @if (evt.StartTime > DateTime.Now)
                                {
                                    <span class="inline-flex items-center px-2 py-1 rounded text-[10px] font-bold uppercase tracking-wider bg-white/90 text-charcoal backdrop-blur-sm border border-white/20 shadow-sm">
                                        Sắp tới
                                    </span>
                                }
                                else if (evt.EndTime < DateTime.Now)
                                {
                                    <span class="inline-flex items-center px-2 py-1 rounded text-[10px] font-bold uppercase tracking-wider bg-charcoal/80 text-white backdrop-blur-sm shadow-sm">
                                        Đã kết thúc
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2 py-1 rounded text-[10px] font-bold uppercase tracking-wider bg-emerald-500/90 text-white backdrop-blur-sm shadow-sm">
                                        Đang diễn ra
                                    </span>
                                }
                            </div>
                        </div>
                        
                        <div class="p-5 flex-1 flex flex-col justify-between">
                            <div>
                                <h3 class="text-base font-bold text-charcoal mb-1 line-clamp-1 transition-colors">@evt.Title</h3>
                                <div class="flex items-center gap-1.5 text-xs text-muted mb-3">
                                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 00-2 2z" />
                                    </svg>
                                    <span>@evt.StartTime.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>
                            
                            <div class="pt-4 border-t border-canvas flex items-center justify-between">
                                <div class="flex flex-col">
                                    <span class="text-[10px] font-semibold text-muted uppercase tracking-wider">Người tham gia</span>
                                    <div class="flex items-baseline gap-1">
                                        <span class="text-sm font-bold text-charcoal">@count</span>
                                        @if (evt.Capacity > 0)
                                        {
                                            <span class="text-xs text-muted">/ @evt.Capacity</span>
                                        }
                                    </div>
                                </div>
                                <div class="h-8 w-8 rounded-full border border-border flex items-center justify-center bg-canvas text-charcoal group-hover:bg-charcoal group-hover:text-white transition-colors">
                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                    </svg>
                                </div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private List<EventResponseDto> events = new();
    private Dictionary<string, int> registrationCounts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            events = await EventService.GetEventsAsync() ?? new List<EventResponseDto>();
            // Sort by newest start time first
            events = events.OrderByDescending(e => e.StartTime).ToList();
            
            registrationCounts.Clear();
            foreach (var evt in events)
            {
                var regs = await RegistrationService.GetEventRegistrationsAsync(evt.Id);
                registrationCounts[evt.Id] = regs?.Count ?? 0;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
