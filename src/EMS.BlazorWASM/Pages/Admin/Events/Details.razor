@page "/admin/events/{Id}"
@attribute [Authorize]
@inject EMS.BlazorWASM.Services.IEventServiceClient EventService
@inject EMS.BlazorWASM.Services.IRegistrationServiceClient RegistrationService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@using EMS.Shared.DTOs.Events
@using EMS.Shared.DTOs.Registrations
@using EMS.BlazorWASM.Services

<PageTitle>@(eventData?.Title ?? "Chi tiết Sự kiện") — EMS</PageTitle>

<div class="max-w-7xl mx-auto pb-12 pt-6">
    @if (isLoading)
    {
        <div class="flex justify-center items-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-charcoal"></div>
        </div>
    }
    else if (eventData == null)
    {
        <div class="bg-white border border-dashed border-border rounded-xl p-12 text-center">
            <h3 class="text-lg font-bold text-charcoal mb-2">Không tìm thấy sự kiện</h3>
            <p class="text-sm text-muted mb-6">Sự kiện này có thể đã bị xoá hoặc không tồn tại.</p>
            <a href="/admin/events" class="px-4 py-2 text-sm font-medium bg-canvas border border-border rounded-md text-charcoal">Quay lại danh sách</a>
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="mb-8 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
            <div>
                <div class="flex items-center gap-2 text-xs font-medium text-muted mb-2">
                    <a href="/admin/events" class="hover:text-charcoal transition-colors">Danh sách sự kiện</a>
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                    <span class="text-charcoal truncate max-w-[200px]">@eventData.Title</span>
                </div>
                <h1 class="text-2xl font-bold tracking-tight text-charcoal">@eventData.Title</h1>
            </div>
            
            <div class="flex items-center gap-2">
                <a href="/event/@eventData.Id" target="_blank" class="inline-flex items-center px-3 py-1.5 text-xs font-medium bg-white border border-border rounded-md hover:bg-canvas transition-colors">
                    <svg class="h-3.5 w-3.5 mr-1.5 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    Xem Public
                </a>
                <button @onclick="DeleteEventAsync" class="inline-flex items-center px-3 py-1.5 text-xs font-medium bg-white border border-red-200 text-red-600 rounded-md hover:bg-red-50 transition-colors">
                    <svg class="h-3.5 w-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                    Xoá sự kiện
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Left Column: Event Info -->
            <div class="space-y-6">
                <div class="bg-white border border-border rounded-xl shadow-bento overflow-hidden">
                    <div class="w-full aspect-video bg-canvas relative">
                        @if (!string.IsNullOrEmpty(eventData.ImageUrl))
                        {
                            <img src="@eventData.ImageUrl" class="w-full h-full object-cover" onerror="this.src='https://placehold.co/600x400/F7F9FC/1A1F36?text=No+Image'; this.onerror=null;" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center bg-slate-100">
                                <svg class="h-8 w-8 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            </div>
                        }
                    </div>
                    
                    <div class="p-6">
                        <div class="space-y-4">
                            <!-- Info row -->
                            <div class="flex items-start gap-3">
                                <div class="mt-0.5 text-muted">
                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 00-2 2z" />
                                    </svg>
                                </div>
                                <div>
                                    <p class="text-[10px] font-semibold text-muted uppercase tracking-wider mb-0.5">Thời gian</p>
                                    <p class="text-sm text-charcoal font-medium">@eventData.StartTime.ToString("HH:mm, dd/MM/yyyy")</p>
                                    <p class="text-xs text-muted">đến @eventData.EndTime.ToString("HH:mm, dd/MM/yyyy")</p>
                                </div>
                            </div>
                            
                            <!-- Info row -->
                            <div class="flex items-start gap-3">
                                <div class="mt-0.5 text-muted">
                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                </div>
                                <div>
                                    <p class="text-[10px] font-semibold text-muted uppercase tracking-wider mb-0.5">Địa điểm</p>
                                    <p class="text-sm text-charcoal font-medium">@(string.IsNullOrEmpty(eventData.Location) ? "Chưa cập nhật" : eventData.Location)</p>
                                </div>
                            </div>

                            <!-- Info row -->
                            <div class="flex items-start gap-3">
                                <div class="mt-0.5 text-muted">
                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                    </svg>
                                </div>
                                <div>
                                    <p class="text-[10px] font-semibold text-muted uppercase tracking-wider mb-0.5">Người tham dự</p>
                                    <p class="text-sm text-charcoal font-medium">@registrations.Count <span class="font-normal text-muted">/ @(eventData.Capacity > 0 ? eventData.Capacity.ToString() : "Không giới hạn")</span></p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-6 pt-5 border-t border-canvas">
                            <p class="text-[10px] font-semibold text-muted uppercase tracking-wider mb-2">Mô tả</p>
                            <div class="text-sm text-charcoal leading-relaxed whitespace-pre-wrap">
                                @(string.IsNullOrEmpty(eventData.Description) ? "Chưa có mô tả." : eventData.Description)
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Registrations Table -->
            <div class="lg:col-span-2">
                <div class="bg-white border border-border rounded-xl shadow-bento overflow-hidden flex flex-col h-full">
                    <div class="px-6 py-5 border-b border-border bg-white flex items-center justify-between">
                        <div>
                            <h2 class="text-sm font-bold text-charcoal">Danh sách Đăng ký</h2>
                            <p class="text-xs text-muted mt-0.5">Quản lý vé và phê duyệt người tham gia.</p>
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-canvas border-b border-border text-[10px] font-semibold text-muted uppercase tracking-wider font-mono">
                                    <th class="py-3 px-6">Tên</th>
                                    <th class="py-3 px-4">Ngày đăng ký</th>
                                    <th class="py-3 px-4">Trạng thái</th>
                                    <th class="py-3 px-6 text-right">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-border text-sm">
                                @if (registrations.Count == 0)
                                {
                                    <tr>
                                        <td colspan="4" class="py-12 text-center text-muted">
                                            Chưa có ai đăng ký sự kiện này.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var reg in registrations)
                                    {
                                        <tr class="hover:bg-canvas/50 transition-colors group">
                                            <td class="py-3 px-6 flex flex-col justify-center">
                                                <p class="font-semibold text-charcoal">@(string.IsNullOrWhiteSpace(reg.UserFullName) ? "Không có tên" : reg.UserFullName)</p>
                                                <p class="text-[10px] text-muted font-mono">@reg.UserEmail</p>
                                            </td>
                                            <td class="py-3 px-4">
                                                <span class="text-charcoal">@reg.CreatedAt.ToString("dd/MM/yyyy")</span>
                                                <p class="text-[10px] text-muted">@reg.CreatedAt.ToString("HH:mm")</p>
                                            </td>
                                            <td class="py-3 px-4">
                                                @if (reg.CheckedIn)
                                                {
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium font-mono bg-paleBlue-bg text-paleBlue-text">Đã Check-in</span>
                                                }
                                                else if (reg.Status == 2)
                                                {
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium font-mono bg-paleGreen-bg text-paleGreen-text">Thành công</span>
                                                }
                                                else if (reg.Status == 1)
                                                {
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium font-mono bg-paleYellow-bg text-paleYellow-text">Chờ duyệt</span>
                                                }
                                                else if (reg.Status == 5 || reg.Status == 4)
                                                {
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium font-mono bg-paleRed-bg text-paleRed-text">Đã huỷ</span>
                                                }
                                                else
                                                {
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium font-mono bg-slate-100 text-slate-600">Trạng thái @reg.Status</span>
                                                }
                                            </td>
                                            <td class="py-3 px-6 text-right space-x-2 lg:opacity-0 group-hover:opacity-100 transition-opacity">
                                                @if (reg.Status == 1)
                                                {
                                                    <button @onclick="() => HandleApprove(reg.Id)" class="inline-flex items-center px-2.5 py-1 text-xs font-semibold text-charcoal hover:bg-paleGreen-bg hover:text-paleGreen-text border border-border rounded transition-colors">Duyệt</button>
                                                }
                                                @if (reg.Status != 5 && reg.Status != 4 && !reg.CheckedIn)
                                                {
                                                    <button @onclick="() => HandleReject(reg.Id)" class="inline-flex items-center px-2.5 py-1 text-xs font-semibold text-red-600 hover:bg-paleRed-bg border border-transparent rounded transition-colors">Huỷ vé</button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private bool isLoading = true;
    private EventResponseDto? eventData;
    private List<RegistrationResponseDto> registrations = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            eventData = await EventService.GetEventByIdAsync(Id);
            if (eventData != null)
            {
                var regs = await RegistrationService.GetEventRegistrationsAsync(Id);
                registrations = regs?.OrderByDescending(r => r.CreatedAt).ToList() ?? new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleApprove(string regId)
    {
        var success = await RegistrationService.ApproveRegistrationAsync(regId);
        if (success)
        {
            await LoadDataAsync();
        }
    }

    private async Task HandleReject(string regId)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc chắn muốn huỷ đăng ký của người này?");
        if (!confirm) return;

        var success = await RegistrationService.RejectRegistrationAsync(regId, "Đã bị huỷ bởi Ban tổ chức");
        if (success)
        {
            await LoadDataAsync();
        }
    }

    private async Task DeleteEventAsync()
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "CẢNH BÁO: Xoá sự kiện sẽ xoá luôn tất cả đăng ký liên quan. Bạn có chắc chắn muốn xoá không?");
        if (!confirm) return;

        try
        {
            var success = await EventService.DeleteEventAsync(Id);
            if (success)
            {
                NavigationManager.NavigateTo("/admin/events");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Không thể xoá sự kiện. Có thể xảy ra lỗi kết nối.");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Lỗi: {ex.Message}");
        }
    }
}
