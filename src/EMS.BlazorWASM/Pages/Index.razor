@code {
    [Inject]
    private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;

    private bool isLoading = true;
    private bool isAdminOrManager = false;

    // User details
    private string userFullName = "Sinh viên";
    private string userEmail = "";
    private string? userMssv = "21520123";
    private string? userPhone = "0901 234 567";
    private string? _subdomain;
    private string? _tenantName;

    // Admin properties
    private List<EventResponseDto> events = new();
    private List<RegistrationResponseDto> allRegistrations = new();
    private List<RegistrationResponseDto> pendingRegistrations = new();
    private List<(string Message, DateTime Time)> recentActivities = new();

    private int totalRegistrations = 0;
    private int pendingApprovalsCount = 0;
    private int checkedInCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadContextDataAsync();
    }

    private async Task LoadContextDataAsync()
    {
        isLoading = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                if (user.IsInRole("superadmin") || user.IsInRole("SuperAdmin"))
                {
                    Navigation.NavigateTo("SuperAdmin/Dashboard");
                    return;
                }
                if (user.IsInRole("admin") || user.IsInRole("Admin"))
                {
                    Navigation.NavigateTo("Admin/Dashboard");
                    return;
                }
                if (user.IsInRole("manager") || user.IsInRole("Manager") || user.IsInRole("organizer"))
                {
                    Navigation.NavigateTo("Organizer/Dashboard");
                    return;
                }

                isAdminOrManager = IsAdminOrManager(user);
                userFullName = user.FindFirst(ClaimTypes.Name)?.Value ?? "Sinh viên";
                userEmail = user.FindFirst(ClaimTypes.Email)?.Value ?? "";

                // Get sub-details if available in custom claims (falling back to placeholders otherwise)
                userMssv = user.FindFirst("mssv")?.Value ?? "21520123";
                userPhone = user.FindFirst("phoneNumber")?.Value ?? "0901 234 567";
                
                // Try to get tenant details from subdomain
                var uri = new Uri(Navigation.Uri);
                var host = uri.Host;
                var parts = host.Split('.');
                if (parts.Length >= 2 && parts[0] != "localhost" && parts[0] != "ems")
                {
                    _subdomain = parts[0];
                    var tenants = await TenantService.GetTenantsAsync();
                    var tenant = tenants.FirstOrDefault(t => t.Subdomain.Equals(_subdomain, StringComparison.OrdinalIgnoreCase));
                    if (tenant != null)
                    {
                        _tenantName = tenant.Name;
                    }
                }
                else
                {
                    _subdomain = "default";
                }

                if (isAdminOrManager)
                {
                    await LoadAdminDataAsync();
                }
                else
                {
                    await LoadStudentDataAsync();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadAdminDataAsync()
    {
        try
        {
            events = await EventService.GetEventsAsync() ?? new List<EventResponseDto>();
            allRegistrations.Clear();
            recentActivities.Clear();

            // Fetch registrations for each event
            foreach (var evt in events)
            {
                var regs = await RegistrationService.GetEventRegistrationsAsync(evt.Id);
                if (regs != null)
                {
                    allRegistrations.AddRange(regs);
                }
            }

            totalRegistrations = allRegistrations.Count;
            pendingRegistrations = allRegistrations.Where(r => r.Status == (int)RegistrationStatus.Pending).ToList();
            pendingApprovalsCount = pendingRegistrations.Count;
            checkedInCount = allRegistrations.Count(r => r.CheckedIn);

            // Mock some recent activities based on registrations
            var latestRegs = allRegistrations.OrderByDescending(r => r.CreatedAt).Take(5);
            foreach(var r in latestRegs)
            {
                var evtName = events.FirstOrDefault(e => e.Id == r.EventId)?.Title ?? "Sự kiện";
                recentActivities.Add(($"Đăng ký mới: {r.UserFullName} tham gia {evtName}", r.CreatedAt));
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading admin dashboard data: {ex.Message}");
        }
    }

    private Task LoadStudentDataAsync()
    {
        // Student portal data loading logic placeholder (to connect to backend user API in future)
        return Task.CompletedTask;
    }

    private bool IsAdminOrManager(ClaimsPrincipal user) =>
        user.IsInRole("admin") || user.IsInRole("manager") ||
        user.IsInRole("Admin") || user.IsInRole("Manager");

    private async Task HandleApprove(string id)
    {
        var success = await RegistrationService.ApproveRegistrationAsync(id);
        if (success)
        {
            await LoadAdminDataAsync();
        }
    }

    private async Task HandleReject(string id)
    {
        var success = await RegistrationService.RejectRegistrationAsync(id, "Bị từ chối bởi Ban tổ chức");
        if (success)
        {
            await LoadAdminDataAsync();
        }
    }
}
