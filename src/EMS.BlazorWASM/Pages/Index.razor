@page "/"
@attribute [Authorize]
@inject NavigationManager Navigation
@inject EMS.BlazorWASM.Services.IAuthService AuthService
@using System.Security.Claims

<PageTitle>Dashboard — EMS</PageTitle>

@if (isLoading)
{
    <div class="flex justify-center items-center py-20">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-charcoal"></div>
    </div>
}

@code {
    [Inject]
    private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;

    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                if (user.IsInRole("superadmin"))
                {
                    Navigation.NavigateTo("SuperAdmin/Dashboard");
                    return;
                }
                if (user.IsInRole("admin"))
                {
                    Navigation.NavigateTo("Admin/Dashboard");
                    return;
                }
                if (user.IsInRole("manager"))
                {
                    Navigation.NavigateTo("Organizer/Dashboard");
                    return;
                }
                if (user.IsInRole("employee") || user.IsInRole("student") || user.IsInRole("Student"))
                {
                    var currentUri = new Uri(Navigation.Uri);
                    string studentPortalUrl = $"{currentUri.Scheme}://{currentUri.Host}";
                    if (currentUri.Port != 80 && currentUri.Port != 443)
                    {
                        studentPortalUrl += $":{currentUri.Port}";
                    }

                    studentPortalUrl += "/Home/Index";

                    var token = await AuthService.GetCurrentTokenAsync();
                    if (!string.IsNullOrEmpty(token))
                    {
                        studentPortalUrl += $"?token={Uri.EscapeDataString(token)}";
                    }

                    Navigation.NavigateTo(studentPortalUrl, forceLoad: true);
                    return;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error in redirect: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
