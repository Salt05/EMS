@inject NavigationManager Navigation

<aside class="fixed inset-y-0 left-0 z-50 flex w-64 flex-col bg-white border-r border-border transition-transform duration-300 @(SidebarOpen ? "translate-x-0" : "-translate-x-full") lg:translate-x-0 lg:static lg:h-full">
    <!-- Brand / Logo -->
    <div class="flex h-16 shrink-0 items-center px-6 border-b border-border">
        <a href="" class="flex items-center gap-3 group" @onclick="CloseSidebar">
            <!-- Minimal Geometric Logo -->
            <svg class="h-6 w-6 text-charcoal" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                <rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                <rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                <rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2" stroke-dasharray="2 2"/>
            </svg>
            <span class="font-bold text-lg tracking-tight font-sans">EMS <span class="font-normal text-muted">Admin</span></span>
        </a>
    </div>

    <!-- Navigation List -->
    <nav class="flex-1 space-y-7 px-4 py-6 overflow-y-auto">
        <!-- Section: Main -->
        <div>
            <span class="px-3 text-[10px] font-semibold text-muted uppercase tracking-widest font-mono">Overview</span>
            <ul class="mt-2 space-y-1">
                <li>
                    <NavLink class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-muted hover:text-charcoal hover:bg-canvas rounded-md transition-all duration-150" href="" Match="NavLinkMatch.All" @onclick="CloseSidebar">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2v-4zM14 16a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2v-4z" />
                        </svg>
                        Dashboard
                    </NavLink>
                </li>
            </ul>
        </div>

        <AuthorizeView Roles="admin,manager,Admin,Manager">
            <Authorized>
                <div>
                    <span class="px-3 text-[10px] font-semibold text-muted uppercase tracking-widest font-mono">Quản trị</span>
                    <ul class="mt-2 space-y-1">
                        <li>
                            <NavLink class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-muted hover:text-charcoal hover:bg-canvas rounded-md transition-all duration-150" href="admin/events" @onclick="CloseSidebar">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 00-2 2z" />
                                </svg>
                                Sự kiện
                            </NavLink>
                        </li>
                        <li>
                            <NavLink class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-muted hover:text-charcoal hover:bg-canvas rounded-md transition-all duration-150" href="admin/users" @onclick="CloseSidebar">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                    <circle cx="9" cy="7" r="4"/>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                </svg>
                                Người dùng
                            </NavLink>
                        </li>
                    </ul>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="admin,manager,Admin,Manager">
            <Authorized>
                <div>
                    <span class="px-3 text-[10px] font-semibold text-muted uppercase tracking-widest font-mono">Tổ chức</span>
                    <ul class="mt-2 space-y-1">
                        <li>
                            <NavLink class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-muted hover:text-charcoal hover:bg-canvas rounded-md transition-all duration-150" href="organizer/events" @onclick="CloseSidebar">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <polygon points="12 2 2 7 12 12 22 7 12 2"/>
                                    <polyline points="2 17 12 22 22 17"/>
                                    <polyline points="2 12 12 17 22 12"/>
                                </svg>
                                Sự kiện của tôi
                            </NavLink>
                        </li>
                    </ul>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="employee">
            <Authorized>
                <div>
                    <span class="px-3 text-[10px] font-semibold text-muted uppercase tracking-widest font-mono">Sinh viên</span>
                    <ul class="mt-2 space-y-1">
                        <li>
                            <NavLink class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-muted hover:text-charcoal hover:bg-canvas rounded-md transition-all duration-150" href="" Match="NavLinkMatch.All" @onclick="CloseSidebar">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                                </svg>
                                Cổng thông tin
                            </NavLink>
                        </li>
                        <li>
                            <a href="#" class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-muted hover:text-charcoal hover:bg-canvas rounded-md transition-all duration-150">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
                                </svg>
                                Vé của tôi (Demo)
                            </a>
                        </li>
                    </ul>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="admin,manager,Admin,Manager">
            <Authorized>
                <div>
                    <div class="flex items-center justify-between px-3">
                        <span class="text-[10px] font-semibold text-muted uppercase tracking-widest font-mono">Tác vụ (Demo)</span>
                        <span class="inline-flex items-center px-1.5 py-0.2 text-[10px] font-medium font-mono rounded bg-paleBlue-bg text-paleBlue-text">4 Active</span>
                    </div>
                    <ul class="mt-2 space-y-1">
                        <li>
                            <a href="#" class="flex items-center justify-between px-3 py-2 text-sm font-medium text-muted hover:text-charcoal hover:bg-canvas rounded-md transition-all duration-150">
                                <div class="flex items-center gap-3">
                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                    Phê duyệt
                                </div>
                                <span class="px-1.5 py-0.5 text-xs font-semibold font-mono rounded-full bg-paleYellow-bg text-paleYellow-text">18</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</aside>

@code {
    [Parameter]
    public bool SidebarOpen { get; set; }

    [Parameter]
    public EventCallback OnSidebarClose { get; set; }

    private async Task CloseSidebar()
    {
        if (OnSidebarClose.HasDelegate)
        {
            await OnSidebarClose.InvokeAsync();
        }
    }
}
