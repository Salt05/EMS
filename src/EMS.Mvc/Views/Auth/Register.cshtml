@model EMS.Shared.DTOs.Auth.RegisterRequest
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="row justify-content-center align-items-center mt-4">
    <div class="col-xl-6 col-lg-7 col-md-9 col-12">
        <div class="premium-card p-4 p-md-5">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary-subtle text-primary mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-person-plus-fill fs-2 text-primary"></i>
                </div>
                <h2 class="fw-bold mb-1">Đăng ký tài khoản</h2>
                <p class="text-muted small">Đăng ký tài khoản sinh viên tham gia sự kiện</p>
            </div>

            <form asp-controller="Auth" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-premium small py-2 mb-3" role="alert"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FullName" class="premium-form-label"><i class="bi bi-person me-1"></i> Họ và tên <span class="text-danger">*</span></label>
                        <input asp-for="FullName" type="text" class="form-control premium-form-control" placeholder="Nguyễn Văn A" required />
                        <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="premium-form-label"><i class="bi bi-envelope me-1"></i> Email <span class="text-danger">*</span></label>
                        <input asp-for="Email" type="email" class="form-control premium-form-control" placeholder="user@domain.com" required autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="MSSV" class="premium-form-label"><i class="bi bi-card-text me-1"></i> Mã số sinh viên (MSSV)</label>
                        <input asp-for="MSSV" type="text" class="form-control premium-form-control" placeholder="SV00123" />
                        <span asp-validation-for="MSSV" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="PhoneNumber" class="premium-form-label"><i class="bi bi-telephone me-1"></i> Số điện thoại</label>
                        <input asp-for="PhoneNumber" type="tel" class="form-control premium-form-control" placeholder="0987654321" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="premium-form-label"><i class="bi bi-key me-1"></i> Mật khẩu <span class="text-danger">*</span></label>
                    <input asp-for="Password" type="password" class="form-control premium-form-control" placeholder="••••••••" required autocomplete="new-password" />
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                    <div class="form-text text-muted small mt-1">Mật khẩu phải dài ít nhất 6 ký tự.</div>
                </div>

                <div class="mb-4 form-check d-flex align-items-center">
                    <input type="checkbox" class="form-check-input me-2" id="terms" required>
                    <label class="form-check-label text-muted small" for="terms">Tôi đồng ý với các <a href="#" class="text-decoration-none text-primary fw-medium">Điều khoản & Điều kiện</a> của hệ thống.</label>
                </div>

                <button type="submit" class="btn btn-premium w-100 py-2.5 mb-3">
                    <i class="bi bi-person-plus me-1"></i> Đăng ký tài khoản
                </button>

                <div class="text-center mt-3">
                    <span class="text-muted small">Bạn đã có tài khoản? </span>
                    <a asp-controller="Auth" asp-action="Login" class="text-primary fw-bold text-decoration-none small">Đăng nhập</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
