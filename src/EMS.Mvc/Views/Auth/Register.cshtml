@model EMS.Shared.DTOs.Auth.RegisterRequest
@{
    ViewData["Title"] = "Đăng ký tài khoản";
    Layout = "_Layout";
}

<style>
    .auth-canvas {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f8fafc 0%, #eef2f7 50%, #e8ecf4 100%);
        position: relative;
        overflow: hidden;
        padding: 3rem 1rem;
    }
    .auth-canvas::before,
    .auth-canvas::after {
        content: '';
        position: absolute;
        width: 24rem;
        height: 24rem;
        border-radius: 50%;
        background: rgba(203, 213, 225, 0.35);
        filter: blur(80px);
        pointer-events: none;
    }
    .auth-canvas::before { top: -10rem; left: -10rem; }
    .auth-canvas::after  { bottom: -10rem; right: -10rem; }

    .auth-card {
        width: 100%;
        max-width: 420px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 1rem;
        padding: 2rem 2.5rem;
        box-shadow: 0 1px 3px rgba(0,0,0,.04), 0 4px 16px rgba(0,0,0,.04);
        position: relative;
        z-index: 10;
    }

    .auth-logo {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: #1e293b;
        color: #fff;
        margin-bottom: 1rem;
        box-shadow: 0 1px 3px rgba(0,0,0,.1);
    }
    .auth-logo svg { width: 24px; height: 24px; }

    .auth-title {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #1e293b;
        margin-bottom: 0.25rem;
    }
    .auth-subtitle {
        font-size: 0.75rem;
        color: #94a3b8;
        margin-bottom: 0;
    }

    .auth-label {
        display: block;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #94a3b8;
        margin-bottom: 0.375rem;
    }
    .auth-label .auth-optional {
        font-weight: 400;
        text-transform: lowercase;
        color: rgba(148, 163, 184, 0.6);
    }

    .auth-input {
        width: 100%;
        padding: 0.625rem 0.875rem 0.625rem 2.5rem;
        font-size: 0.875rem;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        color: #1e293b;
        transition: all 0.15s;
        box-shadow: 0 1px 2px rgba(0,0,0,.03);
    }
    .auth-input:focus {
        outline: none;
        border-color: #1e293b;
        box-shadow: 0 0 0 1px #1e293b;
    }
    .auth-input::placeholder { color: rgba(148, 163, 184, 0.5); }

    .auth-field { position: relative; }
    .auth-field-icon {
        position: absolute;
        left: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(148, 163, 184, 0.6);
        pointer-events: none;
    }
    .auth-field-icon svg { width: 16px; height: 16px; }

    .auth-btn {
        width: 100%;
        padding: 0.625rem 1rem;
        font-size: 0.875rem;
        font-weight: 600;
        color: #fff;
        background: #1e293b;
        border: none;
        border-radius: 0.5rem;
        cursor: pointer;
        transition: all 0.15s;
        box-shadow: 0 1px 2px rgba(0,0,0,.08);
        margin-top: 0.5rem;
    }
    .auth-btn:hover { background: #334155; }
    .auth-btn:active { transform: scale(0.98); }

    .auth-divider {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e2e8f0;
        text-align: center;
        font-size: 0.75rem;
        color: #94a3b8;
    }
    .auth-divider a {
        font-weight: 600;
        color: #1e293b;
        text-decoration: none;
    }
    .auth-divider a:hover { text-decoration: underline; }

    .auth-copyright {
        font-size: 10px;
        color: rgba(148, 163, 184, 0.55);
        margin-top: 0.75rem;
    }

    .auth-error {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.75rem;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        font-weight: 600;
        background: #fef2f2;
        color: #dc2626;
        border: 1px solid #fecaca;
        margin-bottom: 1rem;
    }

    .auth-row {
        display: flex;
        gap: 1rem;
    }
    .auth-row > .auth-col {
        flex: 1;
        min-width: 0;
    }

    @@media (max-width: 576px) {
        .auth-row { flex-direction: column; gap: 0; }
    }
</style>

<div class="auth-canvas">
    <div class="auth-card">
        <!-- Logo & Header -->
        <div class="text-center mb-4">
            <div class="auth-logo">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                    <rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                    <rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                    <rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2" stroke-dasharray="2 2"/>
                </svg>
            </div>
            <h1 class="auth-title">Tạo tài khoản</h1>
            <p class="auth-subtitle">Đăng ký thành viên hệ thống EMS</p>
        </div>

        <form asp-controller="Auth" asp-action="Register" method="post">
            <!-- Validation Summary -->
            <div asp-validation-summary="ModelOnly" class="auth-error" role="alert"></div>

            <!-- Họ và tên + Email -->
            <div class="auth-row mb-3">
                <div class="auth-col">
                    <label asp-for="FullName" class="auth-label">Họ và tên <span class="text-danger">*</span></label>
                    <div class="auth-field">
                        <span class="auth-field-icon">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </span>
                        <input asp-for="FullName" type="text" class="auth-input" placeholder="Nguyễn Văn A" required />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="auth-col">
                    <label asp-for="Email" class="auth-label">Email <span class="text-danger">*</span></label>
                    <div class="auth-field">
                        <span class="auth-field-icon">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                        </span>
                        <input asp-for="Email" type="email" class="auth-input" placeholder="your@email.com" required autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <!-- MSSV + Số điện thoại -->
            <div class="auth-row mb-3">
                <div class="auth-col">
                    <label asp-for="MSSV" class="auth-label">Mã số sinh viên <span class="auth-optional">(tùy chọn)</span></label>
                    <div class="auth-field">
                        <span class="auth-field-icon">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.33 0 4 1 4 2v1H5v-1c0-1 2.67-2 4-2z" />
                            </svg>
                        </span>
                        <input asp-for="MSSV" type="text" class="auth-input" placeholder="2152xxxx (nếu có)" />
                    </div>
                    <span asp-validation-for="MSSV" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="auth-col">
                    <label asp-for="PhoneNumber" class="auth-label">Số điện thoại <span class="auth-optional">(tùy chọn)</span></label>
                    <div class="auth-field">
                        <span class="auth-field-icon">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>
                        </span>
                        <input asp-for="PhoneNumber" type="tel" class="auth-input" placeholder="09xxxxxxxx (nếu có)" />
                    </div>
                    <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <!-- Mật khẩu -->
            <div class="mb-4">
                <label asp-for="Password" class="auth-label">Mật khẩu <span class="text-danger">*</span></label>
                <div class="auth-field">
                    <span class="auth-field-icon">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                    </span>
                    <input asp-for="Password" type="password" class="auth-input" placeholder="Tối thiểu 6 ký tự" required autocomplete="new-password" />
                </div>
                <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- Submit -->
            <button type="submit" class="auth-btn">Đăng ký</button>
        </form>

        <!-- Footer -->
        <div class="auth-divider">
            <p class="mb-0">Đã có tài khoản? <a asp-controller="Auth" asp-action="Login">Đăng nhập</a></p>
            <p class="auth-copyright mb-0">© 2026 EMS — Event Management System</p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
