@model EMS.Shared.DTOs.Auth.RegisterRequest
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="row justify-content-center align-items-center mt-4">
    <div class="col-xl-6 col-lg-7 col-md-9 col-12">
        <div class="glass-card-strong p-4 p-md-5">
            <div class="text-center mb-4">
                <div class="auth-icon-bezel mb-3">
                    <div class="auth-icon-inner">
                        <i class="ri-user-add-line"></i>
                    </div>
                </div>
                <h2 class="fw-bold mb-1">Đăng ký tài khoản</h2>
                <p class="text-muted-custom small">Đăng ký tài khoản sinh viên tham gia sự kiện</p>
            </div>

            <form asp-controller="Auth" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="alert-glass alert-glass-danger small mb-3" role="alert"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FullName" class="form-glass-label"><i class="ri-user-line me-1"></i> Họ và tên <span class="text-danger">*</span></label>
                        <input asp-for="FullName" type="text" class="form-glass-input" placeholder="Nguyễn Văn A" required />
                        <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-glass-label"><i class="ri-mail-line me-1"></i> Email <span class="text-danger">*</span></label>
                        <input asp-for="Email" type="email" class="form-glass-input" placeholder="user@domain.com" required autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="MSSV" class="form-glass-label"><i class="ri-file-list-3-line me-1"></i> Mã số sinh viên (MSSV)</label>
                        <input asp-for="MSSV" type="text" class="form-glass-input" placeholder="SV00123" />
                        <span asp-validation-for="MSSV" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="PhoneNumber" class="form-glass-label"><i class="ri-phone-line me-1"></i> Số điện thoại</label>
                        <input asp-for="PhoneNumber" type="tel" class="form-glass-input" placeholder="0987654321" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-glass-label"><i class="ri-key-2-line me-1"></i> Mật khẩu <span class="text-danger">*</span></label>
                    <input asp-for="Password" type="password" class="form-glass-input" placeholder="••••••••" required autocomplete="new-password" />
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                    <div class="form-text text-muted-custom small mt-1">Mật khẩu phải dài ít nhất 6 ký tự.</div>
                </div>

                <div class="mb-4 form-check d-flex align-items-center">
                    <input type="checkbox" class="form-check-input me-2" id="terms" required>
                    <label class="form-check-label text-muted-custom small" for="terms">Tôi đồng ý với các <a href="#" class="text-decoration-none fw-medium text-primary-custom">Điều khoản & Điều kiện</a> của hệ thống.</label>
                </div>

                <button type="submit" class="btn-cta w-100 justify-content-center py-2.5 mb-3">
                    <span>Đăng ký tài khoản</span>
                    <span class="btn-icon-circle"><i class="ri-user-add-line"></i></span>
                </button>

                <div class="text-center mt-3">
                    <span class="text-muted-custom small">Bạn đã có tài khoản? </span>
                    <a asp-controller="Auth" asp-action="Login" class="fw-bold text-decoration-none small text-primary-custom">Đăng nhập</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
