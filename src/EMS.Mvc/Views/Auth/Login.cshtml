@model EMS.Shared.DTOs.Auth.LoginRequest
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_Layout";
}

<style>
    .auth-canvas {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f8fafc 0%, #eef2f7 50%, #e8ecf4 100%);
        position: relative;
        overflow: hidden;
        padding: 3rem 1rem;
    }
    .auth-canvas::before,
    .auth-canvas::after {
        content: '';
        position: absolute;
        width: 24rem;
        height: 24rem;
        border-radius: 50%;
        background: rgba(203, 213, 225, 0.35);
        filter: blur(80px);
        pointer-events: none;
    }
    .auth-canvas::before { top: -10rem; left: -10rem; }
    .auth-canvas::after  { bottom: -10rem; right: -10rem; }

    .auth-card {
        width: 100%;
        max-width: 420px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 1rem;
        padding: 2rem 2.5rem;
        box-shadow: 0 1px 3px rgba(0,0,0,.04), 0 4px 16px rgba(0,0,0,.04);
        position: relative;
        z-index: 10;
    }

    .auth-logo {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: #1e293b;
        color: #fff;
        margin-bottom: 1rem;
        box-shadow: 0 1px 3px rgba(0,0,0,.1);
    }
    .auth-logo svg { width: 24px; height: 24px; }

    .auth-title {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #1e293b;
        margin-bottom: 0.25rem;
    }
    .auth-subtitle {
        font-size: 0.75rem;
        color: #94a3b8;
        margin-bottom: 0;
    }

    .auth-label {
        display: block;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #94a3b8;
        margin-bottom: 0.375rem;
    }

    .auth-input {
        width: 100%;
        padding: 0.625rem 0.875rem 0.625rem 2.5rem;
        font-size: 0.875rem;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        color: #1e293b;
        transition: all 0.15s;
        box-shadow: 0 1px 2px rgba(0,0,0,.03);
    }
    .auth-input:focus {
        outline: none;
        border-color: #1e293b;
        box-shadow: 0 0 0 1px #1e293b;
    }
    .auth-input::placeholder { color: rgba(148, 163, 184, 0.5); }

    .auth-field { position: relative; }
    .auth-field-icon {
        position: absolute;
        left: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(148, 163, 184, 0.6);
        pointer-events: none;
    }
    .auth-field-icon svg { width: 16px; height: 16px; }

    .auth-btn {
        width: 100%;
        padding: 0.625rem 1rem;
        font-size: 0.875rem;
        font-weight: 600;
        color: #fff;
        background: #1e293b;
        border: none;
        border-radius: 0.5rem;
        cursor: pointer;
        transition: all 0.15s;
        box-shadow: 0 1px 2px rgba(0,0,0,.08);
    }
    .auth-btn:hover { background: #334155; }
    .auth-btn:active { transform: scale(0.98); }

    .auth-divider {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e2e8f0;
        text-align: center;
        font-size: 0.75rem;
        color: #94a3b8;
    }
    .auth-divider a {
        font-weight: 600;
        color: #1e293b;
        text-decoration: none;
    }
    .auth-divider a:hover { text-decoration: underline; }

    .auth-copyright {
        font-size: 10px;
        color: rgba(148, 163, 184, 0.55);
        margin-top: 0.75rem;
    }

    .auth-error {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.75rem;
        border-radius: 0.5rem;
        font-size: 0.75rem;
        font-weight: 600;
        background: #fef2f2;
        color: #dc2626;
        border: 1px solid #fecaca;
        margin-bottom: 1rem;
    }
</style>

<div class="auth-canvas">
    <div class="auth-card">
        <!-- Logo & Header -->
        <div class="text-center mb-4">
            <div class="auth-logo">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                    <rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                    <rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2"/>
                    <rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2" stroke-dasharray="2 2"/>
                </svg>
            </div>
            <h1 class="auth-title">EMS Dashboard</h1>
            <p class="auth-subtitle">Đăng nhập vào hệ thống quản lý sự kiện</p>
        </div>

        <form asp-controller="Auth" asp-action="Login" method="post">
            <!-- Validation Summary -->
            <div asp-validation-summary="ModelOnly" class="auth-error" role="alert"></div>

            <!-- Email -->
            <div class="mb-3">
                <label asp-for="Email" class="auth-label">Email</label>
                <div class="auth-field">
                    <span class="auth-field-icon">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </span>
                    <input asp-for="Email" type="email" class="auth-input" placeholder="your@email.com" required autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- Password -->
            <div class="mb-4">
                <label asp-for="Password" class="auth-label">Mật khẩu</label>
                <div class="auth-field">
                    <span class="auth-field-icon">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                    </span>
                    <input asp-for="Password" type="password" class="auth-input" placeholder="Nhập mật khẩu" required autocomplete="current-password" />
                </div>
                <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
            </div>

            <!-- Submit -->
            <button type="submit" class="auth-btn">Đăng nhập</button>
        </form>

        <!-- Footer -->
        <div class="auth-divider">
            <p class="mb-0">Chưa có tài khoản? <a asp-controller="Auth" asp-action="Register">Đăng ký ngay</a></p>
            <p class="auth-copyright mb-0">© 2026 EMS — Event Management System</p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
