@model EMS.Shared.DTOs.Auth.LoginRequest
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center align-items-center mt-5">
    <div class="col-xl-4 col-lg-5 col-md-7 col-12">
        <div class="glass-card-strong p-4 p-md-5">
            <div class="text-center mb-4">
                <div class="auth-icon-bezel mb-3">
                    <div class="auth-icon-inner">
                        <i class="ri-shield-keyhole-line"></i>
                    </div>
                </div>
                <h2 class="fw-bold mb-1">Chào mừng quay lại</h2>
                <p class="text-muted-custom small">Đăng nhập tài khoản EMS của bạn</p>
            </div>

            <form asp-controller="Auth" asp-action="Login" method="post">
                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="alert-glass alert-glass-danger small mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-glass-label"><i class="ri-mail-line me-1"></i> Email</label>
                    <input asp-for="Email" type="email" class="form-glass-input" placeholder="username@domain.com" required autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Password" class="form-glass-label mb-0"><i class="ri-key-2-line me-1"></i> Mật khẩu</label>
                        <a href="#" class="text-decoration-none small fw-medium text-primary-custom">Quên mật khẩu?</a>
                    </div>
                    <input asp-for="Password" type="password" class="form-glass-input" placeholder="••••••••" required autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4 form-check d-flex align-items-center">
                    <input type="checkbox" class="form-check-input me-2" id="rememberMe">
                    <label class="form-check-label text-muted-custom small" for="rememberMe">Ghi nhớ đăng nhập</label>
                </div>

                <button type="submit" class="btn-cta w-100 justify-content-center py-2.5 mb-3">
                    <span>Đăng nhập</span>
                    <span class="btn-icon-circle"><i class="ri-login-box-line"></i></span>
                </button>

                <div class="text-center mt-3">
                    <span class="text-muted-custom small">Bạn chưa có tài khoản? </span>
                    <a asp-controller="Auth" asp-action="Register" class="fw-bold text-decoration-none small text-primary-custom">Đăng ký ngay</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
