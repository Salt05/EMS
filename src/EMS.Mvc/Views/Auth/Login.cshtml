@model EMS.Shared.DTOs.Auth.LoginRequest
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center align-items-center mt-5">
    <div class="col-xl-4 col-lg-5 col-md-7 col-12">
        <div class="premium-card p-4 p-md-5">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary-subtle text-primary mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-shield-lock-fill fs-2 text-primary"></i>
                </div>
                <h2 class="fw-bold mb-1">Chào mừng quay lại</h2>
                <p class="text-muted small">Đăng nhập tài khoản EMS của bạn</p>
            </div>

            <form asp-controller="Auth" asp-action="Login" method="post">
                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-premium small py-2 mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="premium-form-label"><i class="bi bi-envelope me-1"></i> Email</label>
                    <input asp-for="Email" type="email" class="form-control premium-form-control" placeholder="username@domain.com" required autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Password" class="premium-form-label mb-0"><i class="bi bi-key me-1"></i> Mật khẩu</label>
                        <a href="#" class="text-decoration-none small text-primary fw-medium">Quên mật khẩu?</a>
                    </div>
                    <input asp-for="Password" type="password" class="form-control premium-form-control" placeholder="••••••••" required autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-3 form-check d-flex align-items-center">
                    <input type="checkbox" class="form-check-input me-2" id="rememberMe">
                    <label class="form-check-label text-muted small" for="rememberMe">Ghi nhớ đăng nhập</label>
                </div>

                <button type="submit" class="btn btn-premium w-100 py-2.5 mb-3">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                </button>

                <div class="text-center mt-3">
                    <span class="text-muted small">Bạn chưa có tài khoản? </span>
                    <a asp-controller="Auth" asp-action="Register" class="text-primary fw-bold text-decoration-none small">Đăng ký ngay</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
