@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi";
}

<div class="row justify-content-center align-items-center mt-5">
    <div class="col-xl-6 col-lg-7 col-md-9 col-12">
        <div class="glass-card-strong p-4 p-md-5 text-center">
            <div class="auth-icon-bezel mb-4 mx-auto" style="border-color:rgba(239,68,68,0.2);">
                <div class="auth-icon-inner" style="background:rgba(239,68,68,0.1); color:var(--danger);">
                    <i class="ri-error-warning-line"></i>
                </div>
            </div>
            
            <h1 class="heading-gradient mb-2" style="background: linear-gradient(135deg, var(--text-main) 30%, var(--danger) 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">Đã xảy ra lỗi</h1>
            <p class="subtitle-text mb-4">
                Hệ thống gặp sự cố khi xử lý yêu cầu của bạn. Vui lòng thử lại sau hoặc liên hệ ban quản trị.
            </p>

            @if (Model.ShowRequestId)
            {
                <div class="alert-glass alert-glass-danger mb-4 justify-content-center font-monospace small">
                    <i class="ri-terminal-box-line"></i>
                    <span>Mã yêu cầu (Request ID): <code>@Model.RequestId</code></span>
                </div>
            }

            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Home" asp-action="Index" class="btn-cta">
                    <span>Về trang chủ</span>
                    <span class="btn-icon-circle"><i class="ri-home-4-line"></i></span>
                </a>
                <a href="javascript:history.back()" class="btn-cta-outline">
                    <i class="ri-arrow-left-line"></i>
                    <span>Quay lại</span>
                </a>
            </div>
        </div>
    </div>
</div>
