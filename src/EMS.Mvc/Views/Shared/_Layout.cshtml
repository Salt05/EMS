@{
    string? userSession = Context.Request.Cookies["user_session"];
    string? displayName = null;
    string? userEmail = null;
    string? userRole = null;
    if (!string.IsNullOrEmpty(userSession))
    {
        var parts = userSession.Split('|');
        if (parts.Length >= 3)
        {
            displayName = parts[0];
            userEmail = parts[1];
            userRole = parts[2];
        }
    }
    string tenantName = (displayName != null) ? (Context.Items["TenantName"]?.ToString() ?? "EMS") : "EMS";
}

<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@tenantName — Hệ thống quản lý sự kiện sinh viên. Khám phá, đăng ký và tham gia các sự kiện học đường." />
    <title>@ViewData["Title"] - @tenantName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Remix Icon (Line) — per UI/UX Guideline -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@4.6.0/fonts/remixicon.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EMS.Mvc.styles.css" asp-append-version="true" />

    <!-- Dark Mode Flash Prevention: apply theme from localStorage BEFORE first paint -->
    <script>
        (function () {
            var theme = localStorage.getItem('ems-theme');
            if (theme === 'dark' || (!theme && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md glass-nav py-3">
            <div class="container">
                <a class="navbar-brand-gradient d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <i class="ri-calendar-event-fill" style="font-size:1.3rem;"></i>
                    <span>@tenantName</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse"
                        aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="ri-menu-3-line" style="font-size:1.4rem; color:var(--text-main);"></i>
                </button>
                <div class="collapse navbar-collapse" id="navbarCollapse">
                    <ul class="navbar-nav me-auto mb-2 mb-md-0">
                        <li class="nav-item">
                            <a class="nav-link nav-link-glass @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-glass @(ViewContext.RouteData.Values["controller"]?.ToString() == "Events" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Events" asp-action="Index">Trạng thái sự kiện</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-glass @(ViewContext.RouteData.Values["action"]?.ToString() == "Privacy" ? "active" : "")"
                               asp-controller="Home" asp-action="Privacy">Bảo mật</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-md-center gap-2">
                        <!-- Dark Mode Toggle Button -->
                        <li class="nav-item mb-2 mb-md-0">
                            <button id="themeToggleBtn"
                                    class="btn-theme-toggle"
                                    aria-label="Chuyển sang chế độ tối"
                                    title="Chuyển sang chế độ tối">
                                <i id="themeToggleIcon" class="ri-moon-line"></i>
                                <span id="themeToggleLabel">Tối</span>
                            </button>
                        </li>

                        @if (displayName != null)
                        {
                            <li class="nav-item me-md-1 mb-2 mb-md-0">
                                <a class="nav-link nav-link-glass @(ViewContext.RouteData.Values["controller"]?.ToString() == "Events" && ViewContext.RouteData.Values["action"]?.ToString() == "MyEvents" ? "active" : "")"
                                   asp-controller="Events" asp-action="MyEvents">
                                    <i class="ri-ticket-2-line me-1"></i>Sự kiện của tôi
                                </a>
                            </li>
                            <li class="nav-item dropdown me-md-1 mb-2 mb-md-0">
                                <a class="user-dropdown-trigger dropdown-toggle" href="#"
                                   id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="ri-user-3-line" style="color:var(--primary);"></i>
                                    <span>Chào, <strong>@displayName</strong></span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end dropdown-glass border-0 mt-2" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="ri-user-settings-line me-2"></i>Thông tin cá nhân
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="ri-settings-3-line me-2"></i>Cài đặt
                                        </a>
                                    </li>
                                </ul>
                            </li>
                            <li class="nav-item mb-2 mb-md-0">
                                <a class="btn-danger-outline" asp-controller="Auth" asp-action="Logout">
                                    <i class="ri-logout-box-r-line"></i> Đăng xuất
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-md-1 mb-2 mb-md-0">
                                <a class="nav-link nav-link-glass" asp-controller="Auth" asp-action="Login">
                                    <i class="ri-login-box-line me-1"></i> Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item mb-2 mb-md-0">
                                <a class="btn-cta btn-cta-sm" asp-controller="Auth" asp-action="Register">
                                    <span>Đăng ký</span>
                                    <span class="btn-icon-circle"><i class="ri-arrow-right-up-line"></i></span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- Success Toast Notification -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast-glass p-3 d-flex align-items-center" id="successToast" role="status" aria-live="polite">
            <div class="me-3" style="color:var(--success); font-size:1.3rem;">
                <i class="ri-checkbox-circle-fill"></i>
            </div>
            <div class="flex-grow-1">
                <div class="fw-bold" style="font-size:0.9rem;">Thành công</div>
                <div class="text-muted-custom" style="font-size:0.82rem;">@TempData["SuccessMessage"]</div>
            </div>
            <button type="button" class="btn-close ms-auto p-1" onclick="document.getElementById('successToast').style.display='none'" aria-label="Close"></button>
        </div>

        <script>
            setTimeout(function() {
                var toast = document.getElementById('successToast');
                if (toast) {
                    toast.style.transition = 'transform 0.5s cubic-bezier(0.34,1.56,0.64,1), opacity 0.5s ease';
                    toast.style.opacity = '0';
                    toast.style.transform = 'translateY(30px)';
                    setTimeout(function() { toast.remove(); }, 500);
                }
            }, 4000);
        </script>
    }

    <footer class="footer-section glass-footer mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-md-start text-center mb-2 mb-md-0">
                    <span class="fw-bold" style="color:var(--primary);">EMS</span>
                    <span class="text-muted-custom"> — Event Management System &copy; 2026</span>
                </div>
                <div class="col-md-6 text-md-end text-center">
                    <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted-custom me-3">Chính sách bảo mật</a>
                    <a href="#" class="text-decoration-none text-muted-custom">Điều khoản sử dụng</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
