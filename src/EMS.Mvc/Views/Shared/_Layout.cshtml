@{
    string? userSession = Context.Request.Cookies["user_session"];
    string? displayName = null;
    string? userEmail = null;
    string? userRole = null;
    if (!string.IsNullOrEmpty(userSession))
    {
        var parts = userSession.Split('|');
        if (parts.Length >= 3)
        {
            displayName = parts[0];
            userEmail = parts[1];
            userRole = parts[2];
        }
    }
    string tenantName = (displayName != null) ? (Context.Items["TenantName"]?.ToString() ?? "EMS") : "EMS";
}

<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@tenantName — Hệ thống quản lý sự kiện sinh viên. Khám phá, đăng ký và tham gia các sự kiện học đường." />
    <title>@ViewData["Title"] - @tenantName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Remix Icon (Line) — per Aplot Style Guide -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@4.6.0/fonts/remixicon.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/aplot-student-theme.css" asp-append-version="true" />
    <!-- Lenis Smooth Scroll CSS -->
    <link rel="stylesheet" href="https://unpkg.com/lenis@1.1.18/dist/lenis.css" />
    <link rel="stylesheet" href="~/EMS.Mvc.styles.css" asp-append-version="true" />

    <!-- Dark Mode Flash Prevention: apply theme from localStorage BEFORE first paint -->
    <script>
        (function () {
            var theme = localStorage.getItem('ems-theme');
            if (theme === 'dark' || (!theme && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
</head>
<body>
    <!-- Aurora Background Blobs (Ambient Floating Mesh) -->
    <div class="aurora-bg">
        <div class="aurora-blob aurora-blob-1"></div>
        <div class="aurora-blob aurora-blob-2"></div>
        <div class="aurora-blob aurora-blob-3"></div>
        <div class="aurora-blob aurora-blob-4"></div>
    </div>

    <!-- Floating Glass Header -->
    <header class="floating-header-wrap">
        <nav class="navbar navbar-expand-md glass-nav py-2">
            <div class="container-fluid px-2">
                <a class="navbar-brand-gradient navbar-brand-aplot d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <div class="brand-icon-pill">
                        <i class="ri-sparkles-line"></i>
                    </div>
                    <span class="brand-title-text">@tenantName</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse"
                        aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="ri-menu-3-line" style="font-size:1.4rem; color:var(--text-main);"></i>
                </button>
                <div class="collapse navbar-collapse mt-2 mt-md-0" id="navbarCollapse">
                    <ul class="navbar-nav me-auto mb-2 mb-md-0 gap-1 ms-md-3">
                        <li class="nav-item">
                            <a class="nav-link nav-link-glass nav-link-aplot @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Home" asp-action="Index">
                                <i class="ri-compass-3-line"></i> Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-glass nav-link-aplot @(ViewContext.RouteData.Values["controller"]?.ToString() == "Events" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Events" asp-action="Index">
                                <i class="ri-calendar-event-line"></i> Sự kiện
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-glass nav-link-aplot @(ViewContext.RouteData.Values["action"]?.ToString() == "Privacy" ? "active" : "")"
                               asp-controller="Home" asp-action="Privacy">
                                <i class="ri-shield-user-line"></i> Bảo mật
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-md-center gap-2">
                        <!-- Dark / Light Theme Toggle Button -->
                        <li class="nav-item mb-2 mb-md-0">
                            <button id="themeToggleBtn"
                                    class="btn-theme-toggle btn-theme-toggle-aplot"
                                    aria-label="Chuyển chế độ Dark/Light"
                                    title="Chuyển giao diện sáng/tối">
                                <i id="themeToggleIcon" class="ri-moon-line"></i>
                                <span id="themeToggleLabel">Tối</span>
                            </button>
                        </li>

                        @if (displayName != null)
                        {
                            <li class="nav-item me-md-1 mb-2 mb-md-0">
                                <a class="nav-link nav-link-glass nav-link-aplot @(ViewContext.RouteData.Values["controller"]?.ToString() == "Events" && ViewContext.RouteData.Values["action"]?.ToString() == "MyEvents" ? "active" : "")"
                                   asp-controller="Events" asp-action="MyEvents">
                                    <i class="ri-ticket-2-line"></i> Vé của tôi
                                </a>
                            </li>
                            <li class="nav-item dropdown me-md-1 mb-2 mb-md-0">
                                <a class="user-dropdown-trigger dropdown-toggle nav-link nav-link-glass nav-link-aplot" href="#"
                                   id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="ri-user-3-line" style="color:var(--primary-indigo);"></i>
                                    <span>Chào, <strong>@displayName</strong></span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end dropdown-glass glass-panel border-0 mt-2 p-2 shadow-lg" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item nav-link-aplot py-2" href="#">
                                            <i class="ri-user-settings-line me-2"></i>Thông tin cá nhân
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item nav-link-aplot py-2" href="#">
                                            <i class="ri-settings-3-line me-2"></i>Cài đặt
                                        </a>
                                    </li>
                                </ul>
                            </li>
                            <li class="nav-item mb-2 mb-md-0">
                                <a class="btn-cta-outline btn-cta-sm text-danger" asp-controller="Auth" asp-action="Logout">
                                    <i class="ri-logout-box-r-line"></i> Đăng xuất
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-md-1 mb-2 mb-md-0">
                                <a class="nav-link nav-link-glass nav-link-aplot" asp-controller="Auth" asp-action="Login">
                                    <i class="ri-login-box-line"></i> Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item mb-2 mb-md-0">
                                <a class="btn-cta btn-cta-sm" asp-controller="Auth" asp-action="Register">
                                    <span>Đăng ký</span>
                                    <span class="btn-icon-circle"><i class="ri-arrow-right-up-line"></i></span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-content py-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- Success Toast Notification -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="glass-panel p-3 d-flex align-items-center position-fixed bottom-0 end-0 m-4 shadow-lg" id="successToast" style="z-index: 1050; max-width: 380px; border-radius: var(--radius-md);" role="status" aria-live="polite">
            <div class="me-3" style="color:var(--accent-emerald); font-size:1.4rem;">
                <i class="ri-checkbox-circle-fill"></i>
            </div>
            <div class="flex-grow-1">
                <div class="fw-bold" style="font-size:0.9rem;">Thành công</div>
                <div class="text-secondary" style="font-size:0.82rem;">@TempData["SuccessMessage"]</div>
            </div>
            <button type="button" class="btn-close ms-auto p-1" onclick="document.getElementById('successToast').style.display='none'" aria-label="Close"></button>
        </div>

        <script>
            setTimeout(function() {
                var toast = document.getElementById('successToast');
                if (toast) {
                    toast.style.transition = 'transform 0.5s cubic-bezier(0.34,1.56,0.64,1), opacity 0.5s ease';
                    toast.style.opacity = '0';
                    toast.style.transform = 'translateY(30px)';
                    setTimeout(function() { toast.remove(); }, 500);
                }
            }, 4000);
        </script>
    }

    <footer class="footer-section glass-panel mt-auto py-3 mx-3 my-3">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-md-start text-center mb-2 mb-md-0">
                    <span class="fw-bold" style="color:var(--primary-indigo);">@tenantName</span>
                    <span class="text-muted" style="font-size: 0.9rem;"> — Event Management System &copy; 2026</span>
                </div>
                <div class="col-md-6 text-md-end text-center">
                    <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-secondary me-3" style="font-size: 0.88rem;">Chính sách bảo mật</a>
                    <a href="#" class="text-decoration-none text-secondary" style="font-size: 0.88rem;">Điều khoản sử dụng</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Lenis Smooth Scroll & GSAP + ScrollTrigger Libraries -->
    <script src="https://unpkg.com/lenis@1.1.18/dist/lenis.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

