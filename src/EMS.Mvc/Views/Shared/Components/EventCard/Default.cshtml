@model EMS.Core.Entities.Event

<div class="premium-card event-card position-relative h-100 d-flex flex-column">
    <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=800&auto=format&fit=crop&q=60" : Model.ImageUrl)" 
         class="card-img-top event-image" alt="@Model.Title"
         onerror="this.onerror=null;this.src='https://placehold.co/800x400/6366f1/ffffff?text=EMS+Event';">
    <span class="event-badge @ViewBag.BadgeClass">@ViewBag.BadgeText</span>
    
    <div class="p-4 flex-grow-1">
        <h5 class="fw-bold text-dark mb-2">@Model.Title</h5>
        <p class="text-muted small mb-3">
            <i class="bi bi-calendar-event me-1"></i> @Model.StartTime.ToString("dd/MM/yyyy HH:mm") – @Model.EndTime.ToString("HH:mm")<br />
            <i class="bi bi-geo-alt me-1"></i> @Model.Location
        </p>
        @{
            var displayDesc = Model.Description ?? string.Empty;
            if (displayDesc.Length > 110)
            {
                displayDesc = displayDesc.Substring(0, 107) + "...";
            }
        }
        <p class="text-secondary small mb-0">@displayDesc</p>
    </div>

    <div class="event-footer d-flex justify-content-between align-items-center mt-auto" style="border-top: 1px solid #f3f4f6; padding-top: 1rem;">
        <span class="small text-muted"><i class="bi bi-people me-1"></i> Sức chứa: @Model.Capacity</span>
        <a asp-controller="Events" asp-action="Detail" asp-route-id="@Model.Id" class="btn btn-sm btn-premium py-1.5 px-3">Chi tiết</a>
    </div>
</div>
