@model List<EMS.Core.Entities.Event>
@{
    ViewData["Title"] = "Trạng thái Sự kiện";
    var searchString = ViewData["SearchString"] as string;

    var now = DateTime.UtcNow;

    // Phân loại sự kiện theo trạng thái thực tế
    string GetStatusKey(EMS.Core.Entities.Event ev) {
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Cancelled ||
            ev.Status == EMS.Core.Entities.Enums.EventStatus.Rejected ||
            ev.Status == EMS.Core.Entities.Enums.EventStatus.Pending)
            return "other";
        if (now >= ev.StartTime && now <= ev.EndTime) return "ongoing";
        if (now < ev.StartTime) return "upcoming";
        return "ended";
    }

    var allEvents = Model ?? new List<EMS.Core.Entities.Event>();
    var ongoingEvents  = allEvents.Where(e => GetStatusKey(e) == "ongoing").OrderBy(e => e.StartTime).ToList();
    var upcomingEvents = allEvents.Where(e => GetStatusKey(e) == "upcoming").OrderBy(e => e.StartTime).ToList();
    var endedEvents    = allEvents.Where(e => GetStatusKey(e) == "ended" || GetStatusKey(e) == "other")
                                  .OrderByDescending(e => e.EndTime).ToList();
}

@functions {
    string GetEventStatusClass(EMS.Core.Entities.Event ev)
    {
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Cancelled)
            return "status-badge-cancelled";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Rejected)
            return "status-badge-rejected";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Pending)
            return "status-badge-pending";

        var now = DateTime.UtcNow;
        if (now < ev.StartTime)
            return "status-badge-upcoming";
        if (now >= ev.StartTime && now <= ev.EndTime)
            return "status-badge-ongoing";
        return "status-badge-ended";
    }

    string GetEventStatusName(EMS.Core.Entities.Event ev)
    {
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Cancelled)
            return "Đã hủy";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Rejected)
            return "Đã từ chối";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Pending)
            return "Chờ phê duyệt";

        var now = DateTime.UtcNow;
        if (now < ev.StartTime)
            return "Chưa diễn ra";
        if (now >= ev.StartTime && now <= ev.EndTime)
            return "Đang diễn ra";
        return "Đã kết thúc";
    }
}

<div class="container my-4">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-12">
            <span class="eyebrow-tag">Cổng Sinh Viên</span>
            <h1 class="heading-gradient heading-gradient-md mb-2">Trạng thái Sự kiện</h1>
            <p class="subtitle-text">Theo dõi trạng thái tất cả sự kiện: đang diễn ra, sắp diễn ra và đã kết thúc.</p>
        </div>
    </div>

    <!-- Search Section — Glass Card -->
    <div class="glass-card-strong p-4 mb-4">
        <form method="get" asp-controller="Events" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-9">
                <div style="position:relative;">
                    <i class="ri-search-2-line" style="position:absolute; left:14px; top:50%; transform:translateY(-50%); color:var(--text-muted); font-size:1.1rem;"></i>
                    <input type="text" name="searchString"
                           class="form-glass-input"
                           style="padding-left:2.5rem;"
                           placeholder="Tìm kiếm theo tên sự kiện, nội dung hoặc địa điểm..."
                           value="@searchString" />
                </div>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn-cta w-100 justify-content-center">
                    <span>Tìm kiếm</span>
                    <span class="btn-icon-circle"><i class="ri-search-line"></i></span>
                </button>
            </div>
        </form>
    </div>

    <!-- Result Banner (khi tìm kiếm) -->
    @if (!string.IsNullOrEmpty(searchString))
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div style="color:var(--text-secondary);">
                Tìm thấy <strong>@Model.Count</strong> kết quả cho từ khóa
                <span class="status-badge" style="background:rgba(0,0,0,0.04); color:var(--text-main); font-family:monospace;">"@searchString"</span>
            </div>
            <a asp-action="Index" class="btn-glass">
                <i class="ri-close-circle-line"></i> Xóa tìm kiếm
            </a>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="col-12 text-center py-5">
            <div class="glass-card p-5 mx-auto" style="max-width:500px;">
                <div class="mb-4" style="font-size:3.5rem; color:var(--text-muted);">
                    <i class="ri-search-eye-line"></i>
                </div>
                <h4 class="fw-bold mb-2">Không tìm thấy sự kiện nào</h4>
                <p class="text-muted-custom mb-4">Không có sự kiện nào khớp với từ khóa tìm kiếm hoặc chưa có sự kiện được đăng lên hệ thống.</p>
                <a asp-action="Index" class="btn-cta btn-cta-sm">
                    <span>Xem tất cả sự kiện</span>
                    <span class="btn-icon-circle"><i class="ri-refresh-line"></i></span>
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- ── Status Tabs ────────────────────────────────────────────────────── -->
        <ul class="status-tab-list mb-5" id="statusTabs" role="tablist">
            <li>
                <button class="status-tab-btn active" data-tab="ongoing" role="tab"
                        aria-selected="true" id="tab-ongoing">
                    <span class="status-tab-dot dot-ongoing"></span>
                    Đang diễn ra
                    <span class="status-tab-count">@ongoingEvents.Count</span>
                </button>
            </li>
            <li>
                <button class="status-tab-btn" data-tab="upcoming" role="tab"
                        aria-selected="false" id="tab-upcoming">
                    <span class="status-tab-dot dot-upcoming"></span>
                    Chưa diễn ra
                    <span class="status-tab-count">@upcomingEvents.Count</span>
                </button>
            </li>
            <li>
                <button class="status-tab-btn" data-tab="ended" role="tab"
                        aria-selected="false" id="tab-ended">
                    <span class="status-tab-dot dot-ended"></span>
                    Đã diễn ra
                    <span class="status-tab-count">@endedEvents.Count</span>
                </button>
            </li>
        </ul>

        <!-- ── Tab Panels ─────────────────────────────────────────────────────── -->

        <!-- Đang diễn ra -->
        <div class="status-tab-panel" id="panel-ongoing">
            @if (!ongoingEvents.Any())
            {
                <div class="status-tab-empty">
                    <i class="ri-live-line"></i>
                    <p>Hiện không có sự kiện nào đang diễn ra.</p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var ev in ongoingEvents)
                    {
                        @await Html.PartialAsync("_EventCard", ev)
                    }
                </div>
            }
        </div>

        <!-- Chưa diễn ra -->
        <div class="status-tab-panel d-none" id="panel-upcoming">
            @if (!upcomingEvents.Any())
            {
                <div class="status-tab-empty">
                    <i class="ri-calendar-schedule-line"></i>
                    <p>Hiện chưa có sự kiện sắp diễn ra.</p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var ev in upcomingEvents)
                    {
                        @await Html.PartialAsync("_EventCard", ev)
                    }
                </div>
            }
        </div>

        <!-- Đã diễn ra -->
        <div class="status-tab-panel d-none" id="panel-ended">
            @if (!endedEvents.Any())
            {
                <div class="status-tab-empty">
                    <i class="ri-history-line"></i>
                    <p>Chưa có sự kiện nào đã kết thúc.</p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var ev in endedEvents)
                    {
                        @await Html.PartialAsync("_EventCard", ev)
                    }
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        (function () {
            var tabs   = document.querySelectorAll('.status-tab-btn');
            var panels = document.querySelectorAll('.status-tab-panel');

            tabs.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var target = btn.dataset.tab;

                    // Update tab active state
                    tabs.forEach(function (t) {
                        t.classList.remove('active');
                        t.setAttribute('aria-selected', 'false');
                    });
                    btn.classList.add('active');
                    btn.setAttribute('aria-selected', 'true');

                    // Show/hide panels
                    panels.forEach(function (p) {
                        if (p.id === 'panel-' + target) {
                            p.classList.remove('d-none');
                        } else {
                            p.classList.add('d-none');
                        }
                    });
                });
            });
        })();
    </script>
}
