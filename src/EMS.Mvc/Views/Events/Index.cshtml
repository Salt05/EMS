@model List<EMS.Core.Entities.Event>
@{
    ViewData["Title"] = "Khám phá Sự kiện";
    var searchString = ViewData["SearchString"] as string;
}

@functions {
    string GetBadgeClass(string title, string description)
    {
        var text = (title + " " + description).ToLower();
        if (text.Contains("học thuật") || text.Contains("seminar") || text.Contains("workshop") || text.Contains("google"))
            return "event-badge-academic";
        if (text.Contains("nghệ thuật") || text.Contains("nhạc") || text.Contains("hội họa") || text.Contains("tranh") || text.Contains("mỹ thuật"))
            return "event-badge-art";
        if (text.Contains("thể thao") || text.Contains("bóng đá") || text.Contains("chạy") || text.Contains("run") || text.Contains("đại hội"))
            return "event-badge-sport";
        return "event-badge-default";
    }

    string GetBadgeName(string title, string description)
    {
        var text = (title + " " + description).ToLower();
        if (text.Contains("học thuật") || text.Contains("seminar") || text.Contains("workshop") || text.Contains("google"))
            return "Học thuật";
        if (text.Contains("nghệ thuật") || text.Contains("nhạc") || text.Contains("hội họa") || text.Contains("tranh") || text.Contains("mỹ thuật"))
            return "Nghệ thuật";
        if (text.Contains("thể thao") || text.Contains("bóng đá") || text.Contains("chạy") || text.Contains("run") || text.Contains("đại hội"))
            return "Thể thao";
        return "Sự kiện";
    }
}

<div class="container my-4">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-12">
            <span class="eyebrow-tag">Cổng Sinh Viên</span>
            <h1 class="heading-gradient heading-gradient-md mb-2">Khám phá các sự kiện</h1>
            <p class="subtitle-text">Tìm kiếm và đăng ký tham gia các hoạt động ngoại khóa, câu lạc bộ, học thuật.</p>
        </div>
    </div>

    <!-- Search Section — Glass Card -->
    <div class="glass-card-strong p-4 mb-5">
        <form method="get" asp-controller="Events" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-9">
                <div style="position:relative;">
                    <i class="ri-search-2-line" style="position:absolute; left:14px; top:50%; transform:translateY(-50%); color:var(--text-muted); font-size:1.1rem;"></i>
                    <input type="text" name="searchString"
                           class="form-glass-input"
                           style="padding-left:2.5rem;"
                           placeholder="Tìm kiếm theo tên sự kiện, nội dung hoặc địa điểm..."
                           value="@searchString" />
                </div>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn-cta w-100 justify-content-center">
                    <span>Tìm kiếm</span>
                    <span class="btn-icon-circle"><i class="ri-search-line"></i></span>
                </button>
            </div>
        </form>
    </div>

    <!-- Result Banner -->
    @if (!string.IsNullOrEmpty(searchString))
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div style="color:var(--text-secondary);">
                Tìm thấy <strong>@Model.Count</strong> kết quả cho từ khóa
                <span class="status-badge" style="background:rgba(0,0,0,0.04); color:var(--text-main); font-family:monospace;">"@searchString"</span>
            </div>
            <a asp-action="Index" class="btn-glass">
                <i class="ri-close-circle-line"></i> Xóa tìm kiếm
            </a>
        </div>
    }

    <!-- Event Cards Grid -->
    <div class="row g-4">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="glass-card p-5 mx-auto" style="max-width:500px;">
                    <div class="mb-4" style="font-size:3.5rem; color:var(--text-muted);">
                        <i class="ri-search-eye-line"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Không tìm thấy sự kiện nào</h4>
                    <p class="text-muted-custom mb-4">Không có sự kiện nào khớp với từ khóa tìm kiếm hoặc chưa có sự kiện được đăng lên hệ thống.</p>
                    <a asp-action="Index" class="btn-cta btn-cta-sm">
                        <span>Xem tất cả sự kiện</span>
                        <span class="btn-icon-circle"><i class="ri-refresh-line"></i></span>
                    </a>
                </div>
            </div>
        }
        else
        {
            @foreach (var ev in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="event-glass-card">
                        <!-- Double-bezel image -->
                        <div class="event-image-wrap">
                            <div class="event-image-shell">
                                <img src="@(string.IsNullOrEmpty(ev.ImageUrl) ? "https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=800&auto=format&fit=crop&q=60" : ev.ImageUrl)"
                                     alt="@ev.Title"
                                     onerror="this.onerror=null;this.src='https://placehold.co/800x400/6366f1/ffffff?text=EMS+Event';">
                                <span class="event-badge @GetBadgeClass(ev.Title, ev.Description)">@GetBadgeName(ev.Title, ev.Description)</span>
                            </div>
                        </div>

                        <div class="event-card-body">
                            <h5 class="event-card-title">@ev.Title</h5>
                            <div class="event-card-meta">
                                <div><i class="ri-time-line"></i> @ev.StartTime.ToString("dd/MM/yyyy HH:mm") - @ev.EndTime.ToString("HH:mm")</div>
                                <div><i class="ri-map-pin-2-line"></i> @ev.Location</div>
                            </div>
                            @{
                                var displayDesc = ev.Description;
                                if (displayDesc.Length > 120)
                                {
                                    displayDesc = displayDesc.Substring(0, 117) + "...";
                                }
                            }
                            <p class="event-card-desc">@displayDesc</p>
                        </div>

                        <div class="event-card-footer">
                            <span><i class="ri-group-line me-1"></i> Sức chứa: @ev.Capacity</span>
                            <a asp-controller="Events" asp-action="Detail" asp-route-id="@ev.Id"
                               class="btn-cta btn-cta-sm">
                                <span>Chi tiết</span>
                                <span class="btn-icon-circle"><i class="ri-arrow-right-up-line"></i></span>
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
