@model List<EMS.Core.Entities.Event>
@{
    ViewData["Title"] = "Khám phá Sự kiện";
    var searchString = ViewData["SearchString"] as string;
}



<div class="container my-4">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-12">
            <span class="feature-tag">Cổng sinh viên</span>
            <h1 class="fw-bold mb-2">Khám phá các sự kiện</h1>
            <p class="text-muted">Tìm kiếm và đăng ký tham gia các hoạt động ngoại khóa, câu lạc bộ, học thuật.</p>
        </div>
    </div>

    <!-- Search Section -->
    <div class="premium-card p-4 mb-5">
        <form method="get" asp-controller="Events" asp-action="Index" class="row g-3">
            <div class="col-md-9">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted" style="border-radius: 12px 0 0 12px; border: 1px solid #d1d5db; height: 100%;">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="searchString" class="form-control premium-form-control border-start-0" 
                           style="border-radius: 0 12px 12px 0; padding-left: 0;"
                           placeholder="Tìm kiếm theo tên sự kiện, nội dung hoặc địa điểm..." 
                           value="@searchString" />
                </div>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-premium w-100 h-100 py-2.5">
                    <i class="bi bi-funnel me-2"></i>Tìm kiếm
                </button>
            </div>
        </form>
    </div>

    <!-- Result Banner -->
    @if (!string.IsNullOrEmpty(searchString))
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="text-secondary">
                Tìm thấy <strong>@Model.Count</strong> kết quả cho từ khóa <span class="badge bg-light text-dark font-monospace">"@searchString"</span>
            </div>
            <a asp-action="Index" class="text-decoration-none text-primary small"><i class="bi bi-x-circle me-1"></i>Xóa tìm kiếm</a>
        </div>
    }

    <!-- Event Cards Grid -->
    <div class="row g-4">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="premium-card p-5 max-w-600 mx-auto">
                    <div class="mb-4 text-muted" style="font-size: 4rem;">
                        <i class="bi bi-search-heart"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Không tìm thấy sự kiện nào</h4>
                    <p class="text-muted mb-4">Không có sự kiện nào khớp với từ khóa tìm kiếm của bạn hoặc chưa có sự kiện được đăng lên hệ thống.</p>
                    <a asp-action="Index" class="btn btn-premium btn-sm">Xem tất cả sự kiện</a>
                </div>
            </div>
        }
        else
        {
            @foreach (var ev in Model)
            {
                <div class="col-lg-4 col-md-6">
                    @await Component.InvokeAsync("EventCard", new { eventItem = ev })
                </div>
            }
        }
    </div>
</div>
