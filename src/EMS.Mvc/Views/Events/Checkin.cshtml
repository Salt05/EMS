@model EMS.Mvc.ViewModels.CheckInViewModel
@{
    ViewData["Title"] = "Check-in sự kiện";
    var isOngoing = Model.Event.StartTime <= DateTime.UtcNow && DateTime.UtcNow <= Model.Event.EndTime;
    var isSuccess = Model.CheckInSuccess == true;
    var isError   = Model.CheckInSuccess == false;
}

<style>
    /* ── Page wrapper ── */
    .checkin-page {
        min-height: 80vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    /* ── Card ── */
    .checkin-card {
        background: var(--color-bg-card, #fff);
        border-radius: 24px;
        box-shadow: 0 8px 40px rgba(0,0,0,.12);
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 520px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .checkin-card::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(99,102,241,.08) 0%, rgba(168,85,247,.06) 100%);
        pointer-events: none;
    }

    /* ── Event meta ── */
    .event-badge {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .04em;
        text-transform: uppercase;
        padding: .3rem .9rem;
        border-radius: 99px;
        margin-bottom: 1rem;
    }
    .event-badge.ongoing { background: #dcfce7; color: #16a34a; }
    .event-badge.upcoming { background: #dbeafe; color: #1d4ed8; }
    .event-badge.past    { background: #f1f5f9; color: #64748b; }

    .checkin-event-title {
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--color-text-primary, #1e293b);
        margin-bottom: .35rem;
        line-height: 1.3;
    }

    .checkin-event-meta {
        font-size: .85rem;
        color: var(--color-text-secondary, #64748b);
        margin-bottom: 2rem;
    }

    .checkin-event-meta span { margin: 0 .4rem; }

    /* ── OTP input group ── */
    .otp-label {
        font-size: .9rem;
        font-weight: 600;
        color: var(--color-text-primary, #1e293b);
        margin-bottom: .75rem;
        display: block;
    }

    .otp-wrapper {
        display: flex;
        gap: .5rem;
        justify-content: center;
        margin-bottom: 1.5rem;
    }

    .otp-input {
        width: 48px;
        height: 58px;
        font-size: 1.6rem;
        font-weight: 700;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: .1em;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: var(--color-bg-input, #f8fafc);
        color: var(--color-text-primary, #1e293b);
        transition: border-color .2s, box-shadow .2s;
        caret-color: #6366f1;
        outline: none;
    }

    .otp-input:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99,102,241,.2);
        background: #fff;
    }

    .otp-input.filled { border-color: #6366f1; }

    /* Hidden real input */
    .hidden-input {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
        pointer-events: none;
    }

    /* ── Buttons ── */
    .btn-checkin {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .85rem 2.5rem;
        font-size: 1rem;
        font-weight: 700;
        border-radius: 12px;
        border: none;
        cursor: pointer;
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
        color: #fff;
        box-shadow: 0 4px 20px rgba(99,102,241,.35);
        transition: transform .15s, box-shadow .15s, opacity .15s;
        width: 100%;
        justify-content: center;
        margin-bottom: .75rem;
    }

    .btn-checkin:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(99,102,241,.45);
    }

    .btn-checkin:active:not(:disabled) { transform: translateY(0); }
    .btn-checkin:disabled { opacity: .6; cursor: not-allowed; }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .7rem 2rem;
        font-size: .9rem;
        font-weight: 600;
        border-radius: 12px;
        border: 2px solid #e2e8f0;
        background: transparent;
        color: var(--color-text-secondary, #64748b);
        text-decoration: none;
        transition: border-color .2s, color .2s;
        width: 100%;
        justify-content: center;
    }

    .btn-back:hover { border-color: #6366f1; color: #6366f1; }

    /* ── Result banners ── */
    .result-banner {
        border-radius: 14px;
        padding: 1.2rem 1.4rem;
        margin-bottom: 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .5rem;
        animation: slideDown .3s ease;
    }

    @@keyframes slideDown {
        from { opacity:0; transform: translateY(-12px); }
        to   { opacity:1; transform: translateY(0); }
    }

    .result-banner.success { background: #dcfce7; }
    .result-banner.error   { background: #fee2e2; }

    .result-icon {
        font-size: 2.4rem;
        line-height: 1;
    }

    .result-banner.success .result-title { color: #15803d; font-weight: 700; font-size: 1.05rem; }
    .result-banner.error   .result-title { color: #b91c1c; font-weight: 700; font-size: 1.05rem; }

    .result-banner.success .result-msg { color: #166534; font-size: .9rem; }
    .result-banner.error   .result-msg { color: #991b1b; font-size: .9rem; }

    /* ── Divider ── */
    .checkin-divider {
        height: 1px;
        background: #e2e8f0;
        margin: 1.5rem 0;
    }

    /* ── Dark mode ── */
    [data-theme="dark"] .checkin-card {
        background: #1e1e2e;
        box-shadow: 0 8px 40px rgba(0,0,0,.4);
    }
    [data-theme="dark"] .otp-input {
        background: #2d2d44;
        border-color: #3d3d5c;
        color: #e2e8f0;
    }
    [data-theme="dark"] .otp-input:focus {
        background: #35355a;
    }
    [data-theme="dark"] .btn-back {
        border-color: #3d3d5c;
        color: #a1a1ca;
    }
    [data-theme="dark"] .btn-back:hover { border-color: #8b5cf6; color: #a78bfa; }
    [data-theme="dark"] .checkin-event-title { color: #e2e8f0; }
    [data-theme="dark"] .checkin-event-meta  { color: #a1a1ca; }
    [data-theme="dark"] .otp-label { color: #c4c4e0; }
    [data-theme="dark"] .checkin-divider { background: #3d3d5c; }
    [data-theme="dark"] .result-banner.success { background: rgba(22,163,74,.18); }
    [data-theme="dark"] .result-banner.error   { background: rgba(185,28,28,.18); }
    [data-theme="dark"] .result-banner.success .result-title { color: #4ade80; }
    [data-theme="dark"] .result-banner.success .result-msg   { color: #86efac; }
    [data-theme="dark"] .result-banner.error   .result-title { color: #f87171; }
    [data-theme="dark"] .result-banner.error   .result-msg   { color: #fca5a5; }

    @@media (max-width: 480px) {
        .otp-input { width: 40px; height: 50px; font-size: 1.3rem; border-radius: 9px; }
        .checkin-card { padding: 2rem 1.25rem; }
    }
</style>

<div class="checkin-page">
    <div class="checkin-card">

        {{-- Event badge --}}
        @{
            string badgeClass = isOngoing ? "ongoing" : (DateTime.UtcNow < Model.Event.StartTime ? "upcoming" : "past");
            string badgeText  = isOngoing ? "⏱ Đang diễn ra" : (DateTime.UtcNow < Model.Event.StartTime ? "📅 Sắp diễn ra" : "✅ Đã kết thúc");
        }
        <span class="event-badge @badgeClass">@badgeText</span>

        <div class="checkin-event-title">@Model.Event.Title</div>
        <div class="checkin-event-meta">
            <span>🕐 @Model.Event.StartTime.ToLocalTime().ToString("HH:mm") – @Model.Event.EndTime.ToLocalTime().ToString("HH:mm")</span>
            <span>📍 @Model.Event.Location</span>
        </div>

        @* ── Result banners ── *@
        @if (isSuccess)
        {
            <div class="result-banner success">
                <div class="result-icon">🎉</div>
                <div class="result-title">Check-in thành công!</div>
                <div class="result-msg">@Model.CheckInMessage</div>
            </div>
            <a asp-controller="Events" asp-action="Detail" asp-route-id="@Model.Event.Id" class="btn-back">
                ← Quay lại trang sự kiện
            </a>
        }
        else
        {
            @if (isError)
            {
                <div class="result-banner error">
                    <div class="result-icon">❌</div>
                    <div class="result-title">Check-in thất bại</div>
                    <div class="result-msg">@Model.CheckInMessage</div>
                </div>
            }

            @* ── Check-in form ── *@
            <form method="post" asp-action="CheckIn" asp-route-id="@Model.Event.Id" id="checkinForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="realCode" name="checkInCode" maxlength="6" />

                <label class="otp-label" for="otp-0">Nhập mã check-in (6 ký tự)</label>
                <div class="otp-wrapper" id="otpWrapper">
                    @for (int i = 0; i < 6; i++)
                    {
                        <input class="otp-input" id="otp-@i" type="text" maxlength="1"
                               inputmode="text" autocomplete="off" spellcheck="false"
                               aria-label="Ký tự @(i + 1) của mã check-in" />
                    }
                </div>

                <button type="submit" class="btn-checkin" id="submitBtn" disabled>
                    <span>✔</span> Xác nhận Check-in
                </button>
            </form>

            <div class="checkin-divider"></div>
            <a asp-controller="Events" asp-action="Detail" asp-route-id="@Model.Event.Id" class="btn-back">
                ← Quay lại trang sự kiện
            </a>
        }
    </div>
</div>

<script>
(function () {
    const inputs  = Array.from(document.querySelectorAll('.otp-input'));
    const hidden  = document.getElementById('realCode');
    const submit  = document.getElementById('submitBtn');

    if (!inputs.length) return;

    function syncCode() {
        const code = inputs.map(i => i.value.toUpperCase()).join('');
        hidden.value = code;
        submit.disabled = code.length < 6;
        inputs.forEach((inp, idx) => {
            inp.value = inp.value.toUpperCase();
            inp.classList.toggle('filled', !!inp.value);
        });
    }

    inputs.forEach((input, idx) => {
        input.addEventListener('input', (e) => {
            const val = e.data || input.value;
            if (!val) { syncCode(); return; }

            // Handle paste
            if (val.length > 1) {
                const chars = val.toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 6 - idx);
                chars.split('').forEach((c, i) => {
                    if (inputs[idx + i]) inputs[idx + i].value = c;
                });
                const nextIdx = Math.min(idx + chars.length, 5);
                inputs[nextIdx].focus();
                syncCode();
                return;
            }

            input.value = val.toUpperCase();
            syncCode();
            if (val && idx < inputs.length - 1) inputs[idx + 1].focus();
        });

        input.addEventListener('keydown', (e) => {
            if (e.key === 'Backspace') {
                if (!input.value && idx > 0) {
                    inputs[idx - 1].value = '';
                    inputs[idx - 1].focus();
                } else {
                    input.value = '';
                }
                syncCode();
                e.preventDefault();
            }
            if (e.key === 'ArrowLeft'  && idx > 0) { inputs[idx - 1].focus(); e.preventDefault(); }
            if (e.key === 'ArrowRight' && idx < inputs.length - 1) { inputs[idx + 1].focus(); e.preventDefault(); }
        });

        input.addEventListener('paste', (e) => {
            e.preventDefault();
            const pasted = (e.clipboardData || window.clipboardData)
                .getData('text').toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 6);
            pasted.split('').forEach((c, i) => { if (inputs[i]) inputs[i].value = c; });
            inputs[Math.min(pasted.length, 5)].focus();
            syncCode();
        });
    });

    // Pre-fill from prior attempt if model has code
    const prevCode = '@Model.CheckInCode'.toUpperCase();
    if (prevCode.length === 6) {
        prevCode.split('').forEach((c, i) => { inputs[i].value = c; });
        syncCode();
    }

    // Auto focus first input
    inputs[0].focus();
})();
</script>
