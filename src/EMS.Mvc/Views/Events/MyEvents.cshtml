@model List<EMS.Mvc.ViewModels.MyEventViewModel>
@{
    ViewData["Title"] = "Sự kiện của tôi";
}



<div class="container my-5">
    <div class="row mb-5">
        <div class="col-md-8 mx-auto text-center">
            <span class="eyebrow-tag">Vé của bạn</span>
            <h1 class="heading-gradient heading-gradient-md mb-2">Sự kiện của tôi</h1>
            <p class="subtitle-text">
                Quản lý các sự kiện bạn đã đăng ký tham gia, theo dõi trạng thái vé và thực hiện hủy đăng ký khi cần thiết.
            </p>
        </div>
    </div>

    <!-- Error Alert -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-glass alert-glass-danger mb-4" role="alert">
            <i class="ri-error-warning-line" style="font-size:1.15rem;"></i>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    <div class="row">
        <div class="col-12">
            <!-- Glass Pill Tabs -->
            <ul class="pills-glass justify-content-center" id="myEventsTabs" role="tablist">
                <li role="presentation">
                    <button class="pill-glass active" id="active-tab" data-bs-toggle="pill" data-bs-target="#active-events" type="button" role="tab" aria-controls="active-events" aria-selected="true">
                        <i class="ri-ticket-2-line"></i> Vé hoạt động (@Model.Count(r => r.Registration.Status == EMS.Core.Entities.Enums.RegistrationStatus.Approved || r.Registration.Status == EMS.Core.Entities.Enums.RegistrationStatus.Pending))
                    </button>
                </li>
                <li role="presentation">
                    <button class="pill-glass" id="history-tab" data-bs-toggle="pill" data-bs-target="#history-events" type="button" role="tab" aria-controls="history-events" aria-selected="false">
                        <i class="ri-history-line"></i> Lịch sử & Đã hủy (@Model.Count(r => r.Registration.Status == EMS.Core.Entities.Enums.RegistrationStatus.Cancelled || r.Registration.Status == EMS.Core.Entities.Enums.RegistrationStatus.Rejected))
                    </button>
                </li>
            </ul>

            <!-- Tab Content -->
            <div class="tab-content" id="myEventsTabsContent">
                <!-- Active Events -->
                <div class="tab-pane fade show active" id="active-events" role="tabpanel" aria-labelledby="active-tab">
                    @{
                        var activeRegs = Model.Where(r => r.Registration.Status == EMS.Core.Entities.Enums.RegistrationStatus.Approved || r.Registration.Status == EMS.Core.Entities.Enums.RegistrationStatus.Pending).ToList();
                    }

                    @if (!activeRegs.Any())
                    {
                        <div class="glass-card p-5 text-center my-4">
                            <div class="mb-3" style="font-size:3rem; color:var(--text-muted);">
                                <i class="ri-coupon-2-line"></i>
                            </div>
                            <h4 class="fw-bold text-dark mb-2">Chưa có vé hoạt động nào</h4>
                            <p class="text-muted-custom mb-4">Bạn chưa đăng ký tham gia sự kiện nào hoặc các đăng ký đều đã bị hủy.</p>
                            <a asp-action="Index" class="btn-cta">
                                <span>Khám phá sự kiện ngay</span>
                                <span class="btn-icon-circle"><i class="ri-search-line"></i></span>
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="row g-4">
                            @foreach (var item in activeRegs)
                            {
                                <div class="col-lg-6">
                                    <div class="ticket-glass-card d-flex flex-row overflow-hidden h-100">
                                        <!-- Double-bezel thumbnail -->
                                        <div class="ticket-thumb-wrap">
                                            <div class="ticket-thumb-inner">
                                                <img src="@(string.IsNullOrEmpty(item.Event.ImageUrl) ? "https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=600&auto=format&fit=crop&q=60" : item.Event.ImageUrl)" 
                                                     onerror="this.onerror=null;this.src='https://placehold.co/600x400/6366f1/ffffff?text=EMS';"
                                                     alt="@item.Event.Title">
                                            </div>
                                        </div>
                                        <div class="p-4 d-flex flex-column justify-content-between flex-grow-1">
                                            <div>
                                                <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                                                    <registration-status-badge status="@item.Registration.Status"></registration-status-badge>
                                                    <small class="text-muted-custom"><i class="ri-calendar-line me-1"></i>@item.Registration.CreatedAt.ToString("dd/MM/yyyy")</small>
                                                </div>
                                                <h5 class="fw-bold mb-2">
                                                    <a asp-action="Detail" asp-route-id="@item.Event.Id" class="link-primary-hover">
                                                        @item.Event.Title
                                                    </a>
                                                </h5>
                                                <div class="text-muted-custom small mb-3">
                                                    <div class="mb-1"><i class="ri-time-line me-1 text-primary-custom"></i> @item.Event.StartTime.ToString("dd/MM/yyyy HH:mm")</div>
                                                    <div><i class="ri-map-pin-2-line me-1 text-success-custom"></i> @item.Event.Location</div>
                                                </div>
                                            </div>
                                            <div class="d-flex gap-2 mt-2">
                                                <a asp-action="Detail" asp-route-id="@item.Event.Id" class="btn-glass flex-grow-1">
                                                    Chi tiết
                                                </a>
                                                <form asp-action="Cancel" method="post" class="flex-grow-1">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="eventId" value="@item.Event.Id" />
                                                    <input type="hidden" name="redirectTo" value="MyEvents" />
                                                    <button type="submit" class="btn-danger-outline w-100" onclick="return confirm('Bạn có chắc chắn muốn hủy đăng ký vé cho sự kiện này?')">
                                                        Hủy vé
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- History Events -->
                <div class="tab-pane fade" id="history-events" role="tabpanel" aria-labelledby="history-tab">
                    @{
                        var historyRegs = Model.Where(r => r.Registration.Status == EMS.Core.Entities.Enums.RegistrationStatus.Cancelled || r.Registration.Status == EMS.Core.Entities.Enums.RegistrationStatus.Rejected).ToList();
                    }

                    @if (!historyRegs.Any())
                    {
                        <div class="glass-card p-5 text-center my-4">
                            <div class="mb-3" style="font-size:3rem; color:var(--text-muted);">
                                <i class="ri-inbox-line"></i>
                            </div>
                            <h4 class="fw-bold text-dark mb-2">Lịch sử trống</h4>
                            <p class="text-muted-custom mb-0">Bạn chưa có sự kiện nào trong danh sách hủy hoặc từ chối.</p>
                        </div>
                    }
                    else
                    {
                        <div class="row g-4">
                            @foreach (var item in historyRegs)
                            {
                                <div class="col-lg-6">
                                    <div class="ticket-glass-card d-flex flex-row overflow-hidden h-100 opacity-75">
                                        <!-- Double-bezel thumbnail -->
                                        <div class="ticket-thumb-wrap">
                                            <div class="ticket-thumb-inner">
                                                <img src="@(string.IsNullOrEmpty(item.Event.ImageUrl) ? "https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=600&auto=format&fit=crop&q=60" : item.Event.ImageUrl)" 
                                                     onerror="this.onerror=null;this.src='https://placehold.co/600x400/6b7280/ffffff?text=EMS';"
                                                     alt="@item.Event.Title">
                                            </div>
                                        </div>
                                        <div class="p-4 d-flex flex-column justify-content-between flex-grow-1">
                                            <div>
                                                <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                                                    <registration-status-badge status="@item.Registration.Status"></registration-status-badge>
                                                    <small class="text-muted-custom">Cập nhật: @item.Registration.UpdatedAt.ToString("dd/MM/yyyy")</small>
                                                </div>
                                                <h5 class="fw-bold mb-2">
                                                    <a asp-action="Detail" asp-route-id="@item.Event.Id" class="link-primary-hover">
                                                        @item.Event.Title
                                                    </a>
                                                </h5>
                                                <div class="text-muted-custom small mb-2">
                                                    <div><i class="ri-time-line me-1"></i> @item.Event.StartTime.ToString("dd/MM/yyyy HH:mm")</div>
                                                </div>
                                            </div>
                                            <div class="d-flex gap-2 mt-2">
                                                <a asp-action="Detail" asp-route-id="@item.Event.Id" class="btn-glass w-100">
                                                    Xem thông tin sự kiện
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Tab switching activation (Bootstrap 5 JS tab behavior check)
    document.addEventListener("DOMContentLoaded", function() {
        var triggerTabList = [].slice.call(document.querySelectorAll('#myEventsTabs button'));
        triggerTabList.forEach(function(triggerEl) {
            var tabTrigger = new bootstrap.Tab(triggerEl);
            triggerEl.addEventListener('click', function(event) {
                event.preventDefault();
                // Remove active class from all buttons and add to this one
                triggerTabList.forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');
                tabTrigger.show();
            });
        });
    });
</script>
}
