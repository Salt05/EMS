@model EMS.Core.Entities.Event
@{
    ViewData["Title"] = Model.Title;
    string? userSession = Context.Request.Cookies["user_session"];
    string? displayName = null;
    if (!string.IsNullOrEmpty(userSession))
    {
        displayName = userSession.Split('|')[0];
    }
}

@functions {
    string GetEventBadgeClass(string title, string description)
    {
        var text = (title + " " + description).ToLower();
        if (text.Contains("học thuật") || text.Contains("seminar") || text.Contains("workshop") || text.Contains("google"))
            return "bg-primary text-white";
        if (text.Contains("nghệ thuật") || text.Contains("nhạc") || text.Contains("hội họa") || text.Contains("tranh") || text.Contains("mỹ thuật"))
            return "bg-success text-white";
        if (text.Contains("thể thao") || text.Contains("bóng đá") || text.Contains("chạy") || text.Contains("run") || text.Contains("đại hội"))
            return "bg-warning text-dark";
        return "bg-info text-white";
    }

    string GetEventBadgeName(string title, string description)
    {
        var text = (title + " " + description).ToLower();
        if (text.Contains("học thuật") || text.Contains("seminar") || text.Contains("workshop") || text.Contains("google"))
            return "Học thuật";
        if (text.Contains("nghệ thuật") || text.Contains("nhạc") || text.Contains("hội họa") || text.Contains("tranh") || text.Contains("mỹ thuật"))
            return "Nghệ thuật";
        if (text.Contains("thể thao") || text.Contains("bóng đá") || text.Contains("chạy") || text.Contains("run") || text.Contains("đại hội"))
            return "Thể thao";
        return "Sự kiện";
    }
}

<div class="container my-5">
    <!-- Back Navigation -->
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-sm btn-light border rounded-pill px-3 py-2 text-decoration-none text-secondary">
            <i class="bi bi-arrow-left-short me-1"></i>Quay lại danh sách
        </a>
    </div>

    <!-- Error Message Alert -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-exclamation-octagon-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Left: Image & Info -->
        <div class="col-lg-8">
            <div class="premium-card overflow-hidden mb-4">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=1200&auto=format&fit=crop&q=60" : Model.ImageUrl)" 
                     class="img-fluid w-100" 
                     style="height: 380px; object-fit: cover;" 
                     onerror="this.onerror=null;this.src='https://placehold.co/1200x400/6366f1/ffffff?text=EMS+Event';"
                     alt="@Model.Title">
                
                <div class="p-4 p-md-5">
                    <span class="badge @GetEventBadgeClass(Model.Title, Model.Description) px-3 py-2 mb-3">
                        @GetEventBadgeName(Model.Title, Model.Description)
                    </span>
                    <h1 class="fw-bold text-dark mb-4">@Model.Title</h1>

                    <h5 class="fw-bold mb-3"><i class="bi bi-file-text me-2 text-primary"></i>Giới thiệu sự kiện</h5>
                    <div class="text-secondary leading-relaxed" style="white-space: pre-line;">
                        @Model.Description
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Detail Metadata & CTA -->
        <div class="col-lg-4">
            <div class="premium-card p-4 position-sticky" style="top: 100px;">
                <h4 class="fw-bold text-dark mb-4 border-bottom pb-2">Thông tin chi tiết</h4>
                
                <div class="d-flex align-items-start mb-3">
                    <div class="text-primary me-3 fs-4 mt-0.5">
                        <i class="bi bi-clock"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark small text-uppercase">Thời gian</div>
                        <div class="text-secondary small">
                            <strong>Bắt đầu:</strong><br/> @Model.StartTime.ToString("dd/MM/yyyy HH:mm")<br/>
                            <strong>Kết thúc:</strong><br/> @Model.EndTime.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-start mb-3">
                    <div class="text-success me-3 fs-4 mt-0.5">
                        <i class="bi bi-geo-alt"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark small text-uppercase">Địa điểm</div>
                        <div class="text-secondary small">@Model.Location</div>
                    </div>
                </div>

                <div class="d-flex align-items-start mb-3">
                    <div class="text-warning me-3 fs-4 mt-0.5">
                        <i class="bi bi-people"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark small text-uppercase">Sức chứa tối đa</div>
                        <div class="text-secondary small">@Model.Capacity người tham gia</div>
                    </div>
                </div>

                <div class="d-flex align-items-start mb-4">
                    <div class="text-info me-3 fs-4 mt-0.5">
                        <i class="bi bi-ticket-perforated"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark small text-uppercase">Lệ phí</div>
                        <div class="text-success small fw-bold">MIỄN PHÍ</div>
                    </div>
                </div>

                <div class="border-top pt-4">
                    @if (displayName != null)
                    {
                        @if (ViewBag.RegistrationStatus == EMS.Core.Entities.Enums.RegistrationStatus.Approved)
                        {
                            <div class="alert alert-success py-2.5 text-center mb-3 small rounded-3" role="alert">
                                <i class="bi bi-check-circle-fill me-1"></i> Bạn đã đăng ký tham gia sự kiện này.
                            </div>
                            <form asp-action="Cancel" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="eventId" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-danger w-100 py-2.5 rounded-3">
                                    <i class="bi bi-x-circle me-2"></i>Hủy đăng ký vé
                                </button>
                            </form>
                        }
                        else if (ViewBag.RegistrationStatus == EMS.Core.Entities.Enums.RegistrationStatus.Pending)
                        {
                            <div class="alert alert-warning py-2.5 text-center mb-3 small rounded-3" role="alert">
                                <i class="bi bi-hourglass-split me-1"></i> Đăng ký đang chờ phê duyệt.
                            </div>
                            <form asp-action="Cancel" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="eventId" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-danger w-100 py-2.5 rounded-3">
                                    <i class="bi bi-x-circle me-2"></i>Hủy yêu cầu đăng ký
                                </button>
                            </form>
                        }
                        else if (ViewBag.RegistrationStatus == EMS.Core.Entities.Enums.RegistrationStatus.Rejected)
                        {
                            <div class="alert alert-danger py-2.5 text-center mb-3 small rounded-3" role="alert">
                                <i class="bi bi-x-octagon-fill me-1"></i> Đăng ký của bạn đã bị từ chối.
                            </div>
                            <form asp-action="Register" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="eventId" value="@Model.Id" />
                                <button type="submit" class="btn btn-premium w-100 py-3 rounded-3">
                                    <i class="bi bi-lightning-charge me-2"></i>Đăng ký lại
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Register" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="eventId" value="@Model.Id" />
                                <button type="submit" class="btn btn-premium w-100 py-3 rounded-3">
                                    <i class="bi bi-lightning-charge me-2"></i>Đăng ký vé miễn phí
                                </button>
                            </form>
                        }
                    }
                    else
                    {
                        <div class="alert alert-warning py-3 text-center mb-3 small" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i> Bạn cần đăng nhập để đăng ký.
                        </div>
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-premium w-100 py-2.5">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập ngay
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
