@model EMS.Core.Entities.Event
@{
    ViewData["Title"] = Model.Title;
    string? userSession = Context.Request.Cookies["user_session"];
    string? displayName = null;
    if (!string.IsNullOrEmpty(userSession))
    {
        displayName = userSession.Split('|')[0];
    }
}

@functions {
    string GetEventStatusClass(EMS.Core.Entities.Event ev)
    {
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Cancelled)
            return "status-badge-cancelled";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Rejected)
            return "status-badge-rejected";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Pending)
            return "status-badge-pending";

        var now = DateTime.UtcNow;
        if (now < ev.StartTime)
            return "status-badge-upcoming";
        if (now >= ev.StartTime && now <= ev.EndTime)
            return "status-badge-ongoing";
        return "status-badge-ended";
    }

    string GetEventStatusName(EMS.Core.Entities.Event ev)
    {
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Cancelled)
            return "Đã hủy";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Rejected)
            return "Đã từ chối";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Pending)
            return "Chờ phê duyệt";

        var now = DateTime.UtcNow;
        if (now < ev.StartTime)
            return "Chưa diễn ra";
        if (now >= ev.StartTime && now <= ev.EndTime)
            return "Đang diễn ra";
        return "Đã kết thúc";
    }
}

<div class="container my-5">
    <!-- Back Navigation -->
    <div class="mb-4">
        <a asp-action="Index" class="btn-glass">
            <i class="ri-arrow-left-s-line"></i> Quay lại danh sách
        </a>
    </div>

    <!-- Error Message Alert -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-glass alert-glass-danger mb-4" role="alert">
            <i class="ri-error-warning-line" style="font-size:1.15rem;"></i>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    <div class="row g-4">
        <!-- Left: Image & Content -->
        <div class="col-lg-8">
            <div class="glass-card overflow-hidden mb-4">
                <!-- Double-bezel image -->
                <div class="detail-image-wrap">
                    <div class="detail-image-shell">
                        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=1200&auto=format&fit=crop&q=60" : Model.ImageUrl)"
                             alt="@Model.Title"
                             onerror="this.onerror=null;this.src='https://placehold.co/1200x400/6366f1/ffffff?text=EMS+Event';">
                    </div>
                </div>

                <div class="p-4 p-md-5">
                    <span class="event-badge @GetEventStatusClass(Model)" style="position:static; display:inline-block; margin-bottom:1rem;">
                        @GetEventStatusName(Model)
                    </span>
                    <h1 class="heading-gradient heading-gradient-md mb-4">@Model.Title</h1>

                    <span class="eyebrow-tag" style="margin-bottom:0.75rem;">Giới thiệu sự kiện</span>
                    <div style="color:var(--text-secondary); line-height:1.8; white-space:pre-line;">
                        @Model.Description
                    </div>
                </div>
            </div>

            <!-- Agenda Timeline View -->
            <partial name="_AgendaTimeline" model="Model" />
        </div>

        <!-- Right: Detail Metadata & CTA -->
        <div class="col-lg-4">
            <div class="glass-card-strong p-4 position-sticky" style="top:100px;">
                <h4 class="fw-bold mb-4 pb-2" style="border-bottom:1px solid var(--border-subtle);">Thông tin chi tiết</h4>

                <!-- Time -->
                <div class="detail-meta-row">
                    <div class="detail-meta-icon icon-primary">
                        <i class="ri-time-line"></i>
                    </div>
                    <div>
                        <div class="form-glass-label" style="margin-bottom:0.25rem;">Thời gian</div>
                        <div style="color:var(--text-secondary); font-size:0.88rem;">
                            <strong>Bắt đầu:</strong><br/> @Model.StartTime.ToString("dd/MM/yyyy HH:mm")<br/>
                            <strong>Kết thúc:</strong><br/> @Model.EndTime.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>
                </div>

                <!-- Location -->
                <div class="detail-meta-row">
                    <div class="detail-meta-icon icon-success">
                        <i class="ri-map-pin-2-line"></i>
                    </div>
                    <div>
                        <div class="form-glass-label" style="margin-bottom:0.25rem;">Địa điểm</div>
                        <div style="color:var(--text-secondary); font-size:0.88rem;">@Model.Location</div>
                    </div>
                </div>

                <!-- Capacity -->
                <div class="detail-meta-row">
                    <div class="detail-meta-icon icon-warning">
                        <i class="ri-group-line"></i>
                    </div>
                    <div>
                        <div class="form-glass-label" style="margin-bottom:0.25rem;">Sức chứa tối đa</div>
                        <div style="color:var(--text-secondary); font-size:0.88rem;">@Model.Capacity người tham gia</div>
                    </div>
                </div>

                <!-- Fee -->
                <div class="detail-meta-row" style="margin-bottom:1.5rem;">
                    <div class="detail-meta-icon icon-info">
                        <i class="ri-ticket-line"></i>
                    </div>
                    <div>
                        <div class="form-glass-label" style="margin-bottom:0.25rem;">Lệ phí</div>
                        @if (Model.IsFree)
                        {
                            <div style="color:var(--success); font-weight:700; font-size:0.88rem;">MIỄN PHÍ</div>
                        }
                        else
                        {
                            <div style="color:var(--danger); font-weight:700; font-size:0.88rem;">@Model.Price.ToString("N0") VNĐ</div>
                        }
                    </div>
                </div>

                <div class="mb-4">
                    <a asp-action="DownloadIcs" asp-route-id="@Model.Id" class="btn-glass w-100 justify-content-center">
                        <i class="ri-calendar-event-line me-1"></i> Tải file lịch (.ics)
                    </a>
                </div>

                <div style="border-top:1px solid var(--border-subtle); padding-top:1.25rem;">
                    @if (displayName != null)
                    {
                        @if (ViewBag.RegistrationStatus == EMS.Core.Entities.Enums.RegistrationStatus.Approved)
                        {
                            <div class="alert-glass alert-glass-success mb-3" style="justify-content:center;">
                                <i class="ri-checkbox-circle-line"></i>
                                <span style="font-size:0.85rem;">Bạn đã đăng ký tham gia sự kiện này.</span>
                            </div>

                            @if (ViewBag.RegistrationCheckedIn == true)
                            {
                                <div class="alert-glass alert-glass-success mb-3" style="justify-content:center; background: rgba(16, 185, 129, 0.15); border-color: rgba(16, 185, 129, 0.3);">
                                    <i class="ri-checkbox-circle-fill" style="color:var(--success);"></i>
                                    <span style="font-size:0.85rem; color:var(--success); font-weight:600;">Bạn đã check-in thành công.</span>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-success py-2.5 text-center mb-3 small rounded-3" role="alert">
                                    <i class="bi bi-check-circle-fill me-1"></i> Bạn đã đăng ký tham gia sự kiện này.
                                </div>

                                <!-- ═══════ CHECK-IN SECTION ═══════ -->
                                <div class="checkin-section mb-3">
                                    <div class="checkin-tabs flex mb-3 bg-canvas p-1 rounded-3 border">
                                        <button type="button" class="checkin-tab btn btn-sm w-50 active" data-tab="tab-code">
                                            <i class="bi bi-key me-1"></i>Nhập mã
                                        </button>
                                        <button type="button" class="checkin-tab btn btn-sm w-50" data-tab="tab-qr">
                                            <i class="bi bi-qr-code me-1"></i>Mã QR
                                        </button>
                                    </div>

                                    <!-- Tab 1: Enter Code -->
                                    <div class="checkin-tab-content active" id="tab-code">
                                        <form asp-action="CheckInWithCode" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="eventId" value="@Model.Id" />
                                            <div class="mb-2">
                                                <input type="text" name="code" class="form-control text-center font-mono text-uppercase fw-bold py-2" 
                                                       placeholder="Nhập mã điểm danh" maxlength="10" required autocomplete="off" />
                                            </div>
                                            <button type="submit" class="btn btn-success w-100 py-2 rounded-3">
                                                <i class="bi bi-check-circle me-1"></i>Xác nhận điểm danh
                                            </button>
                                        </form>
                                    </div>

                                    <!-- Tab 2: Show QR Code -->
                                    <div class="checkin-tab-content" id="tab-qr" style="display:none;">
                                        <button type="button" class="btn btn-primary w-100 py-2 rounded-3" id="btnGenerateQr" data-event-id="@Model.Id">
                                            <i class="bi bi-qr-code-scan me-1"></i>Hiển thị mã QR điểm danh
                                        </button>
                                    </div>
                                </div>

                                <!-- QR Modal -->
                                <div class="modal fade" id="qrCodeModal" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog modal-dialog-centered modal-sm">
                                        <div class="modal-content text-center p-3 rounded-4 shadow">
                                            <div class="modal-header border-0 pb-0">
                                                <h5 class="modal-title fw-bold fs-6 mx-auto">Mã QR điểm danh</h5>
                                                <button type="button" class="btn-close ms-0" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body py-3">
                                                <div id="qrCodeContainer" class="qr-code-box mx-auto my-2 p-2 bg-light border rounded-3 flex items-center justify-center" style="width: 192px; height: 192px;">
                                                    <div class="spinner-border text-primary" role="status">
                                                        <span class="visually-hidden">Đang tải...</span>
                                                    </div>
                                                </div>
                                                <p id="qrCodeText" class="fw-bold font-mono text-primary fs-5 mb-1 tracking-wider"></p>
                                                <p id="qrExpiryText" class="text-muted small mb-0"></p>
                                                <div id="qrErrorAlert" class="alert alert-danger py-1 px-2 small mt-2 mb-0" style="display:none;"></div>
                                            </div>
                                            <div class="modal-footer border-0 pt-0 justify-content-center">
                                                <small class="text-muted">Đưa mã QR này cho ban tổ chức để quét điểm danh</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <form asp-action="Cancel" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="eventId" value="@Model.Id" />
                                    <button type="submit" class="btn-danger-outline w-100 py-2">
                                        <i class="ri-close-circle-line"></i> Hủy đăng ký vé
                                    </button>
                                </form>
                            }
                        }
                        else if (ViewBag.RegistrationStatus == EMS.Core.Entities.Enums.RegistrationStatus.PendingPayment)
                        {
                            <div class="alert-glass alert-glass-warning mb-3" style="justify-content:center;">
                                <i class="ri-wallet-2-line"></i>
                                <span style="font-size:0.85rem;">Vé đang chờ thanh toán (VNPAY).</span>
                            </div>
                            <a href="@Url.Action("Pay", "Payment", new { registrationId = ViewBag.RegistrationId })" class="btn-cta w-100 justify-content-center py-3 mb-2" style="background: linear-gradient(135deg, #005baa, #007bff); border: none;">
                                <span>Thanh toán ngay</span>
                                <span class="btn-icon-circle"><i class="ri-bank-card-line"></i></span>
                            </a>
                            <form asp-action="Cancel" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="eventId" value="@Model.Id" />
                                <button type="submit" class="btn-danger-outline w-100 py-2">
                                    <i class="ri-close-circle-line"></i> Hủy đăng ký
                                </button>
                            </form>
                        }
                        else if (ViewBag.RegistrationStatus == EMS.Core.Entities.Enums.RegistrationStatus.Pending)
                        {
                            <div class="alert-glass alert-glass-warning mb-3" style="justify-content:center;">
                                <i class="ri-hourglass-line"></i>
                                <span style="font-size:0.85rem;">Đăng ký đang chờ phê duyệt.</span>
                            </div>
                            <form asp-action="Cancel" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="eventId" value="@Model.Id" />
                                <button type="submit" class="btn-danger-outline w-100 py-2">
                                    <i class="ri-close-circle-line"></i> Hủy yêu cầu đăng ký
                                </button>
                            </form>
                        }
                        else if (ViewBag.RegistrationStatus == EMS.Core.Entities.Enums.RegistrationStatus.Rejected)
                        {
                            <div class="alert-glass alert-glass-danger mb-3" style="justify-content:center;">
                                <i class="ri-forbid-line"></i>
                                <span style="font-size:0.85rem;">Đăng ký của bạn đã bị từ chối.</span>
                            </div>
                            <form asp-action="Register" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="eventId" value="@Model.Id" />
                                <button type="submit" class="btn-cta w-100 justify-content-center py-3">
                                    <span>Đăng ký lại</span>
                                    <span class="btn-icon-circle"><i class="ri-refresh-line"></i></span>
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Register" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="eventId" value="@Model.Id" />
                                <button type="submit" class="btn-cta w-100 justify-content-center py-3">
                                    @if (Model.IsFree)
                                    {
                                        <span>Đăng ký vé miễn phí</span>
                                        <span class="btn-icon-circle"><i class="ri-flashlight-line"></i></span>
                                    }
                                    else
                                    {
                                        <span>Mua vé ngay (@Model.Price.ToString("N0") VNĐ)</span>
                                        <span class="btn-icon-circle"><i class="ri-shopping-cart-2-line"></i></span>
                                    }
                                </button>
                            </form>
                        }
                    }
                    else
                    {
                        <div class="alert-glass alert-glass-warning mb-3" style="justify-content:center;">
                            <i class="ri-error-warning-line"></i>
                            <span style="font-size:0.85rem;">Bạn cần đăng nhập để đăng ký.</span>
                        </div>
                        <a asp-controller="Auth" asp-action="Login" class="btn-cta w-100 justify-content-center py-2">
                            <span>Đăng nhập ngay</span>
                            <span class="btn-icon-circle"><i class="ri-login-box-line"></i></span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .checkin-tab-content { display: none; }
    .checkin-tab-content.active { display: block; }
    .checkin-tab.active { background-color: var(--bs-primary, #4f46e5); color: #fff !important; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Tab switching
        var tabs = document.querySelectorAll('.checkin-tab');
        tabs.forEach(function (tab) {
            tab.addEventListener('click', function () {
                tabs.forEach(function (t) { t.classList.remove('active'); });
                tab.classList.add('active');
                document.querySelectorAll('.checkin-tab-content').forEach(function (c) {
                    c.classList.remove('active');
                    c.style.display = 'none';
                });
                var target = document.getElementById(tab.getAttribute('data-tab'));
                if (target) {
                    target.classList.add('active');
                    target.style.display = 'block';
                }
            });
        });

        // QR Code generation handler
        var btnGenerateQr = document.getElementById('btnGenerateQr');
        if (btnGenerateQr) {
            btnGenerateQr.addEventListener('click', function () {
                var eventId = this.getAttribute('data-event-id');
                var modalEl = document.getElementById('qrCodeModal');
                var container = document.getElementById('qrCodeContainer');
                var textEl = document.getElementById('qrCodeText');
                var expiryEl = document.getElementById('qrExpiryText');
                var errorEl = document.getElementById('qrErrorAlert');

                container.innerHTML = '<div class="spinner-border text-primary" role="status"><span class="visually-hidden">Đang tải...</span></div>';
                textEl.textContent = '';
                expiryEl.textContent = '';
                errorEl.style.display = 'none';

                var modal = new bootstrap.Modal(modalEl);
                modal.show();

                var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

                console.log("Generating QR Code for event:", eventId, "with token:", token);
                fetch('/Events/GenerateQrCode', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: 'eventId=' + encodeURIComponent(eventId) + '&__RequestVerificationToken=' + encodeURIComponent(token)
                })
                .then(function (r) {
                    console.log("HTTP response status:", r.status);
                    if (!r.ok) {
                        return r.text().then(function (text) {
                            throw new Error("HTTP " + r.status + ": " + text);
                        });
                    }
                    return r.json();
                })
                .then(function (data) {
                    console.log("Received QR response data:", data);
                    if (data.success) {
                        container.innerHTML = '';
                        
                        var img = document.createElement('img');
                        img.src = 'https://api.qrserver.com/v1/create-qr-code/?size=176x176&data=' + encodeURIComponent(data.code);
                        img.alt = 'QR Code';
                        img.className = 'img-fluid mx-auto';
                        img.style.width = '176px';
                        img.style.height = '176px';
                        
                        img.onerror = function () {
                            console.warn("Primary QR API failed, falling back to Google Charts API...");
                            this.src = 'https://chart.googleapis.com/chart?cht=qr&chs=176x176&chl=' + encodeURIComponent(data.code);
                            
                            this.onerror = function () {
                                console.warn("Google Charts API failed, falling back to QuickChart API...");
                                this.src = 'https://quickchart.io/qr?text=' + encodeURIComponent(data.code) + '&size=176';
                                
                                this.onerror = function () {
                                    console.error("All QR generation APIs failed.");
                                    container.innerHTML = '<span class="text-danger small">Lỗi tải QR</span>';
                                };
                            };
                        };
                        
                        container.appendChild(img);
                        textEl.textContent = data.code;
                        if (data.expiresAt) {
                            expiryEl.innerHTML = '<i class="bi bi-clock me-1"></i>Hết hạn: ' + data.expiresAt;
                        }
                    } else {
                        container.innerHTML = '<i class="bi bi-exclamation-triangle text-warning fs-1"></i>';
                        errorEl.textContent = data.error;
                        errorEl.style.display = 'block';
                    }
                })
                .catch(function (err) {
                    console.error("AJAX request failed:", err);
                    container.innerHTML = '<i class="bi bi-wifi-off text-danger fs-1"></i>';
                    errorEl.textContent = 'Lỗi kết nối: ' + err.message;
                    errorEl.style.display = 'block';
                });
            });
        }
    });
</script>

