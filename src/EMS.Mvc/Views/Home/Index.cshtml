@using System.Security.Claims
@model List<EMS.Core.Entities.Event>
@{
    ViewData["Title"] = "Trang chủ";
    string? userSession = Context.Request.Cookies["user_session"];
    string? displayName = ViewBag.DisplayName as string ?? Context.User.FindFirstValue(ClaimTypes.Name);
    string? tenantLabel = null;
    bool isGuest = ViewBag.IsGuest is bool guestFlag ? guestFlag : !(Context.User.Identity?.IsAuthenticated ?? false);
    if (!string.IsNullOrEmpty(userSession))
    {
        var parts = userSession.Split('|');
        displayName = parts.Length >= 1 ? parts[0] : null;
        tenantLabel = Context.Items["TenantName"]?.ToString();
    }

    var now = DateTime.UtcNow;
    var rawEvents = Model?.ToList() ?? new List<EMS.Core.Entities.Event>();

    // Sắp xếp: Đang diễn ra → Chưa diễn ra → Đã kết thúc/Đã hủy
    int StatusOrder(EMS.Core.Entities.Event ev) {
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Cancelled ||
            ev.Status == EMS.Core.Entities.Enums.EventStatus.Rejected) return 3;
        if (now >= ev.StartTime && now <= ev.EndTime) return 0;  // Đang diễn ra
        if (now < ev.StartTime) return 1;                        // Chưa diễn ra
        return 2;                                                 // Đã kết thúc
    }
    var allEvents = rawEvents.OrderBy(StatusOrder).ThenBy(e => e.StartTime).ToList();

    int pageSize = 3;
    int pageCount = allEvents.Count == 0 ? 1 : (int)Math.Ceiling(allEvents.Count / (double)pageSize);
}

@functions {
    string GetEventStatusClass(EMS.Core.Entities.Event ev)
    {
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Cancelled)
            return "status-badge-ended";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Rejected)
            return "status-badge-ended";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Pending)
            return "status-badge-upcoming";

        var now = DateTime.UtcNow;
        if (now < ev.StartTime)
            return "status-badge-upcoming";
        if (now >= ev.StartTime && now <= ev.EndTime)
            return "status-badge-ongoing";
        return "status-badge-ended";
    }

    string GetEventStatusName(EMS.Core.Entities.Event ev)
    {
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Cancelled)
            return "Đã hủy";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Rejected)
            return "Đã từ chối";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Pending)
            return "Chờ phê duyệt";

        var now = DateTime.UtcNow;
        if (now < ev.StartTime)
            return "Chưa diễn ra";
        if (now >= ev.StartTime && now <= ev.EndTime)
            return "Đang diễn ra";
        return "Đã kết thúc";
    }
}

<!-- ═══ Hero Section (Aplot Style) ═══ -->
<section class="text-center py-4 my-3 position-relative">
    <span class="eyebrow-tag">
        <i class="ri-sparkles-line"></i> Aplot AI Student Hub
    </span>

    @if (!isGuest && displayName != null)
    {
        <h1 class="heading-gradient heading-gradient-lg mb-3">
            Chào mừng trở lại,<br/>@displayName!
        </h1>
        <p class="subtitle-text mb-4 mx-auto" style="max-width: 620px;">
            Khám phá các sự kiện học thuật, workshop công nghệ & hoạt động ngoại khóa nổi bật tuần này.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap mb-4">
            <a href="#events" class="btn-cta">
                <span>Xem sự kiện</span>
                <span class="btn-icon-circle"><i class="ri-calendar-2-line"></i></span>
            </a>
            <a asp-controller="Events" asp-action="MyEvents" class="btn-cta-outline">
                <i class="ri-ticket-2-line"></i>
                <span>Vé của tôi</span>
            </a>
        </div>
    }
    else
    {
        <h1 class="heading-gradient heading-gradient-lg mb-3">
            Kết nối sinh viên &<br/>Khám phá sự kiện học đường
        </h1>
        <p class="subtitle-text mb-4 mx-auto" style="max-width: 620px;">
            Đăng ký tham gia, điểm danh QR-code và tích lũy điểm rèn luyện thông qua các hoạt động ngoại khóa một cách dễ dàng.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap mb-4">
            <a asp-controller="Auth" asp-action="Register" class="btn-cta">
                <span>Bắt đầu ngay</span>
                <span class="btn-icon-circle"><i class="ri-arrow-right-up-line"></i></span>
            </a>
            <a href="#events" class="btn-cta-outline">
                <i class="ri-compass-3-line"></i>
                <span>Tìm hiểu thêm</span>
            </a>
        </div>
    }

    <!-- ═══ Aplot Floating 3D Search Dock ═══ -->
    <div class="aplot-dock-wrapper">
        <div class="aplot-dock-card p-2">
            <!-- Borderless Search Bar -->
            <form asp-controller="Events" asp-action="Index" method="get">
                <div class="d-flex align-items-center gap-2 px-2 py-1">
                    <i class="ri-search-2-line text-muted" style="font-size:1.3rem;"></i>
                    <input type="text" name="search" class="dock-input-area border-0 bg-transparent flex-grow-1" placeholder="Tìm kiếm sự kiện, diễn giả, địa điểm..." style="min-height:auto;" />
                    <button type="submit" class="btn-send-circle flex-shrink-0" aria-label="Tìm kiếm sự kiện" title="Tìm kiếm">
                        <i class="ri-arrow-right-line"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

<!-- ═══ Upcoming Registered Event / Live Ongoing Agenda Banner ═══ -->
@if (ViewBag.UpcomingBanner != null)
{
    @await Html.PartialAsync("_UpcomingEventBanner", ViewBag.UpcomingBanner as EMS.Mvc.Models.UpcomingEventBannerViewModel)
}

<!-- ═══ Statistics — Double Bezel Architecture ═══ -->
<div class="row g-4 my-4 justify-content-center">
    <div class="col-md-4 col-sm-6 d-flex flex-column">
        <div class="bezel-outer stat-card-wrapper">
            <div class="bezel-inner glass-card-strong">
                <div class="stat-value stat-value-aplot text-primary-custom">@(Model?.Count ?? 0)+</div>
                <div class="stat-label stat-label-aplot">Sự kiện đang mở đăng ký</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6 d-flex flex-column">
        <div class="bezel-outer stat-card-wrapper">
            <div class="bezel-inner glass-card-strong">
                <div class="stat-value stat-value-aplot text-success-custom">1,500+</div>
                <div class="stat-label stat-label-aplot">Lượt sinh viên tham gia</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6 d-flex flex-column">
        <div class="bezel-outer stat-card-wrapper">
            <div class="bezel-inner glass-card-strong">
                <div class="stat-value stat-value-aplot text-warning-custom">98%</div>
                <div class="stat-label stat-label-aplot">Đánh giá trải nghiệm tích cực</div>
            </div>
        </div>
    </div>
</div>

<!-- ═══ Featured Events Section (Double-Bezel Cards) ═══ -->
<section class="my-5" id="events">
    <div class="d-flex justify-content-between align-items-end mb-4 px-2 px-md-4">
        <div>
            <span class="eyebrow-tag"><i class="ri-fire-line" style="color:var(--accent-rose);"></i> @(isGuest ? "Sự kiện trường bạn" : "Đang Diễn Ra")</span>
            <h2 class="h3 fw-bold mb-1">
                @(isGuest ? "Khám phá sự kiện nổi bật" : "Sự kiện mới nhất")
            </h2>
            <p class="text-secondary mb-0" style="font-size:0.92rem;">
                @(isGuest ? "Đăng nhập để xem đầy đủ danh sách sự kiện và đăng ký nhanh." : "Danh sách các hoạt động học đường đang tiếp nhận đăng ký")
            </p>
        </div>
        <a asp-controller="Events" asp-action="Index" class="btn-cta-outline btn-cta-sm d-none d-sm-inline-flex">
            <span>Xem tất cả</span>
            <i class="ri-arrow-right-line"></i>
        </a>
    </div>

    @if (!allEvents.Any())
    {
        <div class="glass-panel text-center py-5 my-4">
            <div class="mb-3" style="font-size:3rem; color:var(--text-muted);"><i class="ri-calendar-close-line"></i></div>
            <h5 class="fw-bold" style="color:var(--text-main);">Hiện tại chưa có sự kiện nào.</h5>
            <p class="text-muted small">Hãy quay lại sau để cập nhật các sự kiện mới nhất!</p>
        </div>
    }
    else
    {
        <!-- Slider Outer -->
        <div class="slider-outer overflow-hidden w-100">
            <div class="slider-viewport overflow-hidden w-100">
                <div id="evtTrack" style="display:flex; width:@(pageCount * 100)%; transition:transform 0.6s var(--ease-aplot); will-change:transform;">
                    @for (int p = 0; p < pageCount; p++)
                    {
                        var pageEvts = allEvents.Skip(p * pageSize).Take(pageSize).ToList();
                        <div style="flex-shrink:0; width:@(Math.Round(100.0/pageCount,6))%; box-sizing:border-box; padding:4px 0;">
                            <div class="row g-3 g-md-4 m-0 justify-content-center">
                                @foreach (var ev in pageEvts)
                                {
                                    <div class="col-lg-4 col-md-6 col-12">
                                        <div class="event-glass-card event-card-aplot">
                                            <!-- Image Shell -->
                                            <div class="event-image-wrap event-image-shell">
                                                <img src="@(string.IsNullOrEmpty(ev.ImageUrl) ? "https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=800&auto=format&fit=crop&q=60" : ev.ImageUrl)"
                                                     alt="@ev.Title"
                                                     onerror="this.onerror=null;this.src='https://placehold.co/800x400/6366f1/ffffff?text=EMS+Event';">
                                                <span class="event-badge status-badge-pill @GetEventStatusClass(ev)">
                                                    @GetEventStatusName(ev)
                                                </span>
                                            </div>

                                            <!-- Card Body -->
                                            <div class="event-card-body event-card-body-aplot">
                                                <h3 class="event-card-title event-title-aplot">@ev.Title</h3>
                                                <div class="event-card-meta event-meta-aplot">
                                                    <div class="event-meta-item">
                                                        <i class="ri-time-line"></i>
                                                        <span><datetime-format date="@ev.StartTime" format="dd/MM/yyyy HH:mm"></datetime-format> – <datetime-format date="@ev.EndTime" format="HH:mm"></datetime-format></span>
                                                    </div>
                                                    <div class="event-meta-item">
                                                        <i class="ri-map-pin-2-line"></i>
                                                        <span class="text-truncate">@ev.Location</span>
                                                    </div>
                                                </div>
                                                @{
                                                    var dsc = (ev.Description?.Length > 110)
                                                        ? ev.Description.Substring(0, 107) + "..."
                                                        : (ev.Description ?? "");
                                                }
                                                <p class="event-card-desc event-desc-aplot">@dsc</p>

                                                <!-- Card Footer -->
                                                @{
                                                    var remainingSlotsDict = ViewBag.RemainingSlots as Dictionary<string, int>;
                                                    int remaining = -1;
                                                    if (remainingSlotsDict != null && remainingSlotsDict.TryGetValue(ev.Id, out var r))
                                                    {
                                                        remaining = r;
                                                    }
                                                    string remainingText = remaining >= 0 ? remaining.ToString() : "Không giới hạn";
                                                }
                                                <div class="event-card-footer event-card-footer-aplot">
                                                    <span class="capacity-badge-pill" id="event-remaining-@ev.Id">
                                                        <i class="ri-group-line" style="color:var(--primary-indigo);"></i> 
                                                        Chỗ còn: <strong class="remaining-value ms-1" style="color:var(--text-main);">@remainingText</strong>
                                                    </span>
                                                    <a asp-controller="Events" asp-action="Detail" asp-route-id="@ev.Id" class="btn-cta btn-cta-sm">
                                                        <span>Chi tiết</span>
                                                        <span class="btn-icon-circle"><i class="ri-arrow-right-up-line"></i></span>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Slider Arrows -->
            <div class="d-flex justify-content-center align-items-center gap-3 mt-4">
                <button class="btn-cta-outline btn-cta-sm" id="evtPrev" aria-label="Trang trước">
                    <i class="ri-arrow-left-s-line"></i> Trước
                </button>
                <div class="slider-dots d-flex gap-2" id="evtDots">
                    @for (int p = 0; p < pageCount; p++)
                    {
                        <button class="pill-chip py-1 px-3 @(p == 0 ? "active" : "")" data-page="@p" aria-label="Trang @(p+1)" style="font-size:0.78rem;">
                            @(p + 1)
                        </button>
                    }
                </div>
                <button class="btn-cta-outline btn-cta-sm" id="evtNext" aria-label="Trang tiếp">
                    Tiếp <i class="ri-arrow-right-s-line"></i>
                </button>
            </div>
        </div>
    }
</section>

<!-- ═══ View Component Section ═══ -->
<section class="my-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            @await Component.InvokeAsync("UpcomingEvents")
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
    <script>
        const hubConnection = new signalR.HubConnectionBuilder()
            .withUrl("https://localhost:7296/notificationHub")
            .withAutomaticReconnect()
            .build();

        hubConnection.on("ReceiveEventCapacityUpdate", (eventId, remainingSlots) => {
            const el = document.getElementById("event-remaining-" + eventId);
            if (el) {
                const valEl = el.querySelector(".remaining-value");
                if (valEl) {
                    valEl.innerText = remainingSlots >= 0 ? remainingSlots : "Không giới hạn";
                }
                el.style.transition = "color 0.5s";
                el.style.color = "var(--primary-indigo, #6366f1)";
                setTimeout(() => { el.style.color = ""; }, 1000);
            }
        });

        hubConnection.start().catch(err => console.error(err.toString()));
    </script>
    <script>
        (function () {
            var INTERVAL = 8000;
            var track = document.getElementById('evtTrack');
            var prev = document.getElementById('evtPrev');
            var next = document.getElementById('evtNext');
            var dotsWrap = document.getElementById('evtDots');
            if (!track || !prev || !next) return;

            var dots = dotsWrap ? Array.from(dotsWrap.querySelectorAll('[data-page]')) : [];
            var total = dots.length || 1;
            var cur = 0;
            var timer = null;

            function goTo(n) {
                cur = ((n % total) + total) % total;
                track.style.transform = 'translateX(-' + (cur * (100 / total)) + '%)';
                dots.forEach(function (d, i) {
                    if (i === cur) {
                        d.classList.add('active');
                    } else {
                        d.classList.remove('active');
                    }
                });

                // Trigger smooth GSAP reveal on current page cards
                if (typeof gsap !== 'undefined') {
                    var currentEvtCards = track.querySelectorAll('.event-glass-card');
                    gsap.fromTo(currentEvtCards, 
                        { y: 15, opacity: 0.8 }, 
                        { y: 0, opacity: 1, duration: 0.45, ease: 'power2.out', stagger: 0.08, clearProps: 'transform,opacity' }
                    );
                }
            }

            function startAuto() {
                clearInterval(timer);
                if (total > 1) {
                    timer = setInterval(function () { goTo(cur + 1); }, INTERVAL);
                }
            }

            prev.addEventListener('click', function (e) {
                e.preventDefault();
                goTo(cur - 1);
                startAuto();
            });

            next.addEventListener('click', function (e) {
                e.preventDefault();
                goTo(cur + 1);
                startAuto();
            });

            dots.forEach(function (d) {
                d.addEventListener('click', function (e) {
                    e.preventDefault();
                    goTo(+d.dataset.page);
                    startAuto();
                });
            });

            track.addEventListener('mouseenter', function () { clearInterval(timer); });
            track.addEventListener('mouseleave', startAuto);

            // Initialize position
            goTo(0);
            startAuto();
        })();
    </script>
}

