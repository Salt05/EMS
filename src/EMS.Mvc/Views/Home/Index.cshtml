@using System.Security.Claims
@model List<EMS.Core.Entities.Event>
@{
    ViewData["Title"] = "Trang chủ";
    string? userSession = Context.Request.Cookies["user_session"];
    string? displayName = ViewBag.DisplayName as string ?? Context.User.FindFirstValue(ClaimTypes.Name);
    string? tenantLabel = null;
    bool isGuest = ViewBag.IsGuest is bool guestFlag ? guestFlag : !(Context.User.Identity?.IsAuthenticated ?? false);
    if (!string.IsNullOrEmpty(userSession))
    {
        var parts = userSession.Split('|');
        displayName = parts.Length >= 1 ? parts[0] : null;
        // Lấy tenant name từ Context.Items
        tenantLabel = Context.Items["TenantName"]?.ToString();
    }

    var now = DateTime.UtcNow;
    var rawEvents = Model?.ToList() ?? new List<EMS.Core.Entities.Event>();

    // Sắp xếp: Đang diễn ra → Chưa diễn ra → Đã kết thúc/Đã hủy
    int StatusOrder(EMS.Core.Entities.Event ev) {
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Cancelled ||
            ev.Status == EMS.Core.Entities.Enums.EventStatus.Rejected) return 3;
        if (now >= ev.StartTime && now <= ev.EndTime) return 0;  // Đang diễn ra
        if (now < ev.StartTime) return 1;                        // Chưa diễn ra
        return 2;                                                 // Đã kết thúc
    }
    var allEvents = rawEvents.OrderBy(StatusOrder).ThenBy(e => e.StartTime).ToList();

    int pageSize = 3;
    int pageCount = allEvents.Count == 0 ? 1 : (int)Math.Ceiling(allEvents.Count / (double)pageSize);
}

@functions {
    string GetEventStatusClass(EMS.Core.Entities.Event ev)
    {
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Cancelled)
            return "status-badge-cancelled";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Rejected)
            return "status-badge-rejected";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Pending)
            return "status-badge-pending";

        var now = DateTime.UtcNow;
        if (now < ev.StartTime)
            return "status-badge-upcoming";
        if (now >= ev.StartTime && now <= ev.EndTime)
            return "status-badge-ongoing";
        return "status-badge-ended";
    }

    string GetEventStatusName(EMS.Core.Entities.Event ev)
    {
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Cancelled)
            return "Đã hủy";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Rejected)
            return "Đã từ chối";
        if (ev.Status == EMS.Core.Entities.Enums.EventStatus.Pending)
            return "Chờ phê duyệt";

        var now = DateTime.UtcNow;
        if (now < ev.StartTime)
            return "Chưa diễn ra";
        if (now >= ev.StartTime && now <= ev.EndTime)
            return "Đang diễn ra";
        return "Đã kết thúc";
    }
}

<!-- ═══ Hero Section ═══ -->
<section class="hero-section">
    <span class="eyebrow-tag">Hệ Thống Quản Lý Sự Kiện</span>

    @if (!isGuest && displayName != null)
    {
        <h1 class="heading-gradient heading-gradient-lg mb-3">
            Chào mừng trở lại,<br/>@displayName!
        </h1>
        <p class="subtitle-text mb-4" style="max-width:560px; margin-left:auto; margin-right:auto;">
            Khám phá các sự kiện học thuật, câu lạc bộ, nghệ thuật nổi bật nhất dành riêng cho bạn tuần này.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a href="#events" class="btn-cta">
                <span>Xem sự kiện</span>
                <span class="btn-icon-circle"><i class="ri-calendar-2-line"></i></span>
            </a>
            <a asp-controller="Events" asp-action="MyEvents" class="btn-cta-outline">
                <i class="ri-ticket-2-line"></i>
                <span>Vé của tôi</span>
            </a>
        </div>
    }
    else
    {
        <h1 class="heading-gradient heading-gradient-lg mb-3">
            Kết nối sinh viên &<br/>Khám phá sự kiện học đường
        </h1>
        <p class="subtitle-text mb-4" style="max-width:560px; margin-left:auto; margin-right:auto;">
            Đăng ký tham gia, điểm danh QR-code và tích lũy điểm rèn luyện thông qua các hoạt động ngoại khóa một cách dễ dàng.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Auth" asp-action="Register" class="btn-cta">
                <span>Bắt đầu ngay</span>
                <span class="btn-icon-circle"><i class="ri-arrow-right-up-line"></i></span>
            </a>
            <a href="#events" class="btn-cta-outline">
                <i class="ri-compass-3-line"></i>
                <span>Tìm hiểu thêm</span>
            </a>
        </div>
    }
</section>

<!-- ═══ Statistics — Double Bezel ═══ -->
<div class="row g-4 mb-5 justify-content-center">
    <div class="col-md-3 col-sm-6">
        <div class="bezel-outer">
            <div class="bezel-inner glass-card-strong p-4 stat-card">
                <div class="stat-value text-primary-custom">@(Model?.Count ?? 0)+</div>
                <div class="stat-label">Sự kiện đang mở</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="bezel-outer">
            <div class="bezel-inner glass-card-strong p-4 stat-card">
                <div class="stat-value text-success-custom">1,500+</div>
                <div class="stat-label">Sinh viên đăng ký</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="bezel-outer">
            <div class="bezel-inner glass-card-strong p-4 stat-card">
                <div class="stat-value text-warning-custom">98%</div>
                <div class="stat-label">Phản hồi tích cực</div>
            </div>
        </div>
    </div>
</div>

<!-- ═══ Event Slider Section ═══ -->
<section class="my-5" id="events">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <span class="eyebrow-tag">@(isGuest ? "Sự kiện trường bạn" : "Đang Diễn Ra")</span>
            <h2 class="section-heading">
                <i class="ri-fire-line text-danger-custom me-2"></i>@(isGuest ? "Khám phá sự kiện" : "Sự kiện nổi bật")
            </h2>
            <p class="text-muted-custom mb-0">@(isGuest ? "Đăng nhập để xem đầy đủ danh sách sự kiện." : "Danh sách sự kiện đang mở đăng ký tham gia")</p>
        </div>
        <a asp-controller="Events" asp-action="Index"
           class="btn-cta-outline btn-cta-sm d-none d-sm-inline-flex">
            <span>Xem tất cả</span>
            <span class="btn-icon-circle"><i class="ri-arrow-right-line"></i></span>
        </a>
    </div>

    @if (!allEvents.Any())
    {
        <div class="text-center py-5">
            <div class="mb-3" style="font-size:3rem; color:var(--text-muted);"><i class="ri-calendar-close-line"></i></div>
            <h5 style="color:var(--text-secondary);">Hiện tại chưa có sự kiện nào.</h5>
        </div>
    }
    else
    {
        <!-- Slider outer -->
        <div class="slider-outer">
            <!-- Viewport -->
            <div class="slider-viewport">
                <div id="evtTrack"
                     style="display:flex; width:@(pageCount * 100)%; transition:transform 0.6s cubic-bezier(0.4,0,0.2,1); will-change:transform;">
                    @for (int p = 0; p < pageCount; p++)
                    {
                        var pageEvts = allEvents.Skip(p * pageSize).Take(pageSize).ToList();
                        <div style="flex-shrink:0; width:@(Math.Round(100.0/pageCount,6))%; box-sizing:border-box; padding:4px 0;">
                            <div class="row g-4">
                                @foreach (var ev in pageEvts)
                                {
                                    <div class="col-lg-4 col-md-6 col-12">
                                        <div class="event-glass-card">
                                            <!-- Double-bezel image -->
                                            <div class="event-image-wrap">
                                                <div class="event-image-shell">
                                                    <img src="@(string.IsNullOrEmpty(ev.ImageUrl) ? "https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=800&auto=format&fit=crop&q=60" : ev.ImageUrl)"
                                                         alt="@ev.Title"
                                                         onerror="this.onerror=null;this.src='https://placehold.co/800x400/6366f1/ffffff?text=EMS+Event';">
                                                    <span class="event-badge @GetEventStatusClass(ev)">@GetEventStatusName(ev)</span>
                                                </div>
                                            </div>
                                            <!-- Content -->
                                            <div class="event-card-body">
                                                <h5 class="event-card-title">@ev.Title</h5>
                                                <div class="event-card-meta">
                                                    <div><i class="ri-time-line"></i> <datetime-format date="@ev.StartTime" format="dd/MM/yyyy HH:mm"></datetime-format> – <datetime-format date="@ev.EndTime" format="HH:mm"></datetime-format></div>
                                                    <div><i class="ri-map-pin-2-line"></i> @ev.Location</div>
                                                </div>
                                                @{
                                                    var dsc = (ev.Description?.Length > 110)
                                                        ? ev.Description.Substring(0, 107) + "..."
                                                        : (ev.Description ?? "");
                                                }
                                                <p class="event-card-desc">@dsc</p>
                                            </div>
                                            <!-- Footer -->
                                            @{
                                                var remainingSlotsDict = ViewBag.RemainingSlots as Dictionary<string, int>;
                                                int remaining = -1;
                                                if (remainingSlotsDict != null && remainingSlotsDict.TryGetValue(ev.Id, out var r))
                                                {
                                                    remaining = r;
                                                }
                                                string remainingText = remaining >= 0 ? remaining.ToString() : "Không giới hạn";
                                            }
                                            <div class="event-card-footer">
                                                <span id="event-remaining-@ev.Id"><i class="ri-group-line me-1"></i> Số lượng còn lại: <span class="remaining-value">@remainingText</span></span>
                                                <a asp-controller="Events" asp-action="Detail" asp-route-id="@ev.Id"
                                                   class="btn-cta btn-cta-sm">
                                                    <span>Chi tiết</span>
                                                    <span class="btn-icon-circle"><i class="ri-arrow-right-up-line"></i></span>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Arrow buttons -->
            <button class="slider-arrow slider-arrow-prev" id="evtPrev" aria-label="Trước">
                <i class="ri-arrow-left-s-line"></i>
            </button>
            <button class="slider-arrow slider-arrow-next" id="evtNext" aria-label="Tiếp">
                <i class="ri-arrow-right-s-line"></i>
            </button>
        </div>

        <!-- Dots -->
        <div class="slider-dots" id="evtDots">
            @for (int p = 0; p < pageCount; p++)
            {
                <button class="slider-dot @(p == 0 ? "active" : "")"
                        data-page="@p" aria-label="Trang @(p+1)"></button>
            }
        </div>
    }
</section>

<!-- ═══ View Component Section ═══ -->
<section class="my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            @await Component.InvokeAsync("UpcomingEvents")
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
    <script>
        const hubConnection = new signalR.HubConnectionBuilder()
            .withUrl("https://localhost:7296/notificationHub")
            .withAutomaticReconnect()
            .build();

        hubConnection.on("ReceiveEventCapacityUpdate", (eventId, remainingSlots) => {
            const el = document.getElementById("event-remaining-" + eventId);
            if (el) {
                const valEl = el.querySelector(".remaining-value");
                if (valEl) {
                    valEl.innerText = remainingSlots >= 0 ? remainingSlots : "Không giới hạn";
                }
                el.style.transition = "color 0.5s";
                el.style.color = "var(--primary-color, #6366f1)";
                setTimeout(() => { el.style.color = ""; }, 1000);
            }
        });

        hubConnection.start().catch(err => console.error(err.toString()));
    </script>
    @if (!isGuest)
    {
        <script>
            (function () {
                var INTERVAL = 30000;
                var track = document.getElementById('evtTrack');
                var prev = document.getElementById('evtPrev');
                var next = document.getElementById('evtNext');
                var dotsWrap = document.getElementById('evtDots');
                if (!track || !prev || !next) return;

                var dots = dotsWrap ? Array.from(dotsWrap.querySelectorAll('.slider-dot')) : [];
                var total = dots.length || 1;
                var cur = 0;
                var timer = null;

                function goTo(n) {
                    cur = ((n % total) + total) % total;
                    track.style.transform = 'translateX(-' + (cur * 100 / total) + '%)';
                    dots.forEach(function (d, i) { d.classList.toggle('active', i === cur); });
                }

                function startAuto() {
                    clearInterval(timer);
                    timer = setInterval(function () { goTo(cur + 1); }, INTERVAL);
                }

                prev.addEventListener('click', function () { goTo(cur - 1); startAuto(); });
                next.addEventListener('click', function () { goTo(cur + 1); startAuto(); });
                dots.forEach(function (d) {
                    d.addEventListener('click', function () { goTo(+d.dataset.page); startAuto(); });
                });

                track.addEventListener('mouseenter', function () { clearInterval(timer); });
                track.addEventListener('mouseleave', startAuto);

                goTo(0);
                startAuto();
            })();
        </script>
    }
}
