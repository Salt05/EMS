{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Firebase": {
    "ProjectId": "ems-project",
    "ApiKey": "your-firebase-api-key",
    "AuthDomain": "ems-project.firebaseapp.com",
    "DatabaseURL": "https://ems-project.firebaseio.com",
    "StorageBucket": "ems-project.appspot.com",
    "MessagingSenderId": "your-messaging-sender-id",
    "AppId": "your-app-id"
  },
  "Jwt": {
    "SecretKey": "your-super-secret-key-min-32-characters-required",
    "Issuer": "ems",
    "Audience": "ems-users",
    "ExpirationMinutes": 60
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:4200",
    "http://localhost:5173"
  ]
}

